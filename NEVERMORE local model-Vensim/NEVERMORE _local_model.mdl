{UTF-8}
URBAN EXPANSION FROM WETLANDS=
	IF THEN ELSE((((EXPANSION RATIO*CONVERSION SPEED WETLANDS TO URBAN)/100)*URBAN*0.1)>\
		0, MIN(((EXPANSION RATIO*CONVERSION SPEED WETLANDS TO URBAN
	)/100)*URBAN*0.1, ((WETLANDS-PROTECTED WETLANDS)/1)) , 0)
	~	km2
	~		|

WETLANDS DESERTION=
	IF THEN ELSE( (WETLANDS*AGRICULTURAL PRESSURE)>0, MIN(( WETLANDS*AGRICULTURAL PRESSURE\
		) , (WETLANDS-PROTECTED WETLANDS
	)/1) , 0)
	~	km2
	~		|

PROTECTED WETLANDS NOT CORRECTED= INTEG (
	IF THEN ELSE(SWITCH PROTECTED WETLANDS=0,0,IF THEN ELSE(SWITCH PROTECTED WETLANDS
	=1:AND:(Time<INITIAL YEAR FOR PROTECTED WETLANDS),0,
	IF THEN ELSE(SWITCH PROTECTED WETLANDS=1:AND:(Time>FINAL YEAR FOR PROTECTED WETLANDS\
		-1),0,
	(INCREASE OBJECTIVE FOR PROTECTED WETLANDS/(FINAL YEAR FOR PROTECTED WETLANDS-INITIAL YEAR FOR PROTECTED WETLANDS
	))))),
		INITIAL PROTECTED WETLANDS)
	~	km2
	~	IF THEN ELSE(SWITCH PROTECTED WETLANDS=0,0,IF THEN ELSE(SWITCH PROTECTED WETLANDS
		=1:AND:(Time<INITIAL YEAR FOR PROTECTED WETLANDS),0,
		IF THEN ELSE(SWITCH PROTECTED WETLANDS=1:AND:(Time>FINAL YEAR FOR PROTECTED \
		WETLANDS-1),0,
		MIN((INCREASE OBJECTIVE FOR PROTECTED WETLANDS/(FINAL YEAR FOR PROTECTED \
		WETLANDS-INITIAL YEAR FOR PROTECTED WETLANDS
		)),DELAY AVAILABLE LAND))))
	|

PROTECTED FOREST LAND=
	IF THEN ELSE(PROTECTED FOREST LAND NOT CORRECTED>=FOREST,FOREST,PROTECTED FOREST LAND NOT CORRECTED\
		)
	~	
	~		|

AVAILABLE FOREST LAND=
	FOREST-PROTECTED FOREST LAND
	~	km2
	~		|

AVAILABLE LAND=
	WETLANDS-PROTECTED WETLANDS
	~	km2
	~		|

PROTECTED FOREST LAND NOT CORRECTED= INTEG (
	IF THEN ELSE(SWITCH PROTECTED FOREST LAND=0,0,IF THEN ELSE(SWITCH PROTECTED FOREST LAND
	=1:AND:(Time<INITIAL YEAR FOR PROTECTED FOREST LAND),0,
	IF THEN ELSE(SWITCH PROTECTED FOREST LAND=1:AND:(Time>FINAL YEAR FOR PROTECTED FOREST LAND\
		-1),0,
	(INCREASE OBJECTIVE FOR PROTECTED FOREST LAND/(FINAL YEAR FOR PROTECTED FOREST LAND-\
		INITIAL YEAR FOR PROTECTED FOREST LAND
	))))),
		INITIAL FOREST PROTECTED LAND)
	~	km2
	~		|

PROTECTED WETLANDS=
	IF THEN ELSE(PROTECTED WETLANDS NOT CORRECTED>=WETLANDS,WETLANDS,PROTECTED WETLANDS NOT CORRECTED\
		)
	~	km2
	~		|

ARTIFICIAL SNOW PRODUCTION MONTHLY[MONTHS]=
	IF THEN ELSE(SWITCH EFFECTS OF ARTIFICIAL SNOW PRODUCTION IN TOURISM=0,0,IF THEN ELSE\
		(MONTHS=MAY:OR:MONTHS=JUNE:OR:MONTHS
	=JULY:OR:MONTHS=AUGUST:OR:MONTHS=SEPTEMBER:OR:MONTHS=OCTOBER,0,IF THEN ELSE
	((SNOW VOLUME FOR SKIING-VOLUME SNOW ACCUMULATION[MONTHS])<0,SKI SLOPE AREA*0.2,IF THEN ELSE\
		(SWITCH SUSTAINABLE SNOWMAKING AND CONSERVATION PRACTICES
	=0,(SNOW VOLUME FOR SKIING
	-VOLUME SNOW ACCUMULATION[MONTHS])+SKI SLOPE AREA*0.2,IF THEN ELSE(SWITCH SUSTAINABLE SNOWMAKING AND CONSERVATION PRACTICES\
		=1:AND:Time<=INITIAL YEAR SUSTAINABLE SNOWMAKING AND CONSERVATION PRACTICES
	:OR:Time>=FINAL YEAR SUSTAINABLE SNOWMAKING AND CONSERVATION PRACTICES,SKI SLOPE AREA\
		*0.2+(SNOW VOLUME FOR SKIING-VOLUME SNOW ACCUMULATION[MONTHS]),MAX(SKI SLOPE AREA*0.2\
		+(SNOW VOLUME FOR SKIING-VOLUME SNOW ACCUMULATION[MONTHS])*(1-SUSTAINABLE SNOWMAKING AND CONSERVATION PRACTICES OBJECTIVE\
		)*((Time-INITIAL YEAR SUSTAINABLE SNOWMAKING AND CONSERVATION PRACTICES)/(FINAL YEAR SUSTAINABLE SNOWMAKING AND CONSERVATION PRACTICES
	-INITIAL YEAR SUSTAINABLE SNOWMAKING AND CONSERVATION PRACTICES)),SKI SLOPE AREA*0.2\
		))))))
	~	m3
	~	IF THEN ELSE(SWITCH EFFECTS OF ARTIFICIAL SNOW PRODUCTION IN TOURISM=0,0,IF THEN \
		ELSE(MONTHS=MAY:OR:MONTHS=JUNE:OR:MONTHS
		=JULY:OR:MONTHS=AUGUST:OR:MONTHS=SEPTEMBER:OR:MONTHS=OCTOBER,0,IF THEN ELSE
		((SNOW VOLUME FOR SKIING-VOLUME SNOW ACCUMULATION[MONTHS])<0,SKI SLOPE AREA*0.2,IF \
		THEN ELSE(SWITCH SUSTAINABLE SNOWMAKING AND CONSERVATION PRACTICES
		=0,(SNOW VOLUME FOR SKIING
		-VOLUME SNOW ACCUMULATION[MONTHS])+SKI SLOPE AREA*0.2,IF THEN ELSE(SWITCH \
		SUSTAINABLE SNOWMAKING AND CONSERVATION PRACTICES=1:AND:Time<=INITIAL YEAR \
		SUSTAINABLE SNOWMAKING AND CONSERVATION PRACTICES
		:OR:Time>=FINAL YEAR SUSTAINABLE SNOWMAKING AND CONSERVATION PRACTICES
		,SKI SLOPE AREA*0.2+(SNOW VOLUME FOR SKIING-VOLUME SNOW \
		ACCUMULATION[MONTHS]),MAX(SKI SLOPE AREA*0.2+(SNOW VOLUME FOR \
		SKIING-VOLUME SNOW ACCUMULATION[MONTHS])*SUSTAINABLE SNOWMAKING AND \
		CONSERVATION PRACTICES OBJECTIVE*((Time-INITIAL YEAR SUSTAINABLE \
		SNOWMAKING AND CONSERVATION PRACTICES)/(FINAL YEAR SUSTAINABLE SNOWMAKING \
		AND CONSERVATION PRACTICES
		-INITIAL YEAR SUSTAINABLE SNOWMAKING AND CONSERVATION PRACTICES))),SKI \
		SLOPE AREA*0.2)))))
	|

DAMAGE BY DEPTH IN ROADS RAILWAYS[RETURN PERIOD, FLOOD DEPTH]=
	ROADS RAILWAYS DAMAGE AT DEPTH[FLOOD DEPTH]*FLOOD AREA ROADS RAILWAYS[RETURN PERIOD,\
		FLOOD DEPTH]
	~	km2
	~		|

DAMAGE BY DEPTH IN URBAN[RETURN PERIOD, FLOOD DEPTH]=
	IF THEN ELSE (SWITCH POLICY FLOOD DEFENSES FOR URBAN AREAS = 0, URBAN DAMAGE AT DEPTH\
		[FLOOD DEPTH]*FLOOD AREA URBAN[RETURN PERIOD,FLOOD DEPTH],
	IF THEN ELSE (SWITCH POLICY FLOOD DEFENSES FOR URBAN AREAS = 1, URBAN DAMAGE AT DEPTH CONSIDERING FLOOD DEFENSES\
		[FLOOD DEPTH]*FLOOD AREA URBAN[RETURN PERIOD,FLOOD DEPTH], URBAN DAMAGE AT DEPTH[FLOOD DEPTH\
		]*FLOOD AREA URBAN[RETURN PERIOD,FLOOD DEPTH]))
	~	km2
	~		|

DAMAGE BY DEPTH IN OTHER[RETURN PERIOD,FLOOD DEPTH]=
	OTHER DAMAGE AT DEPTH[FLOOD DEPTH]*FLOOD AREA OTHER[RETURN PERIOD,FLOOD DEPTH]
	~	km2
	~		|

NEW INFRASTRUCTURE=
	IF THEN ELSE(SWITCH INVESTMENT IN TOURISTIC INFRASTRUCTURES=0,0,IF THEN ELSE(SWITCH INVESTMENT IN TOURISTIC INFRASTRUCTURES\
		=1:AND:Time<INITIAL YEAR INVESTMENT IN TOURISTIC INFRASTRUCTURES
	:OR:Time>FINAL YEAR INVESTMENT IN TOURISTIC INFRASTRUCTURES,0,(INVESTMENT IN TOURISTIC INFRASTRUCTURE OBJECTIVES\
		/(FINAL YEAR INVESTMENT IN TOURISTIC INFRASTRUCTURES-INITIAL YEAR INVESTMENT IN TOURISTIC INFRASTRUCTURES\
		))*(INFRASTRUCTURE CAPACITY)))
	~	Infrastructure
	~	IF THEN ELSE(SWITCH INVESTMENT IN INFRASTRUCTURE=0,0,IF THEN ELSE(SWITCH INVESTMENT \
		IN INFRASTRUCTURE=1:AND:Time<INITIAL YEAR INVESTMENT IN INFRASTRUCTURE
		:OR:Time>FINAL YEAR INVESTMENT IN INFRASTRUCTURE,0,(INVESTMENT IN INFRASTRUCTURE \
		OBJECTIVE/(FINAL YEAR INVESTMENT IN INFRASTRUCTURE
		-INITIAL YEAR INVESTMENT IN INFRASTRUCTURE))*(TOTAL \
		VISITORS-INFRASTRUCTURE CAPACITY)))
	|

FINAL YEAR INVESTMENT IN TOURISTIC INFRASTRUCTURES=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Tourism system', 'FINAL_YEAR_INVESTMENT_IN_INFRASTRUCTURE*'\
		)
	~	Year
	~		|

INITIAL YEAR INVESTMENT IN TOURISTIC INFRASTRUCTURES=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Tourism system', 'INITIAL_YEAR_INVESTMENT_IN_INFRASTRUCTURE*'\
		)
	~	Year
	~		|

SWITCH INVESTMENT IN TOURISTIC INFRASTRUCTURES=
	1
	~	Dmnl
	~	GET DIRECT CONSTANTS ('Policy.xlsx', 'Tourism system', \
		'SWITCH_INVESTMENT_IN_INFRASTRUCTURE*')
	|

MEAN HISTORICAL TCI=
	SAMPLE IF TRUE( Time=2018 , MEAN TCI , MEAN TCI )
	~	Dmnl
	~		|

"POPULATION <5 NORMALIZED"=
	IF THEN ELSE("RATIO OF POPULATION <5"<=0.04,0.25,IF THEN ELSE("RATIO OF POPULATION <5"\
		<=0.06:AND:"RATIO OF POPULATION <5">0.04,0.5, IF THEN ELSE("RATIO OF POPULATION <5"\
		<=0.08:AND:"RATIO OF POPULATION <5">0.06,0.75,1)))
	~	Dmnl
	~		|

MORTALITY RATE NORMALIZED=
	IF THEN ELSE(MORTALITY RATE<=0.008,0.25,IF THEN ELSE(MORTALITY RATE<=0.01:AND:MORTALITY RATE\
		>0.008,0.5, IF THEN ELSE(MORTALITY RATE<=0.012:AND:MORTALITY RATE>0.01,0.75,1)))
	~	Dmnl
	~		|

POPULATION BASELINE SENSITIVITY=
	("POPULATION >65 NORMALIZED"+"POPULATION <5 NORMALIZED"+SENSITIVITY FROM DENSITY+MORTALITY RATE NORMALIZED\
		+BIRTH RATE NORMALIZED+GREEN URBAN AREA NORMALIZED
	+UNEMPLOYMENT NORMALIZED
	+ENERGY POVERTY NORMALIZED+HEALTH SERVICES NORMALIZED)/9
	~	Dmnl
	~	He quitado la media por ahora
	|

HEALTH SERVICES NORMALIZED=
	IF THEN ELSE(HEALTH SERVICES>=0.005,0.25,IF THEN ELSE(HEALTH SERVICES<0.005:AND:HEALTH SERVICES\
		>=0.003,0.5,IF THEN ELSE(HEALTH SERVICES<0.003:AND:HEALTH SERVICES>=0.001,0.75,1)))
	~	Dmnl
	~		|

"POPULATION >65 NORMALIZED"=
	IF THEN ELSE("RATIO OF POPULATION >65"<=0.15,0.25,IF THEN ELSE("RATIO OF POPULATION >65"\
		<=0.2:AND:"RATIO OF POPULATION >65">0.15,0.5, IF THEN ELSE("RATIO OF POPULATION >65"\
		<=0.25:AND:"RATIO OF POPULATION >65">0.2,0.75,1)))
	~	Dmnl
	~		|

UNEMPLOYMENT NORMALIZED=
	IF THEN ELSE(UNEMPLOYMENT RATE<=0.05,0.25,IF THEN ELSE(UNEMPLOYMENT RATE<=0.1:AND:UNEMPLOYMENT RATE\
		>0.05,0.5, IF THEN ELSE(UNEMPLOYMENT RATE<=0.15:AND:UNEMPLOYMENT RATE>0.1,0.75,1)))
	~	Dmnl
	~		|

BIRTH RATE NORMALIZED=
	IF THEN ELSE(BIRTH RATE>=0.012,0.25,IF THEN ELSE(BIRTH RATE<0.012:AND:BIRTH RATE>=0.01\
		,0.5,IF THEN ELSE(BIRTH RATE<0.01:AND:BIRTH RATE>=0.008,0.75,1)))
	~	Dmnl
	~		|

ENERGY POVERTY NORMALIZED=
	IF THEN ELSE(RATIO ENERGY POVERTY<=0.05,0.25,IF THEN ELSE(RATIO ENERGY POVERTY<=0.1:AND:\
		RATIO ENERGY POVERTY>0.05,0.5, IF THEN ELSE(RATIO ENERGY POVERTY<=0.2:AND:RATIO ENERGY POVERTY\
		>0.1,0.75,1)))
	~	Dmnl
	~		|

GREEN URBAN AREA NORMALIZED=
	IF THEN ELSE(RATIO OF GREEN URBAN AREA>=0.25,0.25,IF THEN ELSE(RATIO OF GREEN URBAN AREA\
		<0.25:AND:RATIO OF GREEN URBAN AREA>=0.15,0.5, IF THEN ELSE(RATIO OF GREEN URBAN AREA\
		<0.15:AND:RATIO OF GREEN URBAN AREA>=0.05,0.75,1)))
	~	Dmnl
	~		|

TEMPERATURE[MONTHS]:INTERPOLATE::=
	IF THEN ELSE (SELECT TEMPERATURE SCENARIO = 0, MEAN TEMPERATURE SSP245[MONTHS],
	IF THEN ELSE (SELECT TEMPERATURE SCENARIO = 1, MEAN TEMPERATURE SSP585[MONTHS], 1))
	~	ºc
	~		|

RATIO WATER PER SNOW PRODUCTION=
	IF THEN ELSE(SWITCH TECHNICAL IMPROVEMENTS IN SNOW PRODUCTION=0,INITIAL RATIO WATER PER SNOW PRODUCTION\
		,IF THEN ELSE(SWITCH TECHNICAL IMPROVEMENTS IN SNOW PRODUCTION=1:AND:Time<=INITIAL YEAR TECHNICAL IMPROVEMENTS IN SNOW PRODUCTION\
		,INITIAL RATIO WATER PER SNOW PRODUCTION,IF THEN ELSE(SWITCH TECHNICAL IMPROVEMENTS IN SNOW PRODUCTION\
		=1:AND:Time>=FINAL YEAR TECHNICAL IMPROVEMENTS IN SNOW PRODUCTION,INITIAL RATIO WATER PER SNOW PRODUCTION\
		*(1-WATER USE DECREASE IN SNOW PRODUCTION OBJECTIVE),MAX(0,INITIAL RATIO WATER PER SNOW PRODUCTION\
		*(1-WATER USE DECREASE IN SNOW PRODUCTION OBJECTIVE*((Time-INITIAL YEAR TECHNICAL IMPROVEMENTS IN SNOW PRODUCTION\
		)/(FINAL YEAR TECHNICAL IMPROVEMENTS IN SNOW PRODUCTION-INITIAL YEAR TECHNICAL IMPROVEMENTS IN SNOW PRODUCTION\
		)))))))
	~	Dmnl
	~		|

NATIONAL VISITORS WINTER=
	IF THEN ELSE(SWITCH PROMOTE ALL YEAR TOURISM=0,INITIAL NATIONAL VISITORS[WINTER], 
	IF THEN ELSE(SWITCH PROMOTE ALL YEAR TOURISM=1:AND:Time<INITIAL YEAR PROMOTE ALL YEAR TOURISM\
		,INITIAL NATIONAL VISITORS
	[WINTER],
	IF THEN ELSE(SWITCH PROMOTE ALL YEAR TOURISM=1:AND:Time>FINAL YEAR PROMOTE ALL YEAR TOURISM\
		,INITIAL NATIONAL VISITORS[WINTER
	]*(1-PROMOTE ALL YEAR TOURISM OBJECTIVE)+(SUM(INITIAL NATIONAL VISITORS[SEASONS!])/4\
		)*PROMOTE ALL YEAR TOURISM OBJECTIVE
	,INITIAL NATIONAL VISITORS[WINTER]*(1-(PROMOTE ALL YEAR TOURISM OBJECTIVE*((Time-INITIAL YEAR PROMOTE ALL YEAR TOURISM\
		)
	/
	(FINAL YEAR PROMOTE ALL YEAR TOURISM-INITIAL YEAR PROMOTE ALL YEAR TOURISM))))+(SUM(\
		INITIAL NATIONAL VISITORS[SEASONS!]
	)
	/4)*PROMOTE ALL YEAR TOURISM OBJECTIVE*((Time-INITIAL YEAR PROMOTE ALL YEAR TOURISM)\
		/(FINAL YEAR PROMOTE ALL YEAR TOURISM
	-INITIAL YEAR PROMOTE ALL YEAR TOURISM)))))
	~	Tourists
	~		|

RATIO ENERGY PER SNOW PRODUCTION=
	IF THEN ELSE(SWITCH TECHNICAL IMPROVEMENTS IN SNOW PRODUCTION=0,INITIAL RATIO ENERGY PER SNOW PRODUCTION\
		,IF THEN ELSE(SWITCH TECHNICAL IMPROVEMENTS IN SNOW PRODUCTION=1:AND:Time<=INITIAL YEAR TECHNICAL IMPROVEMENTS IN SNOW PRODUCTION\
		,INITIAL RATIO ENERGY PER SNOW PRODUCTION,IF THEN ELSE(SWITCH TECHNICAL IMPROVEMENTS IN SNOW PRODUCTION\
		=1:AND:Time>=FINAL YEAR TECHNICAL IMPROVEMENTS IN SNOW PRODUCTION,INITIAL RATIO ENERGY PER SNOW PRODUCTION\
		*(1-ENERGY USE DECREASE IN SNOW PRODUCTION OBJECTIVE),MAX(0,INITIAL RATIO ENERGY PER SNOW PRODUCTION\
		*(1-ENERGY USE DECREASE IN SNOW PRODUCTION OBJECTIVE*((Time-INITIAL YEAR TECHNICAL IMPROVEMENTS IN SNOW PRODUCTION\
		)/(FINAL YEAR TECHNICAL IMPROVEMENTS IN SNOW PRODUCTION-INITIAL YEAR TECHNICAL IMPROVEMENTS IN SNOW PRODUCTION\
		)))))))
	~	Dmnl
	~		|

INITIAL NATIONAL VISITORS WINTER=
	IF THEN ELSE(SWITCH EFFECTS OF ARTIFICIAL SNOW PRODUCTION IN TOURISM=0:AND:SNOW VOLUME FOR SKIING YEARLY\
		>VOLUME SNOW ACCUMULATION YEARLY,0.8*(IF THEN ELSE
	(SWITCH PROMOTE DOMESTIC TOURISM=0,ALFA WINTER*MEAN TCI WINTER+BETA WINTER,IF THEN ELSE\
		(SWITCH PROMOTE DOMESTIC TOURISM
	=1:AND:Time<INITIAL YEAR PROMOTE DOMESTIC TOURISM,ALFA WINTER*MEAN TCI WINTER+BETA WINTER\
		,IF THEN ELSE(SWITCH PROMOTE DOMESTIC TOURISM
	=1:AND:Time>FINAL YEAR PROMOTE DOMESTIC TOURISM,(ALFA WINTER*MEAN TCI WINTER+BETA WINTER\
		)*(1+PROMOTE DOMESTIC TOURISM OBJECTIVE
	[WINTER]),(ALFA WINTER*MEAN TCI WINTER+BETA WINTER)*(1+PROMOTE DOMESTIC TOURISM OBJECTIVE\
		[WINTER]*((Time-INITIAL YEAR PROMOTE DOMESTIC TOURISM
	)/(FINAL YEAR PROMOTE DOMESTIC TOURISM-INITIAL YEAR PROMOTE DOMESTIC TOURISM))))))),\
		IF THEN ELSE(SWITCH PROMOTE DOMESTIC TOURISM
	=0,ALFA WINTER*MEAN TCI WINTER+BETA WINTER,IF THEN ELSE(SWITCH PROMOTE DOMESTIC TOURISM
	=1:AND:Time<INITIAL YEAR PROMOTE DOMESTIC TOURISM,ALFA WINTER*MEAN TCI WINTER+BETA WINTER\
		,IF THEN ELSE(SWITCH PROMOTE DOMESTIC TOURISM
	=1:AND:Time>FINAL YEAR PROMOTE DOMESTIC TOURISM,(ALFA WINTER*MEAN TCI WINTER+BETA WINTER\
		)*(1+PROMOTE DOMESTIC TOURISM OBJECTIVE
	[WINTER]),(ALFA WINTER*MEAN TCI WINTER+BETA WINTER)*(1+PROMOTE DOMESTIC TOURISM OBJECTIVE\
		[WINTER]*((Time-INITIAL YEAR PROMOTE DOMESTIC TOURISM
	)/(FINAL YEAR PROMOTE DOMESTIC TOURISM-INITIAL YEAR PROMOTE DOMESTIC TOURISM)))))))
	~	Tourists
	~		|

WATER USE DECREASE IN SNOW PRODUCTION OBJECTIVE=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', 'WATER_USE_DECREASE_IN_SNOW_PRODUCTION_OBJECTIVE*'\
		)
	~	Dmnl
	~	e.g.decrease of 60%
	|

WATER USED FOR SNOW PRODUCTION=
	((ARTIFICIAL SNOW PRODUCTION YEARLY)*RATIO WATER PER SNOW PRODUCTION)/1e+06
	~	Hm3
	~		|

INITIAL YEAR TECHNICAL IMPROVEMENTS IN SNOW PRODUCTION=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', 'INITIAL_YEAR_TECHNICAL_IMPROVEMENTS_IN_SNOW_PRODUCTION*'\
		)
	~	Year
	~		|

INITIAL RATIO WATER PER SNOW PRODUCTION=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', 'INITIAL_RATIO_WATER_PER_SNOW_PRODUCTION*'\
		)
	~	Dmnl
	~	m3 water over m3 snow
	|

ENERGY USED FOR SNOW PRODUCTION=
	(ARTIFICIAL SNOW PRODUCTION YEARLY)*RATIO ENERGY PER SNOW PRODUCTION
	~	MWh
	~		|

INTERNATIONAL VISITORS WINTER=
	IF THEN ELSE(SWITCH PROMOTE ALL YEAR TOURISM=0,INITIAL INTERNATIONAL VISITORS[WINTER\
		], 
	IF THEN ELSE(SWITCH PROMOTE ALL YEAR TOURISM=1:AND:Time<INITIAL YEAR PROMOTE ALL YEAR TOURISM\
		,INITIAL INTERNATIONAL VISITORS
	[WINTER],
	IF THEN ELSE(SWITCH PROMOTE ALL YEAR TOURISM=1:AND:Time>FINAL YEAR PROMOTE ALL YEAR TOURISM\
		,INITIAL INTERNATIONAL VISITORS
	[WINTER]*(1-PROMOTE ALL YEAR TOURISM OBJECTIVE)+(SUM(INITIAL INTERNATIONAL VISITORS[\
		SEASONS!])/4)*PROMOTE ALL YEAR TOURISM OBJECTIVE
	,INITIAL INTERNATIONAL VISITORS[WINTER]*(1-(PROMOTE ALL YEAR TOURISM OBJECTIVE*((Time\
		-INITIAL YEAR PROMOTE ALL YEAR TOURISM
	)/(FINAL YEAR PROMOTE ALL YEAR TOURISM-INITIAL YEAR PROMOTE ALL YEAR TOURISM))))+(SUM\
		(INITIAL INTERNATIONAL VISITORS[SEASONS
	!])/4)*PROMOTE ALL YEAR TOURISM OBJECTIVE*((Time-INITIAL YEAR PROMOTE ALL YEAR TOURISM\
		)/(FINAL YEAR PROMOTE ALL YEAR TOURISM
	-INITIAL YEAR PROMOTE ALL YEAR TOURISM)))))
	~	Tourists
	~		|

ENERGY USE DECREASE IN SNOW PRODUCTION OBJECTIVE=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', 'ENERGY_USE_DECREASE_IN_SNOW_PRODUCTION_OBJECTIVE*'\
		)
	~	Dmnl
	~		|

FINAL YEAR TECHNICAL IMPROVEMENTS IN SNOW PRODUCTION=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', 'FINAL_YEAR_TECHNICAL_IMPROVEMENTS_IN_SNOW_PRODUCTION*'\
		)
	~	Year
	~		|

SNOW VOLUME FOR SKIING YEARLY=
	SNOW VOLUME FOR SKIING*5
	~	m3
	~		|

VOLUME SNOW ACCUMULATION YEARLY=
	SUM(VOLUME SNOW ACCUMULATION[MONTHS!])
	~	m3
	~		|

SWITCH EFFECTS OF ARTIFICIAL SNOW PRODUCTION IN TOURISM=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', 'SWITCH_ARTIFICIAL_SNOW_PRODUCTION*'\
		)
	~	Dmnl
	~	0 = OFF
		1 = ON
	|

INITIAL INTERNATIONAL VISITORS WINTER=
	IF THEN ELSE(SWITCH EFFECTS OF ARTIFICIAL SNOW PRODUCTION IN TOURISM=0:AND:SNOW VOLUME FOR SKIING YEARLY\
		>VOLUME SNOW ACCUMULATION YEARLY,0.8*ALFA 1 WINTER
	*MEAN TCI WINTER+BETA 1 WINTER,ALFA 1 WINTER*MEAN TCI WINTER+BETA 1 WINTER)
	~	Tourists
	~		|

SWITCH TECHNICAL IMPROVEMENTS IN SNOW PRODUCTION=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', 'SWITCH_TECHNICAL_IMPROVEMENTS_IN_SNOW_PRODUCTION*'\
		)
	~	Dmnl
	~	0 = OFF
		1 = ON
	|

IRRIGATED CROP AREA=
	AGRICULTURE NO SOLAR*RATIO IRRIGATED CROP AREA
	~	km2
	~		|

RATIO RAINFED AGRICULTURE TO SOLAR=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Land system', 'RATIO_RAINFED_AGRICULTURE_TO_SOLAR*'\
		)
	~	Dmnl
	~		|

MAX SOLAR CAPACITY=
	MAX POTENTIAL SOLAR*(OTHER+RAINFED CROP AREA)
	~	MW
	~		|

AGRICULTURE NO SOLAR=
	AGRICULTURE+RATIO RAINFED AGRICULTURE TO SOLAR*VARIATION OF SOLAR LAND
	~	
	~		|

RAINFED CROP AREA=
	AGRICULTURE NO SOLAR*RATIO RAINFED CROP AREA-RATIO RAINFED AGRICULTURE TO SOLAR*VARIATION OF SOLAR LAND
	~	km2
	~		|

WATER= INTEG (
	AGRICULTURE TO WATER+FOREST TO WATER+URBAN TO WATER+OTHER TO WATER,
		INITIAL WATER AREA)
	~	km2
	~		|

OTHER= INTEG (
	-URBAN EXPANSION-OTHER TO WATER-RATIO OTHER TO SOLAR*VARIATION OF SOLAR LAND,
		INITIAL OTHER AREA)
	~	km2
	~		|

DELAY SOLAR LAND=
	DELAY FIXED( SOLAR LAND , 1 , SOLAR LAND )
	~	km2
	~		|

AGRICULTURE= INTEG (
	AGRICULTURAL EXPANSION+WETLANDS DESERTION-AFFORESTATION-AGRICULTURE TO WATER-URBANIZATION\
		-RATIO RAINFED AGRICULTURE TO SOLAR*VARIATION OF SOLAR LAND,
		INITIAL AGRICULTURAL AREA)
	~	km2
	~		|

OTHER TO WATER=
	IF THEN ELSE (SELECT LOCATION WATER STORAGE=1,WATER AREA,0)
	~	km2
	~		|

VARIATION OF SOLAR LAND=
	SOLAR LAND-DELAY SOLAR LAND
	~	km2
	~		|

RATIO OTHER TO SOLAR=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Land system', 'RATIO_OTHER_TO_SOLAR*')
	~	Dmnl
	~		|

URBAN= INTEG (
	URBAN EXPANSION+URBAN EXPANSION FROM WETLANDS+URBANIZATION-URBAN TO WATER,
		INITIAL URBAN AREA-INITIAL SOLAR LAND)
	~	
	~		|

INITIAL SOLAR LAND=
	INITIAL(SOLAR LAND)
	~	km2
	~		|

INITIAL BUILT UP URBAN=
	INITIAL( BUILT UP URBAN )
	~	km2
	~		|

INITIAL EXPOSED CROPS=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Crop system', 'INITIAL_EXPOSED_CROPS*')
	~	km2
	~		|

INITIAL EXPOSED POPULATION=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', 'INITIAL_EXPOSED_POPULATION*'\
		)
	~	Inhabitants
	~		|

MAX ROOFTOP CAPACITY=
	(BUILDING AREA/INITIAL BUILT UP URBAN)*BUILT UP URBAN*MAX POTENTIAL ROOFTOP
	~	MW
	~		|

SOLAR LAND=
	SOLAR CAPACITY*AREA OCCUPIED BY SOLAR PER MW
	~	km2
	~		|

EXPOSED CROPS= INTEG (
	INCREASE EXPOSED CROPS,
		INITIAL EXPOSED CROPS)
	~	km2
	~		|

AREA OCCUPIED BY SOLAR PER MW=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'ENERGY', 'AREA_OCCUPIED_BY_SOLAR_PER_MW*')
	~	km2/MW
	~		|

EXPOSED POPULATION= INTEG (
	INCREASE EXPOSED POPULATION,
		INITIAL EXPOSED POPULATION)
	~	Inhabitants
	~		|

VEHICLES GROWTH[TYPE OF VEHICLE,TYPE OF FUEL]=
	INTEGER(IF THEN ELSE(SWITCH INCREASE IN ELECTRIC VEHICLES=0,(GDP*ALPHA VEHICLE[TYPE OF VEHICLE\
		,TYPE OF FUEL]*(1-LIMIT 1 VEHICLE GROWTH[TYPE OF VEHICLE,TYPE OF FUEL]*(Time-2018))\
		+(BETA VEHICLE[TYPE OF VEHICLE,TYPE OF FUEL]))*((LIMIT 2 VEHICLE GROWTH[TYPE OF VEHICLE\
		,TYPE OF FUEL])^(Time-2018)),IF THEN ELSE(SWITCH INCREASE IN ELECTRIC VEHICLES=1:AND:\
		Time<INITIAL YEAR INCREASE IN ELECTRIC VEHICLES:OR:Time>FINAL YEAR INCREASE IN ELECTRIC VEHICLES\
		,(GDP*ALPHA VEHICLE[TYPE OF VEHICLE,TYPE OF FUEL]*(1-LIMIT 1 VEHICLE GROWTH[TYPE OF VEHICLE\
		,TYPE OF FUEL]*(Time-2018))+(BETA VEHICLE[TYPE OF VEHICLE,TYPE OF FUEL]))*((LIMIT 2 VEHICLE GROWTH\
		[TYPE OF VEHICLE,TYPE OF FUEL])^(Time-2018)),IF THEN ELSE(SWITCH INCREASE IN ELECTRIC VEHICLES\
		=1:AND:Time>=
	INITIAL YEAR INCREASE IN ELECTRIC VEHICLES:OR:Time<=FINAL YEAR INCREASE IN ELECTRIC VEHICLES\
		,((GDP*ALPHA VEHICLE[TYPE OF VEHICLE,TYPE OF FUEL]*(1-LIMIT 1 VEHICLE GROWTH[TYPE OF VEHICLE\
		,TYPE OF FUEL]*(Time-2018))+(BETA VEHICLE[TYPE OF VEHICLE,TYPE OF FUEL]))*((LIMIT 2 VEHICLE GROWTH\
		[TYPE OF VEHICLE,TYPE OF FUEL])^(Time-2018)))*(1+(SUBSIDIES ELECTRIC VEHICLES OBJECTIVE\
		[TYPE OF FUEL])/(FINAL YEAR INCREASE IN ELECTRIC VEHICLES-INITIAL YEAR INCREASE IN ELECTRIC VEHICLES\
		)),0))))
	~	vehicle
	~	INTEGER(IF THEN ELSE(SWITCH SUBSIDIES ELECTRIC VEHICLES=0,(GDP*ALPHA VEHICLE[TYPE OF \
		VEHICLE,TYPE OF FUEL]*(1-LIMIT 1 VEHICLE GROWTH[TYPE OF VEHICLE,TYPE OF \
		FUEL]*(Time-2018))+(BETA VEHICLE[TYPE OF VEHICLE,TYPE OF FUEL]))*((LIMIT 2 \
		VEHICLE GROWTH[TYPE OF VEHICLE,TYPE OF FUEL])^(Time-2018)),IF THEN \
		ELSE(SWITCH SUBSIDIES ELECTRIC VEHICLES=1:AND:Time<INITIAL YEAR SUBSIDIES \
		ELECTRIC VEHICLES:OR:Time>FINAL YEAR SUBSIDIES ELECTRIC \
		VEHICLES,(GDP*ALPHA VEHICLE[TYPE OF VEHICLE,TYPE OF FUEL]*(1-LIMIT 1 \
		VEHICLE GROWTH[TYPE OF VEHICLE,TYPE OF FUEL]*(Time-2018))+(BETA \
		VEHICLE[TYPE OF VEHICLE,TYPE OF FUEL]))*((LIMIT 2 VEHICLE GROWTH[TYPE OF \
		VEHICLE,TYPE OF FUEL])^(Time-2018)),IF THEN ELSE(SWITCH SUBSIDIES ELECTRIC \
		VEHICLES=1:AND:(TYPE OF FUEL=ELECTRICITY):AND:Time>=
		INITIAL YEAR SUBSIDIES ELECTRIC VEHICLES:OR:Time<=FINAL YEAR SUBSIDIES \
		ELECTRIC VEHICLES,((GDP*ALPHA VEHICLE[TYPE OF VEHICLE,TYPE OF \
		FUEL]*(1-LIMIT 1 VEHICLE GROWTH[TYPE OF VEHICLE,TYPE OF \
		FUEL]*(Time-2018))+(BETA VEHICLE[TYPE OF VEHICLE,TYPE OF FUEL]))*((LIMIT 2 \
		VEHICLE GROWTH[TYPE OF VEHICLE,TYPE OF FUEL])^(Time-2018)))*(1+(SUBSIDIES \
		ELECTRIC VEHICLES OBJECTIVE)/(FINAL YEAR SUBSIDIES ELECTRIC \
		VEHICLES-INITIAL YEAR SUBSIDIES ELECTRIC VEHICLES)),IF THEN ELSE(TYPE OF \
		FUEL=PETROL:OR:TYPE OF FUEL=DIESEL:AND:SWITCH SUBSIDIES ELECTRIC \
		VEHICLES=1:AND:((GDP*ALPHA VEHICLE[TYPE OF VEHICLE,TYPE OF FUEL]*(1-LIMIT \
		1 VEHICLE GROWTH[TYPE OF VEHICLE,TYPE OF FUEL]*(Time-2018))+(BETA \
		VEHICLE[TYPE OF VEHICLE,TYPE OF FUEL]))*((LIMIT 2 VEHICLE GROWTH[TYPE OF \
		VEHICLE,TYPE OF FUEL])^(Time-2018)))<0, ((GDP*ALPHA VEHICLE[TYPE OF \
		VEHICLE,TYPE OF FUEL]*(1-LIMIT 1 VEHICLE GROWTH[TYPE OF VEHICLE,TYPE OF \
		FUEL]*(Time-2018))+(BETA VEHICLE[TYPE OF VEHICLE,TYPE OF FUEL]))*((LIMIT 2 \
		VEHICLE GROWTH[TYPE OF VEHICLE,TYPE OF FUEL])^(Time-2018)))*(1+(SUBSIDIES \
		ELECTRIC VEHICLES OBJECTIVE/2)/(FINAL YEAR SUBSIDIES ELECTRIC \
		VEHICLES-INITIAL YEAR SUBSIDIES ELECTRIC VEHICLES)),((GDP*ALPHA \
		VEHICLE[TYPE OF VEHICLE,TYPE OF FUEL]*(1-LIMIT 1 VEHICLE GROWTH[TYPE OF \
		VEHICLE,TYPE OF FUEL]*(Time-2018))+(BETA VEHICLE[TYPE OF VEHICLE,TYPE OF \
		FUEL]))*((LIMIT 2 VEHICLE GROWTH[TYPE OF VEHICLE,TYPE OF \
		FUEL])^(Time-2018)))*(1-(SUBSIDIES ELECTRIC VEHICLES OBJECTIVE/2)/(FINAL \
		YEAR SUBSIDIES ELECTRIC VEHICLES-INITIAL YEAR SUBSIDIES ELECTRIC \
		VEHICLES)))))))
	|

INCREASE RATIO IRRIGATED CROP NEW=
	IF THEN ELSE(SWITCH INCREASE IRRIGATED CROP=0,0,IF THEN ELSE(SWITCH INCREASE IRRIGATED CROP\
		=1:AND:Time<INITIAL YEAR INCREASE IRRIGATED CROP
	:OR:Time>=FINAL YEAR INCREASE IRRIGATED CROP,0,IF THEN ELSE(SWITCH INCREASE IRRIGATED CROP\
		=1:AND:WATER SECURITY=0,0,(INCREASE IRRIGATED CROP OBJECTIVE-INITIAL RATIO IRRIGATED CROP AREA\
		)
	/(FINAL YEAR INCREASE IRRIGATED CROP-INITIAL YEAR INCREASE IRRIGATED CROP))))
	~	Dmnl
	~		|

WATER DEMAND FROM AGRICULTURE=
	IF THEN ELSE(SWITCH EFFICIENT WATER DEMAND FROM AGRICULTURE=0,WATER INTENSITY IN 2018\
		*CS POPULATION*IRRIGATED CROP AREA,IF THEN ELSE
	(SWITCH EFFICIENT WATER DEMAND FROM AGRICULTURE
	=1:AND:(Time<INITIAL YEAR EFFICIENT WATER DEMAND FROM AGRICULTURE),WATER INTENSITY IN 2018\
		*CS POPULATION*IRRIGATED CROP AREA
	,IF THEN ELSE(SWITCH EFFICIENT WATER DEMAND FROM AGRICULTURE
	=1:AND:(Time>FINAL YEAR EFFICIENT WATER DEMAND FROM AGRICULTURE),(WATER INTENSITY IN 2018\
		*CS POPULATION*IRRIGATED CROP AREA
	)*(1-EFFICIENT WATER DEMAND FROM AGRICULTURE OBJECTIVE
	),(WATER INTENSITY IN 2018*CS POPULATION*IRRIGATED CROP AREA)*(1-(EFFICIENT WATER DEMAND FROM AGRICULTURE OBJECTIVE
	*((Time-INITIAL YEAR EFFICIENT WATER DEMAND FROM AGRICULTURE
	)/(FINAL YEAR EFFICIENT WATER DEMAND FROM AGRICULTURE-INITIAL YEAR EFFICIENT WATER DEMAND FROM AGRICULTURE\
		)))))))
	~	Hm3
	~		|

WATER INTENSITY IN 2018=
	IF THEN ELSE((AGRICULTURE*INITIAL RATIO IRRIGATED CROP AREA)=0,0,WATER DEMAND FROM AGRICULTURE PER CAPITA\
		/(AGRICULTURE*INITIAL RATIO IRRIGATED CROP AREA))
	~	Hm3/capita*km2
	~		|

VEHICLES FROM 15 TO 19 YEARS[TYPE OF VEHICLE,TYPE OF FUEL]= INTEG (
	VEHICLE GROWTH 15 TO 19 YEARS[TYPE OF VEHICLE,TYPE OF FUEL]-DROP OUT VEHICLES FROM 15 TO 19 YEARS\
		[TYPE OF VEHICLE,TYPE OF FUEL]-VEHICLE GROWTH MORE THAN 20 YEARS[TYPE OF VEHICLE,TYPE OF FUEL\
		],
		RATIO OF INITIAL VEHICLES BASED ON AGE[TRUCK,FROM 15 TO 19 YEARS]*INITIAL VEHICLES TOT\
		[TYPE OF VEHICLE,TYPE OF FUEL])
	~	vehicle
	~		|

VEHICLES FROM 5 TO 9 YEARS[TYPE OF VEHICLE,TYPE OF FUEL]= INTEG (
	VEHICLE GROWTH 5 TO 9 YEARS[TYPE OF VEHICLE,TYPE OF FUEL]-DROP OUT VEHICLES FROM 5 TO 9 YEARS\
		[TYPE OF VEHICLE,TYPE OF FUEL]-VEHICLE GROWTH 10 TO 14 YEARS[TYPE OF VEHICLE,TYPE OF FUEL\
		],
		RATIO OF INITIAL VEHICLES BASED ON AGE[TRUCK,FROM 5 TO 9 YEARS]*INITIAL VEHICLES TOT\
		[TYPE OF VEHICLE,TYPE OF FUEL])
	~	vehicle
	~		|

CHANGE INITIAL VEHICLE LESS THAN 4 YEARS[TYPE OF VEHICLE,TYPE OF FUEL]=
	IF THEN ELSE(Time<2028,(INITIAL VEHICLES TOT[TYPE OF VEHICLE,TYPE OF FUEL]*RATIO OF INITIAL VEHICLES BASED ON AGE\
		[TRUCK,LESS THAN 4 YEARS]*0.1),0)
	~	vehicle
	~		|

VEHICLES LESS THAN 4 YEARS[TYPE OF VEHICLE,TYPE OF FUEL]= INTEG (
	VEHICLE GROWTH LESS THAN 4 YEARS[TYPE OF VEHICLE,TYPE OF FUEL]-DROP OUT VEHICLES LESS THAN 4 YEARS\
		[TYPE OF VEHICLE,TYPE OF FUEL]-VEHICLE GROWTH 5 TO 9 YEARS[TYPE OF VEHICLE,TYPE OF FUEL\
		],
		RATIO OF INITIAL VEHICLES BASED ON AGE[TRUCK,LESS THAN 4 YEARS]*INITIAL VEHICLES TOT\
		[TYPE OF VEHICLE,TYPE OF FUEL])
	~	vehicle
	~		|

VEHICLES MORE THAN 20 YEARS[TYPE OF VEHICLE,TYPE OF FUEL]= INTEG (
	VEHICLE GROWTH MORE THAN 20 YEARS[TYPE OF VEHICLE,TYPE OF FUEL]-DROP OUT VEHICLES MORE THAN 20 YEARS\
		[TYPE OF VEHICLE,TYPE OF FUEL]-END OF VEHICLE LIFE[TYPE OF VEHICLE,TYPE OF FUEL],
		RATIO OF INITIAL VEHICLES BASED ON AGE[TRUCK,MORE THAN 20 YEARS]*INITIAL VEHICLES TOT\
		[TYPE OF VEHICLE,TYPE OF FUEL])
	~	vehicle
	~		|

CHANGE INITIAL VEHICLE 5 TO 9 YEARS[TYPE OF VEHICLE,TYPE OF FUEL]=
	IF THEN ELSE(Time<2028,(INITIAL VEHICLES TOT[TYPE OF VEHICLE,TYPE OF FUEL]*RATIO OF INITIAL VEHICLES BASED ON AGE\
		[TRUCK,FROM 5 TO 9 YEARS]*0.1),0)
	~	vehicle
	~		|

VEHICLES FROM 10 TO 14 YEARS[TYPE OF VEHICLE,TYPE OF FUEL]= INTEG (
	VEHICLE GROWTH 10 TO 14 YEARS[TYPE OF VEHICLE,TYPE OF FUEL]-DROP OUT VEHICLES FROM 10 TO 14 YEARS\
		[TYPE OF VEHICLE,TYPE OF FUEL]-VEHICLE GROWTH 15 TO 19 YEARS[TYPE OF VEHICLE,TYPE OF FUEL\
		],
		RATIO OF INITIAL VEHICLES BASED ON AGE[TRUCK,FROM 10 TO 14 YEARS]*INITIAL VEHICLES TOT\
		[TYPE OF VEHICLE,TYPE OF FUEL])
	~	vehicle
	~		|

CHANGE INITIAL VEHICLE 15 TO 19 YEARS[TYPE OF VEHICLE,TYPE OF FUEL]=
	IF THEN ELSE(Time<2028,(INITIAL VEHICLES TOT[TYPE OF VEHICLE,TYPE OF FUEL]*RATIO OF INITIAL VEHICLES BASED ON AGE\
		[TRUCK,FROM 15 TO 19 YEARS]*0.1),0)
	~	vehicle
	~		|

CHANGE INITIAL VEHICLE MORE THAN 20 YEARS[TYPE OF VEHICLE,TYPE OF FUEL]=
	IF THEN ELSE(Time<2028,(INITIAL VEHICLES TOT[TYPE OF VEHICLE,TYPE OF FUEL]*RATIO OF INITIAL VEHICLES BASED ON AGE\
		[TRUCK,MORE THAN 20 YEARS]*0.1),0)
	~	vehicle
	~		|

CHANGE INITIAL VEHICLE 10 TO 14 YEARS[TYPE OF VEHICLE,TYPE OF FUEL]=
	IF THEN ELSE(Time<2028,(INITIAL VEHICLES TOT[TYPE OF VEHICLE,TYPE OF FUEL]*RATIO OF INITIAL VEHICLES BASED ON AGE\
		[TRUCK,FROM 10 TO 14 YEARS]*0.1),0)
	~	vehicle
	~		|

VEHICLES[TYPE OF VEHICLE,TYPE OF FUEL]= INTEG (
	VEHICLES GROWTH[TYPE OF VEHICLE,TYPE OF FUEL]-VEHICLES DROPOUT[TYPE OF VEHICLE,TYPE OF FUEL\
		]+VALUE FOR SUBSCRIPT ELECTRIC[TYPE OF VEHICLE,TYPE OF FUEL],
		INITIAL VEHICLES TOT[TYPE OF VEHICLE,TYPE OF FUEL])
	~	vehicle
	~		|

TOTAL DROPOUT VEHICLES[TYPE OF VEHICLE,TYPE OF FUEL]=
	END OF VEHICLE LIFE[TYPE OF VEHICLE,TYPE OF FUEL]+DROP OUT VEHICLES LESS THAN 4 YEARS\
		[TYPE OF VEHICLE,TYPE OF FUEL]+DROP OUT VEHICLES FROM 5 TO 9 YEARS
	[TYPE OF VEHICLE,TYPE OF FUEL]+DROP OUT VEHICLES FROM 10 TO 14 YEARS[TYPE OF VEHICLE\
		,TYPE OF FUEL]+DROP OUT VEHICLES FROM 15 TO 19 YEARS
	[TYPE OF VEHICLE,TYPE OF FUEL]+DROP OUT VEHICLES MORE THAN 20 YEARS[TYPE OF VEHICLE,\
		TYPE OF FUEL]
	~	vehicle
	~		|

VEHICLES DELAY[TYPE OF VEHICLE, TYPE OF FUEL]=
	DELAY1(VEHICLES CORRECTED[TYPE OF VEHICLE,TYPE OF FUEL], 1)
	~	vehicle
	~		|

VEHICLES DIFFERENCE[TYPE OF VEHICLE, TYPE OF FUEL]=
	VEHICLES CORRECTED[TYPE OF VEHICLE,TYPE OF FUEL]-VEHICLES DELAY[TYPE OF VEHICLE,TYPE OF FUEL\
		]
	~	vehicle
	~		|

VEHICLES DROPOUT[TYPE OF VEHICLE,TYPE OF FUEL]=
	REAL DROPOUT[TYPE OF VEHICLE,TYPE OF FUEL] + DROPOUT DISTRIBUTED FROM ELECTRIC VEHICLES\
		[TYPE OF VEHICLE,TYPE OF FUEL]
	~	vehicle
	~	IF THEN ELSE((Time-INITIAL TIME)<5,TOTAL VEHICLES GROWTH*0.02,IF THEN \
		ELSE((Time-INITIAL TIME)<10,DELAY 5 YEAR AGE*0.08+TOTAL VEHICLES \
		GROWTH*0.02
		, IF THEN ELSE (
		(Time
		-INITIAL TIME)<15,DELAY 10 YEARS AGE*0.2+DELAY 5 YEAR AGE*0.08+TOTAL \
		VEHICLES GROWTH*0.02,IF THEN ELSE ((Time-INITIAL TIME)<20,DELAY 15 YEARS \
		AGE*0.4+DELAY 10 YEARS AGE*0.2+DELAY 5 YEAR AGE*0.08+TOTAL VEHICLES \
		GROWTH*0.02,DELAY 20 YEARS AGE*0.8+DELAY 15 YEARS AGE*0.4+DELAY 10 YEARS \
		AGE*0.2+DELAY 5 YEAR AGE*0.08+TOTAL VEHICLES GROWTH*0.02))))+INITIAL \
		VEHICLES DROPOUT
	|

RENOVATED VEHICLES[TYPE OF VEHICLE,TYPE OF FUEL]=
	INTEGER(TOTAL DROPOUT VEHICLES[TYPE OF VEHICLE,TYPE OF FUEL]*0.8)
	~	vehicle
	~		|

VEHICLES EMISSIONS[TYPE OF VEHICLE,TYPE OF FUEL]=
	VEHICLES CORRECTED[TYPE OF VEHICLE,TYPE OF FUEL]*VEHICLES EMISSION COEFFICIENT[TYPE OF VEHICLE\
		,TYPE OF FUEL]*DISTANCE COVERED*VEHICLE AGE COEFFICIENT[TYPE OF VEHICLE,TYPE OF FUEL\
		]
	~	tCO2
	~		|

VEHICLE AGE COEFFICIENT[TYPE OF VEHICLE,TYPE OF FUEL]=
	IF THEN ELSE (VEHICLES CORRECTED[TYPE OF VEHICLE,TYPE OF FUEL]<=0,0,(VEHICLES LESS THAN 4 YEARS\
		[TYPE OF VEHICLE,TYPE OF FUEL]+1.2
	*VEHICLES FROM 5 TO 9 YEARS[TYPE OF VEHICLE,TYPE OF FUEL]+1.4*VEHICLES FROM 10 TO 14 YEARS\
		[TYPE OF VEHICLE,TYPE OF FUEL]
	+1.8*VEHICLES FROM 15 TO 19 YEARS[TYPE OF VEHICLE,TYPE OF FUEL]+2*VEHICLES MORE THAN 20 YEARS\
		[TYPE OF VEHICLE,TYPE OF FUEL
	])/VEHICLES CORRECTED[TYPE OF VEHICLE,TYPE OF FUEL])
	~	vehicle
	~	IF THEN ELSE((Time-INITIAL TIME)<5,(TOTAL VEHICLES GROWTH-(TOTAL VEHICLES \
		GROWTH*0.02)),IF THEN ELSE((Time-INITIAL TIME
		)<10,(1+0.15)*(TOTAL VEHICLES GROWTH-(DELAY 5 YEAR AGE*0.08+TOTAL VEHICLES \
		GROWTH*0.02))
		, IF THEN ELSE (
		(Time
		-INITIAL TIME)<15,(1+0.4)*(TOTAL VEHICLES GROWTH-(DELAY 10 YEARS AGE*0.2+DELAY 5 \
		YEAR AGE*0.08+TOTAL VEHICLES GROWTH*0.02
		)),IF THEN ELSE ((Time-INITIAL TIME)<20,(1+0.8)*(TOTAL VEHICLES GROWTH-(DELAY 15 \
		YEARS AGE*0.4+DELAY 10 YEARS AGE*0.2+DELAY 5 YEAR AGE
		*0.08+TOTAL VEHICLES GROWTH*0.02)),2*(TOTAL VEHICLES GROWTH-(DELAY 20 YEARS \
		AGE*0.8+DELAY 15 YEARS AGE*0.4+DELAY 10 YEARS AGE
		*0.2+DELAY 5 YEAR AGE*0.08+TOTAL VEHICLES GROWTH*0.02))))))/VEHICLES
	|

DROPOUT DISTRIBUTED FROM ELECTRIC VEHICLES[TRUCK, TYPE OF FUEL]=
	IF THEN ELSE((TYPE OF FUEL = PETROL) :OR: (TYPE OF FUEL = DIESEL), IF THEN ELSE(TYPE OF FUEL\
		 = DIESEL, INTEGER(VEHICLES DIFFERENCE[TRUCK, ELECTRICITY] * 0.99), VEHICLES DIFFERENCE\
		[TRUCK, ELECTRICITY] - INTEGER(VEHICLES DIFFERENCE[TRUCK, ELECTRICITY] * 0.01)),0) ~~|
DROPOUT DISTRIBUTED FROM ELECTRIC VEHICLES[VAN,TYPE OF FUEL]=
	IF THEN ELSE((TYPE OF FUEL = PETROL) :OR: (TYPE OF FUEL = DIESEL), VEHICLES DIFFERENCE\
		[VAN, ELECTRICITY]*0.5 + IF THEN ELSE(MODULO(VEHICLES DIFFERENCE[VAN, ELECTRICITY],\
		2) <> 0, IF THEN ELSE(TYPE OF FUEL = DIESEL, 0.5, -0.5),0),0) ~~|
DROPOUT DISTRIBUTED FROM ELECTRIC VEHICLES[BUS,TYPE OF FUEL]=
	IF THEN ELSE((TYPE OF FUEL = PETROL) :OR: (TYPE OF FUEL = DIESEL), IF THEN ELSE(TYPE OF FUEL\
		 = DIESEL, INTEGER(VEHICLES DIFFERENCE[BUS, ELECTRICITY] * 0.99), VEHICLES DIFFERENCE\
		[BUS, ELECTRICITY] - INTEGER(VEHICLES DIFFERENCE[BUS, ELECTRICITY] * 0.01)),0) ~~|
DROPOUT DISTRIBUTED FROM ELECTRIC VEHICLES[CAR,TYPE OF FUEL]=
	IF THEN ELSE((TYPE OF FUEL = PETROL) :OR: (TYPE OF FUEL = DIESEL), VEHICLES DIFFERENCE\
		[CAR, ELECTRICITY]*0.5 + IF THEN ELSE(MODULO(VEHICLES DIFFERENCE[CAR, ELECTRICITY],\
		2) <> 0, IF THEN ELSE(TYPE OF FUEL = DIESEL, 0.5, -0.5),0),0) ~~|
DROPOUT DISTRIBUTED FROM ELECTRIC VEHICLES[MOTORCYCLE,TYPE OF FUEL]=
	IF THEN ELSE((TYPE OF FUEL = PETROL) :OR: (TYPE OF FUEL = DIESEL), IF THEN ELSE(TYPE OF FUEL\
		 = DIESEL, INTEGER(VEHICLES DIFFERENCE[MOTORCYCLE, ELECTRICITY] * 0.01), VEHICLES DIFFERENCE\
		[MOTORCYCLE, ELECTRICITY] - INTEGER(VEHICLES DIFFERENCE[MOTORCYCLE, ELECTRICITY] * \
		0.01)),0) ~~|
DROPOUT DISTRIBUTED FROM ELECTRIC VEHICLES[TRACTOR,TYPE OF FUEL]=
	IF THEN ELSE((TYPE OF FUEL = PETROL) :OR: (TYPE OF FUEL = DIESEL), IF THEN ELSE(TYPE OF FUEL\
		 = DIESEL, INTEGER(VEHICLES DIFFERENCE[TRACTOR, ELECTRICITY] * 0.99), VEHICLES DIFFERENCE\
		[TRACTOR, ELECTRICITY] - INTEGER(VEHICLES DIFFERENCE[TRACTOR, ELECTRICITY] * 0.01))\
		,0)
	~	vehicle
	~		|

CHANGE TO ELECTRIC VEHICLES[TYPE OF VEHICLE]=
	SUM(INTEGER(TOTAL DROPOUT VEHICLES[TYPE OF VEHICLE,TYPE OF FUEL!]*0.01))
	~	vehicle
	~		|

VEHICLES CORRECTED[TYPE OF VEHICLE,TYPE OF FUEL]=
	IF THEN ELSE(VEHICLES[TYPE OF VEHICLE,TYPE OF FUEL]<0, 0 , VEHICLES[TYPE OF VEHICLE,\
		TYPE OF FUEL])
	~	vehicle
	~		|

REAL DROPOUT[TYPE OF VEHICLE,TYPE OF FUEL]=
	TOTAL DROPOUT VEHICLES[TYPE OF VEHICLE,TYPE OF FUEL]-RENOVATED VEHICLES[TYPE OF VEHICLE\
		,TYPE OF FUEL]
	~	vehicle
	~		|

VALUE FOR SUBSCRIPT ELECTRIC[TYPE OF VEHICLE, TYPE OF FUEL]=
	IF THEN ELSE((TYPE OF FUEL = ELECTRICITY) :AND:((TYPE OF VEHICLE = CAR) :OR: (TYPE OF VEHICLE\
		 = VAN) :OR: (TYPE OF VEHICLE = MOTORCYCLE)),CHANGE TO ELECTRIC VEHICLES[TYPE OF VEHICLE\
		],0)
	~	vehicle
	~		|

TOTAL EMISSIONS FROM TRANSPORT=
	SUM(VEHICLES EMISSIONS[TYPE OF VEHICLE!,TYPE OF FUEL!])
	~	tCO2
	~		|

VEHICLE GROWTH MORE THAN 20 YEARS[TYPE OF VEHICLE,TYPE OF FUEL]=
	INTEGER((DELAY VEHICLE GROWTH 15 TO 19 YEARS[TYPE OF VEHICLE,TYPE OF FUEL]+CHANGE INITIAL VEHICLE 15 TO 19 YEARS\
		[TYPE OF VEHICLE,TYPE OF FUEL])*(1-RATIO DROP OUT FROM 15 TO 19 YEARS))
	~	vehicle
	~		|

DELAY VEHICLE GROWTH 15 TO 19 YEARS[TYPE OF VEHICLE,TYPE OF FUEL]= DELAY FIXED (
	VEHICLE GROWTH 15 TO 19 YEARS[TYPE OF VEHICLE,TYPE OF FUEL], 5 , 0)
	~	vehicle
	~		|

DROP OUT VEHICLES FROM 10 TO 14 YEARS[TYPE OF VEHICLE,TYPE OF FUEL]=
	INTEGER(RATIO DROP OUT FROM 10 TO 14 YEARS*(CHANGE INITIAL VEHICLE 10 TO 14 YEARS[TYPE OF VEHICLE\
		,TYPE OF FUEL]+VEHICLE GROWTH 10 TO 14 YEARS[TYPE OF VEHICLE,TYPE OF FUEL]))
	~	vehicle
	~		|

DROP OUT VEHICLES FROM 15 TO 19 YEARS[TYPE OF VEHICLE,TYPE OF FUEL]=
	INTEGER(RATIO DROP OUT FROM 15 TO 19 YEARS*(CHANGE INITIAL VEHICLE 15 TO 19 YEARS[TYPE OF VEHICLE\
		,TYPE OF FUEL]+VEHICLE GROWTH 15 TO 19 YEARS[TYPE OF VEHICLE,TYPE OF FUEL]))
	~	vehicle
	~		|

DROP OUT VEHICLES FROM 5 TO 9 YEARS[TYPE OF VEHICLE,TYPE OF FUEL]=
	INTEGER(RATIO DROP OUT FROM 5 TO 9 YEARS*(CHANGE INITIAL VEHICLE 5 TO 9 YEARS[TYPE OF VEHICLE\
		,TYPE OF FUEL]+VEHICLE GROWTH 5 TO 9 YEARS[TYPE OF VEHICLE,TYPE OF FUEL]))
	~	vehicle
	~		|

DROP OUT VEHICLES LESS THAN 4 YEARS[TYPE OF VEHICLE,TYPE OF FUEL]=
	INTEGER(RATIO DROP OUT VEHICLES LESS THAN 4 YEARS*(CHANGE INITIAL VEHICLE LESS THAN 4 YEARS\
		[TYPE OF VEHICLE,TYPE OF FUEL]+VEHICLE GROWTH LESS THAN 4 YEARS[TYPE OF VEHICLE,TYPE OF FUEL\
		]))
	~	vehicle
	~		|

DROP OUT VEHICLES MORE THAN 20 YEARS[TYPE OF VEHICLE,TYPE OF FUEL]=
	INTEGER(RATIO DROP OUT MORE THAN 20 YEARS*(CHANGE INITIAL VEHICLE MORE THAN 20 YEARS\
		[TYPE OF VEHICLE,TYPE OF FUEL]+VEHICLE GROWTH MORE THAN 20 YEARS[TYPE OF VEHICLE,TYPE OF FUEL\
		]))
	~	vehicle
	~		|

VEHICLE GROWTH 15 TO 19 YEARS[TYPE OF VEHICLE,TYPE OF FUEL]=
	INTEGER((DELAY VEHICLE GROWTH 10 TO 14 YEARS[TYPE OF VEHICLE,TYPE OF FUEL]+CHANGE INITIAL VEHICLE 10 TO 14 YEARS\
		[TYPE OF VEHICLE,TYPE OF FUEL])*(1-RATIO DROP OUT FROM 10 TO 14 YEARS))
	~	vehicle
	~		|

VEHICLE GROWTH 5 TO 9 YEARS[TYPE OF VEHICLE,TYPE OF FUEL]=
	INTEGER((DELAY VEHICLE GROWTH LESS THAN 4 YEARS[TYPE OF VEHICLE,TYPE OF FUEL]+CHANGE INITIAL VEHICLE LESS THAN 4 YEARS\
		[TYPE OF VEHICLE,TYPE OF FUEL])*(1-RATIO DROP OUT VEHICLES LESS THAN 4 YEARS))
	~	vehicle
	~		|

VEHICLE GROWTH LESS THAN 4 YEARS[TYPE OF VEHICLE,TYPE OF FUEL]=
	IF THEN ELSE(VEHICLES GROWTH[TYPE OF VEHICLE,TYPE OF FUEL]<0,0,INTEGER(VEHICLES GROWTH\
		[TYPE OF VEHICLE,TYPE OF FUEL]))
	~	vehicle
	~		|

DELAY VEHICLE GROWTH 10 TO 14 YEARS[TYPE OF VEHICLE,TYPE OF FUEL]= DELAY FIXED (
	VEHICLE GROWTH 10 TO 14 YEARS[TYPE OF VEHICLE,TYPE OF FUEL], 5 , 0)
	~	vehicle
	~		|

END OF VEHICLE LIFE[TYPE OF VEHICLE,TYPE OF FUEL]=
	INTEGER((DELAY VEHICLE GROWTH MORE THAN 20 YEARS[TYPE OF VEHICLE,TYPE OF FUEL]+CHANGE INITIAL VEHICLE MORE THAN 20 YEARS\
		[TYPE OF VEHICLE,TYPE OF FUEL])*(1-RATIO DROP OUT MORE THAN 20 YEARS))
	~	vehicle
	~		|

DELAY VEHICLE GROWTH 5 TO 9 YEARS[TYPE OF VEHICLE,TYPE OF FUEL]= DELAY FIXED (
	VEHICLE GROWTH 5 TO 9 YEARS[TYPE OF VEHICLE,TYPE OF FUEL], 5 , 0)
	~	vehicle
	~		|

DELAY VEHICLE GROWTH LESS THAN 4 YEARS[TYPE OF VEHICLE,TYPE OF FUEL]= DELAY FIXED (
	 VEHICLE GROWTH LESS THAN 4 YEARS[TYPE OF VEHICLE,TYPE OF FUEL], 5 , 0)
	~	vehicle
	~		|

DELAY VEHICLE GROWTH MORE THAN 20 YEARS[TYPE OF VEHICLE,TYPE OF FUEL]= DELAY FIXED (
	VEHICLE GROWTH MORE THAN 20 YEARS[TYPE OF VEHICLE,TYPE OF FUEL], 5 ,0)
	~	vehicle
	~		|

VEHICLE GROWTH 10 TO 14 YEARS[TYPE OF VEHICLE,TYPE OF FUEL]=
	INTEGER((DELAY VEHICLE GROWTH 5 TO 9 YEARS[TYPE OF VEHICLE,TYPE OF FUEL]+CHANGE INITIAL VEHICLE 5 TO 9 YEARS\
		[TYPE OF VEHICLE,TYPE OF FUEL])*(1-RATIO DROP OUT FROM 5 TO 9 YEARS))
	~	vehicle
	~		|

INITIAL VEHICLES TOT[TYPE OF VEHICLE,TYPE OF FUEL]=
	IF THEN ELSE(SWITCH CS=4,IF THEN ELSE(TYPE OF VEHICLE=TRUCK:AND:TYPE OF FUEL=ELECTRICITY\
		,INITIAL VEHICLES[TRUCK,ELECTRICITY]*RATIO ELECTRIC TRUCK OVER VAN,IF THEN ELSE(TYPE OF VEHICLE\
		=VAN:AND:TYPE OF FUEL=ELECTRICITY,INITIAL VEHICLES[VAN,ELECTRICITY]*(1-RATIO ELECTRIC TRUCK OVER VAN\
		),INITIAL VEHICLES[TYPE OF VEHICLE,TYPE OF FUEL])),INITIAL VEHICLES[TYPE OF VEHICLE\
		,TYPE OF FUEL])
	~	vehicle
	~		|

INITIAL VEHICLES[TRUCK,TYPE OF FUEL]=
	GET DIRECT CONSTANTS('Historical.xlsx', 'Transport system', 'INITIAL_VEHICLES_TRUCK'\
		) ~~|
INITIAL VEHICLES[VAN,TYPE OF FUEL]=
	GET DIRECT CONSTANTS('Historical.xlsx', 'Transport system', 'INITIAL_VEHICLES_VAN') ~~|
INITIAL VEHICLES[BUS,TYPE OF FUEL]=
	GET DIRECT CONSTANTS('Historical.xlsx', 'Transport system', 'INITIAL_VEHICLES_BUS') ~~|
INITIAL VEHICLES[CAR,TYPE OF FUEL]=
	GET DIRECT CONSTANTS('Historical.xlsx', 'Transport system', 'INITIAL_VEHICLES_CAR') ~~|
INITIAL VEHICLES[MOTORCYCLE,TYPE OF FUEL]=
	GET DIRECT CONSTANTS('Historical.xlsx', 'Transport system', 'INITIAL_VEHICLES_MOTORCYCLE'\
		) ~~|
INITIAL VEHICLES[TRACTOR,TYPE OF FUEL]=
	GET DIRECT CONSTANTS('Historical.xlsx', 'Transport system', 'INITIAL_VEHICLES_TRACTOR'\
		)
	~	vehicle
	~		|

LOSSES WITH H2=
	PRODUCTION WITH H2*LOSSES FACTOR
	~	MWh
	~		|

IMPORT WITH H2=
	IF THEN ELSE(BALANCE WITH H2>0,BALANCE WITH H2,0)
	~	MWh
	~		|

ENERGY SUPPLY CONSIDERING H2=
	PRODUCTION WITH H2-LOSSES WITH H2
	~	MWh
	~		|

TOTAL PRODUCTION CONSIDERING H2=
	SOLAR PRODUCTION AFTER H2+HYDRO PRODUCTION AFTER H2+BIOMASS PRODUCTION+NON RENEWABLE PRODUCTION\
		+ROOFTOP PRODUCTION+WIND PRODUCTION AFTER H2+H2 PRODUCTION
	~	MWh
	~		|

BALANCE WITH H2=
	ENERGY CONSUMPTION-ENERGY SUPPLY CONSIDERING H2
	~	MWh
	~		|

EXPORT WITH H2=
	IF THEN ELSE(BALANCE WITH H2<0,-1*BALANCE WITH H2,0)
	~	MWh
	~		|

PRODUCTION WITH H2=
	TOTAL PRODUCTION CONSIDERING H2
	~	MWh
	~		|

H2 PRODUCTION=
	REQUEST FROM ENERGY DEMAND WITH POLICY
	~	MWh
	~		|

TOTAL PRODUCTION=
	BIOMASS PRODUCTION+HYDRO PRODUCTION+NON RENEWABLE PRODUCTION+ROOFTOP PRODUCTION+SOLAR PRODUCTION\
		+WIND PRODUCTION
	~	MWh
	~		|

ENERGY DISTRIBUTION=
	(ENERGY CONSUMPTION-IMPORT)*RENEWABLES RATIO
	~	MWh
	~		|

GREEN URBAN= INTEG (
	IF THEN ELSE (SWITCH GREEN URBAN PLANNING=0, MIN(URBAN EXPANSION*RATIO OTHER TO GREEN AREA\
		+URBAN EXPANSION FROM WETLANDS
	*RATIO WETLANDS TO GREEN AREA+URBANIZATION*RATIO AGRICULTURE TO GREEN AREA-URBAN TO WATER\
		*RATIO GREEN AREA TO WATER,URBAN
	*0.9),
	IF THEN ELSE(SWITCH GREEN URBAN PLANNING=1:AND:Time<INITIAL YEAR GREEN URBAN PLANNING\
		:OR:Time>FINAL YEAR GREEN URBAN PLANNING
	,MIN(URBAN EXPANSION*RATIO OTHER TO GREEN AREA+URBAN EXPANSION FROM WETLANDS*RATIO WETLANDS TO GREEN AREA\
		+URBANIZATION*
	RATIO AGRICULTURE TO GREEN AREA
	-URBAN TO WATER*RATIO GREEN AREA TO WATER,URBAN*0.9),MIN((URBAN EXPANSION*RATIO OTHER TO GREEN AREA\
		+URBAN EXPANSION FROM WETLANDS
	*RATIO WETLANDS TO GREEN AREA+URBANIZATION*RATIO AGRICULTURE TO GREEN AREA-URBAN TO WATER\
		*RATIO GREEN AREA TO WATER)*(GREEN URBAN PLANNING OBJECTIVE
	)*(1/(FINAL YEAR GREEN URBAN PLANNING-INITIAL YEAR GREEN URBAN PLANNING)),URBAN*0.9)\
		)),
		INITIAL GREEN URBAN AREA)
	~	km2
	~		|

RENEWABLES RATIO=
	ENERGY CONSUMPTION SHARE[RENEWABLES]/ENERGY CONSUMPTION
	~	MWh
	~		|

GDP DOLLARS=
	GDP PER CAPITA/EURO TO DOLLAR
	~	Dollars
	~		|

URBAN EXPANSION=
	IF THEN ELSE( OTHER>(INITIAL OTHER AREA*0.5), MIN((URBAN*(EXPANSION RATIO*CONVERSION SPEED\
		)/100)*0.6, (INITIAL OTHER AREA*0.5)/1),0 )
	~	km2
	~		|

URBAN TO WATER=
	IF THEN ELSE (SELECT LOCATION WATER STORAGE=2,WATER AREA,0)
	~	km2
	~		|

URBANIZATION=
	ACCESIBILITY RESTRICTION*AGRICULTURE*EXPANSION RATIO*0.3
	~	km2
	~		|

WETLANDS= INTEG (
	-URBAN EXPANSION FROM WETLANDS-WETLANDS DESERTION,
		INITIAL WETLANDS AREA)
	~	km2
	~		|

BALANCE FOR H2=
	ENERGY CONSUMPTION-ENERGY SUPPLY
	~	MWh
	~		|

TOTAL DAMAGES CURRENT VALUE[RETURN PERIOD]=
	TOTAL DAMAGES[RETURN PERIOD]*(1*((1+INFLATION RATE 2018 TO 2024)^8))
	~	Euros
	~		|

DAMAGES IN OTHER[RETURN PERIOD, FLOOD DEPTH]=
	MAXIMUM DAMAGE OTHER*DAMAGE BY DEPTH IN OTHER[RETURN PERIOD,FLOOD DEPTH]
	~	Euros 2010
	~		|

DAMAGES IN ROADS RAILWAYS[RETURN PERIOD, FLOOD DEPTH]=
	MAXIMUM DAMAGE ROADS RAILWAYS*DAMAGE BY DEPTH IN ROADS RAILWAYS[RETURN PERIOD,FLOOD DEPTH\
		]
	~	Euros 2010
	~		|

DAMAGES IN URBAN[RETURN PERIOD, FLOOD DEPTH]=
	MAXIMUM DAMAGE URBAN*DAMAGE BY DEPTH IN URBAN[RETURN PERIOD,FLOOD DEPTH]
	~	Euros 2010
	~		|

FLOOD AREA ROADS RAILWAYS[RETURN PERIOD,FLOOD DEPTH]=
	FLOOD AREA[RETURN PERIOD,FLOOD DEPTH,RAIL RAILWAYS]*1e+06
	~	
	~		|

FLOOD AREA URBAN[RETURN PERIOD,FLOOD DEPTH]=
	FLOOD AREA[RETURN PERIOD,FLOOD DEPTH,URBAN LAND]*1e+06
	~	m2
	~		|

FLOOD DEPTH:
	ONE METER, TWO METERS, THREE METERS, FOUR METERS, HIGHER THAN FOUR METERS
	~	
	~		|

FLOODED LAND:
	URBAN LAND, OTHER LAND, RAIL RAILWAYS
	~	
	~		|

SWITCH POLICY FLOOD DEFENSES FOR URBAN AREAS=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Floods', 'SWITCH_POLICY_DEFENSES*')
	~	Dmnl
	~	0 = Without flood defences
		1 = With flood defences
	|

AGGREGATED DAMAGES IN OTHER[RETURN PERIOD]=
	SUM(DAMAGES IN OTHER[RETURN PERIOD,FLOOD DEPTH!])
	~	Euros 2010
	~		|

AGGREGATED DAMAGES IN ROADS RAILWAYS[RETURN PERIOD]=
	SUM(DAMAGES IN ROADS RAILWAYS[RETURN PERIOD,FLOOD DEPTH!])
	~	Euros 2010
	~		|

AGGREGATED DAMAGES IN URBAN[RETURN PERIOD]=
	SUM(DAMAGES IN URBAN[RETURN PERIOD,FLOOD DEPTH!])
	~	Euros 2010
	~		|

EURO TO DOLLAR=
	0.86
	~	Dmnl
	~		|

RETURN PERIOD:
	TEN, FIFTY, HUNDRED
	~	
	~		|

FLOOD AREA[TEN, FLOOD DEPTH, FLOODED LAND]=
	GET DIRECT CONSTANTS('Historical.xlsx', 'Floods', 'RP10_DATA') ~~|
FLOOD AREA[FIFTY, FLOOD DEPTH, FLOODED LAND]=
	GET DIRECT CONSTANTS('Historical.xlsx', 'Floods', 'RP50_DATA') ~~|
FLOOD AREA[HUNDRED, FLOOD DEPTH, FLOODED LAND]=
	GET DIRECT CONSTANTS('Historical.xlsx', 'Floods', 'RP100_DATA')
	~	km2
	~		|

FLOOD AREA OTHER[RETURN PERIOD,FLOOD DEPTH]=
	FLOOD AREA[RETURN PERIOD,FLOOD DEPTH,OTHER LAND]*1e+06
	~	
	~		|

EXPECTED LOSSES BY FLOODS[RETURN PERIOD]= INTEG (
	(TOTAL DAMAGES CURRENT VALUE[RETURN PERIOD]*(1+INFLATION))-TOTAL DAMAGES CURRENT VALUE\
		[RETURN PERIOD],
		TOTAL DAMAGES CURRENT VALUE[RETURN PERIOD])
	~	Euros
	~		|

OTHER DAMAGE AT DEPTH[FLOOD DEPTH]=
	0.55, 0.75, 0.85, 0.95, 1
	~	Dmnl
	~		|

INFLATION RATE 2018 TO 2024=
	GET DIRECT CONSTANTS('Historical.xlsx', 'Floods', 'HISTORICAL_INFLATION_RATE')
	~	Dmnl
	~		|

ROADS RAILWAYS DAMAGE AT DEPTH[FLOOD DEPTH]=
	0.42, 0.65, 0.8, 0.9, 1
	~	Dmnl
	~		|

MAXIMUM DAMAGE OTHER=
	(0.000585*GDP DOLLARS)+29.12
	~	Euros/m2
	~		|

MAXIMUM DAMAGE ROADS RAILWAYS=
	(0.000403*GDP DOLLARS)+26.2
	~	Euros/m2
	~		|

INFLATION=
	GET DIRECT CONSTANTS('Historical.xlsx', 'Floods', 'INFLATION_RATE')
	~	Dmnl
	~		|

URBAN DAMAGE AT DEPTH CONSIDERING FLOOD DEFENSES[FLOOD DEPTH]=
	0.08, 0.45, 0.68, 0.85, 0.95
	~	Dmnl
	~		|

TOTAL DAMAGES[RETURN PERIOD]=
	(AGGREGATED DAMAGES IN URBAN[RETURN PERIOD]+AGGREGATED DAMAGES IN OTHER[RETURN PERIOD\
		]+AGGREGATED DAMAGES IN ROADS RAILWAYS[RETURN PERIOD])
	~	Euros 2010
	~		|

URBAN DAMAGE AT DEPTH[FLOOD DEPTH]=
	0.4, 0.6, 0.75, 0.85, 0.95
	~	Dmnl
	~		|

MAXIMUM DAMAGE URBAN=
	(0.0034*GDP DOLLARS)+195.8
	~	Euros/m2
	~		|

RATIO DROP OUT FROM 10 TO 14 YEARS=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Transport system', 'RATIO_DROP_OUT_VEHICLES_FROM_10_TO_14_YEARS*'\
		)
	~	Dmnl
	~	0.2
	|

RATIO DROP OUT FROM 15 TO 19 YEARS=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Transport system', 'RATIO_DROP_OUT_VEHICLES_FROM_15_TO_19_YEARS*'\
		)
	~	Dmnl
	~	0.4
	|

RATIO DROP OUT FROM 5 TO 9 YEARS=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Transport system', 'RATIO_DROP_OUT_VEHICLES_FROM_5_TO_9_YEARS*'\
		)
	~	Dmnl
	~	0.08
	|

RATIO DROP OUT MORE THAN 20 YEARS=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Transport system', 'RATIO_DROP_OUT_VEHICLES_MORE_THAN_20_YEARS*'\
		)
	~	Dmnl
	~	0.8
	|

RATIO DROP OUT VEHICLES LESS THAN 4 YEARS=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Transport system', 'RATIO_DROP_OUT_VEHICLES_LESS_THAN_4_YEARS*'\
		)
	~	Dmnl
	~	0.02
	|

LIMIT 2 VEHICLE GROWTH[TRUCK,TYPE OF FUEL]=
	GET DIRECT CONSTANTS('Historical.xlsx', 'Transport system', 'LIMIT_2_VEHICLE_GROWTH_TRUCK'\
		) ~~|
LIMIT 2 VEHICLE GROWTH[VAN,TYPE OF FUEL]=
	GET DIRECT CONSTANTS('Historical.xlsx', 'Transport system', 'LIMIT_2_VEHICLE_GROWTH_VAN'\
		) ~~|
LIMIT 2 VEHICLE GROWTH[BUS,TYPE OF FUEL]=
	GET DIRECT CONSTANTS('Historical.xlsx', 'Transport system', 'LIMIT_2_VEHICLE_GROWTH_BUS'\
		) ~~|
LIMIT 2 VEHICLE GROWTH[CAR,TYPE OF FUEL]=
	GET DIRECT CONSTANTS('Historical.xlsx', 'Transport system', 'LIMIT_2_VEHICLE_GROWTH_CAR'\
		) ~~|
LIMIT 2 VEHICLE GROWTH[MOTORCYCLE,TYPE OF FUEL]=
	GET DIRECT CONSTANTS('Historical.xlsx', 'Transport system', 'LIMIT_2_VEHICLE_GROWTH_MOTORCYCLE'\
		) ~~|
LIMIT 2 VEHICLE GROWTH[TRACTOR,TYPE OF FUEL]=
	GET DIRECT CONSTANTS('Historical.xlsx', 'Transport system', 'LIMIT_2_VEHICLE_GROWTH_TRACTOR'\
		)
	~	Dmnl
	~		|

VEHICLE AGE:
	LESS THAN 4 YEARS, FROM 5 TO 9 YEARS, FROM 10 TO 14 YEARS, FROM 15 TO 19 YEARS, MORE THAN 20 YEARS
	~	age
	~		|

RATIO OF INITIAL VEHICLES BASED ON AGE[TRUCK,VEHICLE AGE]=
	GET DIRECT CONSTANTS('Policy.xlsx', 'Transport system', 'RATIO_OF_INITIAL_VEHICLES_BASED_ON_AGE_TRUCK'\
		) ~~|
RATIO OF INITIAL VEHICLES BASED ON AGE[VAN,VEHICLE AGE]=
	GET DIRECT CONSTANTS('Policy.xlsx', 'Transport system', 'RATIO_OF_INITIAL_VEHICLES_BASED_ON_AGE_VAN'\
		) ~~|
RATIO OF INITIAL VEHICLES BASED ON AGE[BUS,VEHICLE AGE]=
	GET DIRECT CONSTANTS('Policy.xlsx', 'Transport system', 'RATIO_OF_INITIAL_VEHICLES_BASED_ON_AGE_BUS'\
		) ~~|
RATIO OF INITIAL VEHICLES BASED ON AGE[CAR,VEHICLE AGE]=
	GET DIRECT CONSTANTS('Policy.xlsx', 'Transport system', 'RATIO_OF_INITIAL_VEHICLES_BASED_ON_AGE_CAR'\
		) ~~|
RATIO OF INITIAL VEHICLES BASED ON AGE[MOTORCYCLE,VEHICLE AGE]=
	GET DIRECT CONSTANTS('Policy.xlsx', 'Transport system', 'RATIO_OF_INITIAL_VEHICLES_BASED_ON_AGE_MOTORCYCLE'\
		) ~~|
RATIO OF INITIAL VEHICLES BASED ON AGE[TRACTOR,VEHICLE AGE]=
	GET DIRECT CONSTANTS('Policy.xlsx', 'Transport system', 'RATIO_OF_INITIAL_VEHICLES_BASED_ON_AGE_TRACTOR'\
		)
	~	Dmnl
	~		|

LIMIT 1 VEHICLE GROWTH[TRUCK,TYPE OF FUEL]=
	GET DIRECT CONSTANTS('Historical.xlsx', 'Transport system', 'LIMIT_1_VEHICLE_GROWTH_TRUCK'\
		) ~~|
LIMIT 1 VEHICLE GROWTH[VAN,TYPE OF FUEL]=
	GET DIRECT CONSTANTS('Historical.xlsx', 'Transport system', 'LIMIT_1_VEHICLE_GROWTH_VAN'\
		) ~~|
LIMIT 1 VEHICLE GROWTH[BUS,TYPE OF FUEL]=
	GET DIRECT CONSTANTS('Historical.xlsx', 'Transport system', 'LIMIT_1_VEHICLE_GROWTH_BUS'\
		) ~~|
LIMIT 1 VEHICLE GROWTH[CAR,TYPE OF FUEL]=
	GET DIRECT CONSTANTS('Historical.xlsx', 'Transport system', 'LIMIT_1_VEHICLE_GROWTH_CAR'\
		) ~~|
LIMIT 1 VEHICLE GROWTH[MOTORCYCLE,TYPE OF FUEL]=
	GET DIRECT CONSTANTS('Historical.xlsx', 'Transport system', 'LIMIT_1_VEHICLE_GROWTH_MOTORCYCLE'\
		) ~~|
LIMIT 1 VEHICLE GROWTH[TRACTOR,TYPE OF FUEL]=
	GET DIRECT CONSTANTS('Historical.xlsx', 'Transport system', 'LIMIT_1_VEHICLE_GROWTH_TRACTOR'\
		)
	~	Dmnl
	~		|

WIND PRODUCTION AFTER H2=
	WIND PRODUCTION-WIND ENERGY REQUEST
	~	MWh
	~		|

LITERS TO HM3=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Energy', 'LITERS_TO_HM3*')
	~	Dmnl
	~		|

TRANSFORMATION COEFFICIENT ONE=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Energy', 'TRANSFORMATION_COEFFICIENT_ONE*'\
		)
	~	kWh/kg
	~		|

TRANSFORMATION COEFFICIENT TWO=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Energy', 'TRANSFORMATION_COEFFICIENT_TWO*'\
		)
	~	kg/kWh
	~		|

FINAL YEAR H2 POLICY=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Energy', 'FINAL_YEAR_H2_POLICY*')
	~	Year
	~		|

HYDRO ENERGY REQUEST=
	ENERGY REQUESTED FROM H2 PRODUCTION*ENERGY DISTRIBUTION SCENARIO FOR H2[HYDRO]
	~	kWh
	~		|

H2 OBJECTIVE IN RENEWABLES=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Energy', 'H2_OBJECTIVE_IN_RENEWABLES*')
	~	Dmnl
	~		|

HYDRO PRODUCTION AFTER H2=
	HYDRO PRODUCTION-HYDRO ENERGY REQUEST
	~	MWh
	~		|

KWH TO MWH=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Energy', 'KWH_TO_MWH*')
	~	Dmnl
	~		|

SWITCH H2 POLICY=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Energy', 'SWITCH_H2_POLICY*')
	~	Dmnl
	~	0=OFF
		1=ON
	|

SOLAR PRODUCTION AFTER H2=
	SOLAR PRODUCTION-SOLAR ENERGY REQUEST
	~	MWh
	~		|

WATER REQUIREMENTS FROM H2 PRODUCTION=
	(((H2 PRODUCTION/KWH TO MWH)/TRANSFORMATION COEFFICIENT ONE)*WATER CONSUMPTION)/LITERS TO HM3
	~	Hm3
	~		|

ENERGY DISTRIBUTION SCENARIO FOR H2[TYPE OF RENEWABLES]=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Energy', 'ENERGY_DISTRIBUTION_SCENARIO_FOR_H2*'\
		)
	~	Dmnl
	~		|

INITIAL ROLE OF H2 IN RENEWABLES=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Energy', 'INITIAL_ROLE_OF_H2_IN_RENEWABLES*')
	~	Dmnl
	~		|

REQUEST FROM ENERGY DEMAND WITH POLICY= INTEG (
	IF THEN ELSE (SWITCH H2 POLICY= 0, 0,
	IF THEN ELSE (SWITCH H2 POLICY=1:AND:(Time<INITIAL YEAR H2 POLICY:OR:Time>FINAL YEAR H2 POLICY\
		-1),0,
	((H2 OBJECTIVE IN RENEWABLES-INITIAL ROLE OF H2 IN RENEWABLES)/(FINAL YEAR H2 POLICY\
		 - INITIAL YEAR H2 POLICY))*ENERGY DISTRIBUTION)),
		0)
	~	MWh
	~		|

INITIAL YEAR H2 POLICY=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Energy', 'INITIAL_YEAR_H2_POLICY*')
	~	Year
	~		|

WATER DEMAND=
	WATER DEMAND FROM AGRICULTURE+WATER DEMAND FROM INDUSTRY+WATER DEMAND FROM URBAN+WATER USED FOR SNOW PRODUCTION\
		+WATER REQUIREMENTS FROM H2 PRODUCTION
	~	Hm3
	~		|

WIND ENERGY REQUEST=
	ENERGY REQUESTED FROM H2 PRODUCTION*ENERGY DISTRIBUTION SCENARIO FOR H2[WIND]
	~	kWh
	~		|

SOLAR ENERGY REQUEST=
	ENERGY REQUESTED FROM H2 PRODUCTION*ENERGY DISTRIBUTION SCENARIO FOR H2[SOLAR]
	~	kWh
	~		|

WATER CONSUMPTION=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Energy', 'WATER_CONSUMPTION*')
	~	l/kg
	~		|

ENERGY REQUESTED FROM H2 PRODUCTION=
	(H2 PRODUCTION/(TRANSFORMATION COEFFICIENT ONE*KWH TO MWH))*(TRANSFORMATION COEFFICIENT TWO\
		*KWH TO MWH)
	~	MWh
	~		|

RATIO OF GREEN URBAN AREA=
	1-(GREEN URBAN/URBAN)
	~	Dmnl
	~		|

RATIO ELECTRIC TRUCK OVER VAN=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Transport system', 'RATIO_ELECTRIC_TRUCK_OVER_VAN*'\
		)
	~	Dmnl
	~		|

MEDIUM INCENTIVES ELECTRIC VEHICLES=
	0.5
	~	Dmnl
	~		|

INITIAL YEAR GREEN URBAN PLANNING=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Land system', 'INITIAL_YEAR_GREEN_URBAN_PLANNING*'\
		)
	~	Year
	~		|

FINAL YEAR GREEN URBAN PLANNING=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Land system', 'FINAL_YEAR_GREEN_URBAN_PLANNING*'\
		)
	~	Year
	~		|

ALPHA VEHICLE[TRUCK,TYPE OF FUEL]=
	GET DIRECT CONSTANTS('Historical.xlsx', 'Transport system', 'ALPHA_VEHICLE_TRUCK') ~~|
ALPHA VEHICLE[VAN,TYPE OF FUEL]=
	GET DIRECT CONSTANTS('Historical.xlsx', 'Transport system', 'ALPHA_VEHICLE_VAN') ~~|
ALPHA VEHICLE[BUS,TYPE OF FUEL]=
	GET DIRECT CONSTANTS('Historical.xlsx', 'Transport system', 'ALPHA_VEHICLE_BUS') ~~|
ALPHA VEHICLE[CAR,TYPE OF FUEL]=
	GET DIRECT CONSTANTS('Historical.xlsx', 'Transport system', 'ALPHA_VEHICLE_CAR') ~~|
ALPHA VEHICLE[MOTORCYCLE,TYPE OF FUEL]=
	GET DIRECT CONSTANTS('Historical.xlsx', 'Transport system', 'ALPHA_VEHICLE_MOTORCYCLE'\
		) ~~|
ALPHA VEHICLE[TRACTOR,TYPE OF FUEL]=
	GET DIRECT CONSTANTS('Historical.xlsx', 'Transport system', 'ALPHA_VEHICLE_TRACTOR')
	~	Dmnl
	~		|

SUBSIDIES ELECTRIC VEHICLES OBJECTIVE[TYPE OF FUEL]=
	IF THEN ELSE(TYPE OF FUEL=ELECTRICITY,IF THEN ELSE (SELECT INCENTIVES ELECTRIC VEHICLES\
		 = 0, LOW INCENTIVES ELECTRIC VEHICLES,
	IF THEN ELSE (SELECT INCENTIVES ELECTRIC VEHICLES = 1, MEDIUM INCENTIVES ELECTRIC VEHICLES\
		,
	IF THEN ELSE (SELECT INCENTIVES ELECTRIC VEHICLES = 2, HIGH INCENTIVES ELECTRIC VEHICLES\
		,
	IF THEN ELSE (SELECT INCENTIVES ELECTRIC VEHICLES = 3, VERY HIGH INCENTIVES ELECTRIC VEHICLES\
		, LOW INCENTIVES ELECTRIC VEHICLES)))),
	IF THEN ELSE(SELECT INCENTIVES ELECTRIC VEHICLES = 0, -LOW INCENTIVES ELECTRIC VEHICLES\
		,
	IF THEN ELSE (SELECT INCENTIVES ELECTRIC VEHICLES = 1, -MEDIUM INCENTIVES ELECTRIC VEHICLES\
		,
	IF THEN ELSE (SELECT INCENTIVES ELECTRIC VEHICLES = 2, -HIGH INCENTIVES ELECTRIC VEHICLES\
		,
	IF THEN ELSE (SELECT INCENTIVES ELECTRIC VEHICLES = 3, -VERY HIGH INCENTIVES ELECTRIC VEHICLES\
		, -LOW INCENTIVES ELECTRIC VEHICLES)))))
	~	Dmnl
	~		|

HIGH INCENTIVES ELECTRIC VEHICLES=
	0.75
	~	Dmnl
	~		|

SWITCH INCREASE IN ELECTRIC VEHICLES=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Transport system', 'SWITCH_SUBSIDIES_ELECTRIC_VEHICLES*'\
		)
	~	Dmnl
	~	0 = OFF
		1 = ON
		GET DIRECT CONSTANTS ('Policy.xlsx', 'Transport system', \
		'SWITCH_SUBSIDIES_ELECTRIC_VEHICLES*')
	|

SWITCH GREEN URBAN PLANNING=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Land system', 'SWITCH_GREEN_URBAN_PLANNING*')
	~	Dmnl
	~	0=OFF
		1=ON
	|

RATIO GREEN AREA TO WATER=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Land system', 'RATIO_GREEN_AREA_TO_WATER*')
	~	Dmnl
	~		|

BETA VEHICLE[TRUCK,TYPE OF FUEL]=
	GET DIRECT CONSTANTS('Historical.xlsx', 'Transport system', 'BETA_VEHICLE_TRUCK') ~~|
BETA VEHICLE[VAN,TYPE OF FUEL]=
	GET DIRECT CONSTANTS('Historical.xlsx', 'Transport system', 'BETA_VEHICLE_VAN') ~~|
BETA VEHICLE[BUS,TYPE OF FUEL]=
	GET DIRECT CONSTANTS('Historical.xlsx', 'Transport system', 'BETA_VEHICLE_BUS') ~~|
BETA VEHICLE[CAR,TYPE OF FUEL]=
	GET DIRECT CONSTANTS('Historical.xlsx', 'Transport system', 'BETA_VEHICLE_CAR') ~~|
BETA VEHICLE[MOTORCYCLE,TYPE OF FUEL]=
	GET DIRECT CONSTANTS('Historical.xlsx', 'Transport system', 'BETA_VEHICLE_MOTORCYCLE'\
		) ~~|
BETA VEHICLE[TRACTOR,TYPE OF FUEL]=
	GET DIRECT CONSTANTS('Historical.xlsx', 'Transport system', 'BETA_VEHICLE_TRACTOR')
	~	Dmnl
	~		|

GREEN URBAN PLANNING OBJECTIVE=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Land system', 'GREEN_URBAN_PLANNING_OBJECTIVE*'\
		)
	~	km2
	~		|

RATIO AGRICULTURE TO GREEN AREA=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Land system', 'RATIO_AGRICULTURE_TO_GREEN_AREA*'\
		)
	~	Dmnl
	~		|

FINAL YEAR INCREASE IN ELECTRIC VEHICLES=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Transport system', 'FINAL_YEAR_SUBSIDIES_ELECTRIC_VEHICLES*'\
		)
	~	Year
	~		|

VERY HIGH INCENTIVES ELECTRIC VEHICLES=
	1
	~	Dmnl
	~		|

INITIAL YEAR INCREASE IN ELECTRIC VEHICLES=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Transport system', 'INITIAL_YEAR_SUBSIDIES_ELECTRIC_VEHICLES*'\
		)
	~	Year
	~		|

SELECT INCENTIVES ELECTRIC VEHICLES=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Transport system', 'SELECT_SUBSIDIES_ELECTRIC_VEHICLES*'\
		)
	~	Dmnl
	~	0 = Low
		1 = Medium
		2 = High
		3 = Very High
	|

RATIO OTHER TO GREEN AREA=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Land system', 'RATIO_OTHER_TO_GREEN_AREA*')
	~	Dmnl
	~		|

RATIO WETLANDS TO GREEN AREA=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Land system', 'RATIO_WETLANDS_TO_GREEN_AREA*')
	~	Dmnl
	~		|

INITIAL GREEN URBAN AREA=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Land system', 'INITIAL_GREEN_URBAN_AREA*')
	~	km2
	~		|

BUILT UP URBAN=
	URBAN-GREEN URBAN
	~	km2
	~		|

LOW INCENTIVES ELECTRIC VEHICLES=
	0.25
	~	Dmnl
	~		|

GDP=
	CS POPULATION*GDP PER CAPITA
	~	Euros
	~		|

DISTANCE COVERED=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Transport system', 'DISTANCE_COVERED*')
	~	km
	~		|

TYPE OF VEHICLE:
	TRUCK, VAN, BUS, CAR, MOTORCYCLE, TRACTOR
	~	Dmnl
	~		|

VEHICLES EMISSION COEFFICIENT[TRUCK,TYPE OF FUEL]=
	GET DIRECT CONSTANTS('Historical.xlsx', 'Transport system', 'VEHICLES_EMISSION_COEFFICIENT_TRUCK'\
		) ~~|
VEHICLES EMISSION COEFFICIENT[VAN,TYPE OF FUEL]=
	GET DIRECT CONSTANTS('Historical.xlsx', 'Transport system', 'VEHICLES_EMISSION_COEFFICIENT_VAN'\
		) ~~|
VEHICLES EMISSION COEFFICIENT[BUS,TYPE OF FUEL]=
	GET DIRECT CONSTANTS('Historical.xlsx', 'Transport system', 'VEHICLES_EMISSION_COEFFICIENT_BUS'\
		) ~~|
VEHICLES EMISSION COEFFICIENT[CAR,TYPE OF FUEL]=
	GET DIRECT CONSTANTS('Historical.xlsx', 'Transport system', 'VEHICLES_EMISSION_COEFFICIENT_CAR'\
		) ~~|
VEHICLES EMISSION COEFFICIENT[MOTORCYCLE,TYPE OF FUEL]=
	GET DIRECT CONSTANTS('Historical.xlsx', 'Transport system', 'VEHICLES_EMISSION_COEFFICIENT_MOTORCYCLE'\
		) ~~|
VEHICLES EMISSION COEFFICIENT[TRACTOR,TYPE OF FUEL]=
	GET DIRECT CONSTANTS('Historical.xlsx', 'Transport system', 'VEHICLES_EMISSION_COEFFICIENT_TRACTOR'\
		)
	~	tCO2/km
	~		|

TYPE OF FUEL:
	PETROL, DIESEL, ELECTRICITY
	~	Dmnl
	~		|

ARTIFICIAL SNOW PRODUCTION YEARLY=
	SUM(ARTIFICIAL SNOW PRODUCTION MONTHLY[MONTHS!])
	~	m3
	~		|

RATIO 2018 AND 2045=
	1-ZIDZ( RATIO ENERGY AND GDP 2045 , RATIO ENERGY AND GDP 2018 )
	~	
	~		|

RATIO 2018 AND 2030=
	1-ZIDZ( RATIO ENERGY AND GDP 2030 , RATIO ENERGY AND GDP 2018 )
	~	
	~		|

RATIO ENERGY AND GDP 2045=
	SAMPLE IF TRUE(Time=2045 , RATIO ENERGY CONSUMPTION AND GDP PER CAPITA , 0)
	~	MWh/euro per capita
	~		|

RATIO ENERGY CONSUMPTION AND GDP PER CAPITA=
	ENERGY CONSUMPTION/GDP PER CAPITA
	~	MWh/euro per capita
	~		|

RATIO ENERGY AND GDP 2030=
	SAMPLE IF TRUE( Time=2030 , RATIO ENERGY CONSUMPTION AND GDP PER CAPITA,0)
	~	MWh/euro per capita
	~		|

ENERGY CONSUMPTION=
	IF THEN ELSE(SWITCH ENERGY EFFICIENCY INCREASE=0,ENERGY CONSUMPTION DOMESTIC AND INDUSTRY\
		+ENERGY CONSUMPTION DESALINATION+ENERGY CONSUMPTION WATER TREATMENT
	+ENERGY USED FOR SNOW PRODUCTION
	,IF THEN ELSE(SWITCH ENERGY EFFICIENCY INCREASE=
	1:AND:(Time<INITIAL YEAR ENERGY EFFICIENCY INCREASE),ENERGY CONSUMPTION DOMESTIC AND INDUSTRY\
		+ENERGY CONSUMPTION DESALINATION+ENERGY CONSUMPTION WATER TREATMENT
	+ENERGY USED FOR SNOW PRODUCTION
	, IF THEN ELSE(SWITCH ENERGY EFFICIENCY INCREASE
	=1:AND:(Time>FINAL YEAR ENERGY EFFICIENCY INCREASE),(ENERGY USED FOR SNOW PRODUCTION\
		+ENERGY CONSUMPTION DESALINATION+ENERGY CONSUMPTION WATER TREATMENT
	+ENERGY CONSUMPTION DOMESTIC AND INDUSTRY)*(1-(ENERGY EFFICIENCY OBJECTIVE)),(ENERGY USED FOR SNOW PRODUCTION\
		+ENERGY CONSUMPTION DESALINATION+ENERGY CONSUMPTION WATER TREATMENT
	+
	ENERGY CONSUMPTION DOMESTIC AND INDUSTRY)*(1-((ENERGY EFFICIENCY OBJECTIVE)*(Time-INITIAL YEAR ENERGY EFFICIENCY INCREASE\
		)/(FINAL YEAR ENERGY EFFICIENCY INCREASE
	 - INITIAL YEAR ENERGY EFFICIENCY INCREASE))))))
	~	MWh
	~		|

ENERGY CONSUMPTION DOMESTIC AND INDUSTRY=
	CONSUMPTION PER CAPITA*CS POPULATION
	~	MWh
	~		|

RATIO ENERGY AND GDP 2018=SAMPLE IF TRUE(
	Time=2018,RATIO ENERGY CONSUMPTION AND GDP PER CAPITA,RATIO ENERGY CONSUMPTION AND GDP PER CAPITA\
		)
	~	MWh/euro per capita
	~		|

MAX BIOMASS INCREASE TOT=
	MAX BIOMASS INCREASE PER YEAR*(2060-2018)
	~	MW
	~		|

NEW BIOMASS CAPACITY=
	IF THEN ELSE(SWITCH BIOMASS CAPACITY=0,0,
	IF THEN ELSE(SWITCH BIOMASS CAPACITY=1:AND:(Time<INITIAL YEAR BIOMASS POLICY CAPACITY\
		:OR:Time>FINAL YEAR BIOMASS POLICY CAPACITY
	),0,MIN((BIOMASS CAPACITY OBJECTIVE)/(FINAL YEAR BIOMASS POLICY CAPACITY - INITIAL YEAR BIOMASS POLICY CAPACITY\
		), MAX BIOMASS CAPACITY
	-BIOMASS CAPACITY)))
	~	MW
	~	IF THEN ELSE(SWITCH BIOMASS CAPACITY=0,MIN(MARKET DRIVEN INVESTMENTS FOR BIOMASS \
		CAPACITY,MAX BIOMASS CAPACITY-BIOMASS CAPACITY
		),
		IF THEN ELSE(SWITCH BIOMASS CAPACITY=1:AND:(Time<INITIAL YEAR BIOMASS POLICY \
		CAPACITY:OR:Time>FINAL YEAR BIOMASS POLICY CAPACITY
		),MIN(MARKET DRIVEN INVESTMENTS FOR BIOMASS CAPACITY,MAX BIOMASS CAPACITY-BIOMASS \
		CAPACITY),
		IF THEN ELSE( BIOMASS CAPACITY < MAX BIOMASS CAPACITY, IF THEN ELSE(((BIOMASS \
		CAPACITY OBJECTIVE)/(FINAL YEAR BIOMASS POLICY CAPACITY
		 - INITIAL YEAR BIOMASS POLICY CAPACITY))>MARKET DRIVEN INVESTMENTS FOR BIOMASS \
		CAPACITY,MIN((BIOMASS CAPACITY OBJECTIVE
		)/(FINAL YEAR BIOMASS POLICY CAPACITY - INITIAL YEAR BIOMASS POLICY CAPACITY), MAX \
		BIOMASS CAPACITY-BIOMASS CAPACITY),MIN
		(MARKET DRIVEN INVESTMENTS FOR BIOMASS CAPACITY,MAX BIOMASS \
		CAPACITY-BIOMASS CAPACITY)), 0 ) ) )
	|

MAX BIOMASS CAPACITY=
	INITIAL BIOMASS CAPACITY+MAX BIOMASS INCREASE TOT
	~	MW
	~		|

VOLUME SNOW ACCUMULATION[MONTHS]=
	TOT SNOW ACCUMULATION CS2[MONTHS]*SKI SLOPE AREA*0.01
	~	m3
	~		|

TOT SNOW ACCUMULATION CS2[MONTHS]=
	IF THEN ELSE(SWITCH CS=2,IF THEN ELSE(MONTHS = OCTOBER, SNOW ACCUMULATION MONTHLY[OCTOBER\
		]*0.7,
	IF THEN ELSE(MONTHS=NOVEMBER,SNOW ACCUMULATION MONTHLY[NOVEMBER]*0.7+SNOW ACCUMULATION MONTHLY\
		[OCTOBER]*0.7*0.6,
	IF THEN ELSE(MONTHS=DECEMBER,SNOW ACCUMULATION MONTHLY[DECEMBER]*0.7+(SNOW ACCUMULATION MONTHLY\
		[NOVEMBER]*0.7+SNOW ACCUMULATION MONTHLY[OCTOBER]*0.7*0.6)*0.6,
	IF THEN ELSE(MONTHS=JANUARY,SNOW ACCUMULATION MONTHLY[JANUARY]*0.7+(SNOW ACCUMULATION MONTHLY\
		[DECEMBER]+(SNOW ACCUMULATION MONTHLY[NOVEMBER]+SNOW ACCUMULATION MONTHLY[OCTOBER]*\
		0.6)*0.6)*0.7*0.6,
	IF THEN ELSE(MONTHS=FEBRUARY,SNOW ACCUMULATION MONTHLY[FEBRUARY]*0.7+(SNOW ACCUMULATION MONTHLY\
		[JANUARY]+(SNOW ACCUMULATION MONTHLY[DECEMBER]+(SNOW ACCUMULATION MONTHLY[NOVEMBER]\
		+SNOW ACCUMULATION MONTHLY[OCTOBER]*0.6)*0.6)*0.6)*0.7*0.6,
	IF THEN ELSE(MONTHS=MARCH,SNOW ACCUMULATION MONTHLY[MARCH]*0.7+(SNOW ACCUMULATION MONTHLY\
		[FEBRUARY]+(SNOW ACCUMULATION MONTHLY[JANUARY]+(SNOW ACCUMULATION MONTHLY[DECEMBER]\
		+(SNOW ACCUMULATION MONTHLY[NOVEMBER]+SNOW ACCUMULATION MONTHLY[OCTOBER]*0.6)*0.6)*\
		0.6)*0.6)*0.7*0.5,
	IF THEN ELSE(MONTHS=APRIL,SNOW ACCUMULATION MONTHLY[APRIL]*0.7+(SNOW ACCUMULATION MONTHLY\
		[MARCH]+(SNOW ACCUMULATION MONTHLY[FEBRUARY]+(SNOW ACCUMULATION MONTHLY[JANUARY]+(SNOW ACCUMULATION MONTHLY\
		[DECEMBER]+(SNOW ACCUMULATION MONTHLY[NOVEMBER]+SNOW ACCUMULATION MONTHLY[OCTOBER]*\
		0.6)*0.6)*0.6)*0.6)*0.6)*0.7*0.4,0))))))),0)
	~	cm/Month
	~		|

SNOW VOLUME FOR SKIING=
	MINIMUM SKI DEPTH*SKI SLOPE AREA
	~	m3
	~		|

BUILDING AREA=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'ENERGY', 'BUILDING_AREA*')
	~	km2
	~		|

MAX BIOMASS INCREASE PER YEAR=
	((BOREAL BROADLEAVED SUMMERGREEN*BBS+BOREAL NEEDLELEAVED EVERGREEN*BNE+TEMPERATE BROADLEAVED EVERGREEN\
		*TBE+TEMPERATE BROADLEAVED SUMMERGREEN
	*TBS+TEMPERATE NEEDLELEAVED EVERGREEN*TNE)*FACTOR HA TO KM2*KG TO TONNES*BIOMASS ENERGY CONTENT\
		)/(BIOMASS PERFORMANCE*HOURS IN A YEAR)
	~	MW
	~	(((BIOMASS STOCK/FOREST)*BIOMASS ENERGY CONTENT)/(BIOMASS \
		PERFORMANCE*HOURS IN A YEAR))*(AVAILABLE FOREST LAND)
	|

WATER FLOW YEARLY TO SEA=
	RUNOFF TO RIVER FLOW-AVAILABLE WATER FROM RUNOFF YEARLY
	~	Hm3/Year
	~		|

EFFECTIVE SNOWMELT[MONTHS]=
	IF THEN ELSE(CUMULATIVE SNOWMELT CAPACITY[MONTHS] >= TOTAL SNOW ACCUMULATION CORRECTED\
		,0,
	IF THEN ELSE(CUMULATIVE SNOWMELT CAPACITY[MONTHS] < TOTAL SNOW ACCUMULATION CORRECTED\
		,SNOWMELT[MONTHS],
	IF THEN ELSE(CUMULATIVE SNOWMELT CAPACITY[MONTHS] + SNOWMELT[MONTHS] < TOTAL SNOW ACCUMULATION CORRECTED\
		,TOTAL SNOW ACCUMULATION CORRECTED 
	- CUMULATIVE SNOWMELT CAPACITY[MONTHS],0)))+SNOW OUTPUT[MONTHS]
	~	mm
	~		|

TOTAL SNOW ACCUMULATION CORRECTED=
	SNOW ACCUMULATION MONTHLY[JANUARY]+SNOW ACCUMULATION MONTHLY[FEBRUARY]+SNOW ACCUMULATION MONTHLY\
		[MARCH]+SNOW ACCUMULATION MONTHLY[APRIL]+SNOW ACCUMULATION MONTHLY[MAY]+SNOW ACCUMULATION MONTHLY\
		[JUNE]+SNOW ACCUMULATION MONTHLY[JULY]+SNOW ACCUMULATION MONTHLY[AUGUST]+SNOW ACCUMULATION MONTHLY\
		[SEPTEMBER]+SNOW ACCUMULATION MONTHLY PREVIOUS YEAR[OCTOBER]+SNOW ACCUMULATION MONTHLY PREVIOUS YEAR\
		[NOVEMBER]+SNOW ACCUMULATION MONTHLY PREVIOUS YEAR[DECEMBER]
	~	cm
	~		|

WATER SUPPLY=
	AVAILABLE WATER FROM RUNOFF YEARLY+GROUNDWATER INPUTS+DESALINATION+SUM(TRANSBOUNDARY WATER\
		[MONTHS!])+WATER TREATMENT-STORAGE OUTPUTS
	~	Hm3
	~		|

RUNOFF TO RIVER FLOW=
	SUM(AVAILABLE RUNOFF[MONTHS!])
	~	Hm3
	~		|

AVAILABLE WATER FROM RUNOFF YEARLY=
	IF THEN ELSE(TOTAL RESERVOIR CAPACITY=0, (SUM(AVAILABLE RUNOFF[MONTHS!]))*0.1 , IF THEN ELSE
	(TOTAL RESERVOIR CAPACITY>(SUM(AVAILABLE RUNOFF[MONTHS!])),SUM(AVAILABLE RUNOFF[MONTHS\
		!]),(TOTAL RESERVOIR CAPACITY*1.25)))
	~	Hm3/Year
	~		|

DIFFERENCE[MONTHS]=
	IF THEN ELSE(CUMULATIVE SNOWMELT CAPACITY[MONTHS]-TOTAL SNOW ACCUMULATION CORRECTED>\
		0, 0, (-1*(CUMULATIVE SNOWMELT CAPACITY[MONTHS
	]-TOTAL SNOW ACCUMULATION CORRECTED)))
	~	mm
	~		|

SNOW ACCUMULATION MONTHLY PREVIOUS YEAR[MONTHS]=
	DELAY FIXED( SNOW ACCUMULATION MONTHLY[MONTHS] , 1 , 0 )
	~	cm/Month
	~		|

SNOW VALIDATION[MONTHS]=
	IF THEN ELSE (DIFFERENCE[MONTHS]>=0.8*TOTAL SNOW ACCUMULATION CORRECTED, 0, DIFFERENCE\
		[MONTHS])
	~	mm
	~		|

SWITCH SUSTAINABLE SNOWMAKING AND CONSERVATION PRACTICES=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', 'SWITCH_SUSTAINABLE_SNOWMAKING_AND_CONSERVATION_PRACTICES*'\
		)
	~	Dmnl
	~	0 = OFF
		1 = ON
		GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', \
		'SWITCH_SUSTAINABLE_SNOWMAKING_AND_CONSERVATION_PRACTICES*')
	|

INITIAL YEAR SUSTAINABLE SNOWMAKING AND CONSERVATION PRACTICES=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', 'INITIAL_YEAR_SUSTAINABLE_SNOWMAKING_AND_CONSERVATION_PRACTICES*'\
		)
	~	Year
	~		|

SUSTAINABLE SNOWMAKING AND CONSERVATION PRACTICES OBJECTIVE=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', 'SUSTAINABLE_SNOWMAKING_AND_CONSERVATION_PRACTICES_OBJECTIVE*'\
		)
	~	Dmnl
	~	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', \
		'SUSTAINABLE_SNOWMAKING_AND_CONSERVATION_PRACTICES_OBJECTIVE*')
	|

FINAL YEAR SUSTAINABLE SNOWMAKING AND CONSERVATION PRACTICES=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', 'FINAL_YEAR_SUSTAINABLE_SNOWMAKING_AND_CONSERVATION_PRACTICES*'\
		)
	~	Year
	~		|

INITIAL RATIO ENERGY PER SNOW PRODUCTION=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', 'INITIAL_RATIO_ENERGY_PER_SNOW_PRODUCTION*'\
		)
	~	MWh/m3
	~		|

SKI SLOPE AREA=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', 'SKI_SLOPE_AREA*')
	~	m2
	~		|

MINIMUM SKI DEPTH=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', 'MINIMUM_SKI_DEPTH*')
	~	m
	~		|

MAX HYDRO CAPACITY=
	IF THEN ELSE(HOURS OF HYDRO PRODUCTION PER YEAR<=0,0,MAX POTENTIAL HYDRO/(HOURS OF HYDRO PRODUCTION PER YEAR\
		*HYDRO PERFORMANCE))
	~	MW
	~		|

WIND PRODUCTION=
	WIND CAPACITY*WIND PERFORMANCE*HOURS IN A YEAR
	~	MWh
	~		|

NON RENEWABLE PRODUCTION=
	NON RENEWABLE PERFORMANCE*NON RENEWABLE CAPACITY*HOURS IN A YEAR
	~	MWh
	~		|

MAX POTENTIAL ROOFTOP=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'ENERGY', 'MAX_POTENTIAL_ROOFTOP*')
	~	MW/km2
	~		|

ROOFTOP PRODUCTION=
	ROOFTOP CAPACITY*ROOFTOP PERFORMANCE*HOURS IN A YEAR
	~	MWh
	~		|

MAX WIND CAPACITY=
	MAX POTENTIAL WIND
	~	MW
	~		|

BIOMASS PRODUCTION=
	BIOMASS CAPACITY*BIOMASS PERFORMANCE*HOURS IN A YEAR
	~	MWh
	~		|

REAL UNEMPLOYED=
	SMOOTH(IF THEN ELSE(UNEMPLOYED<(0.01*CS POPULATION),0.01*CS POPULATION,UNEMPLOYED),2\
		)
	~	Inhabitants
	~		|

UNEMPLOYMENT RATE=
	REAL UNEMPLOYED/CS POPULATION
	~	Dmnl
	~		|

NEW NON RENEWABLE CAPACITY=
	IF THEN ELSE(SWITCH INCREASE NON RENEWABLE CAPACITY=0,0,IF THEN ELSE(SWITCH INCREASE NON RENEWABLE CAPACITY\
		=1:AND:Time>
	FINAL YEAR INCREASE NON RENEWABLE CAPACITY,0,INCREASE NON RENEWABLE CAPACITY OBJECTIVE
	/(FINAL YEAR INCREASE NON RENEWABLE CAPACITY-INITIAL TIME)))
	~	MW
	~		|

RATIO IRRIGATED CROP AREA=
	MIN(RATIO IRRIGATED CROP AREA NOT NORMALIZED,1)
	~	Dmnl
	~		|

RATIO IRRIGATED CROP AREA NOT NORMALIZED= INTEG (
	INCREASE RATIO IRRIGATED CROP NEW,
		INITIAL RATIO IRRIGATED CROP AREA)
	~	Dmnl
	~		|

RATIO RAINFED CROP AREA=
	1-RATIO IRRIGATED CROP AREA
	~	Dmnl
	~		|

SWITCH INCREASE IRRIGATED CROP=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Crop system', 'SWITCH_INCREASE_IRRIGATED_CROP*'\
		)
	~	Dmnl
	~	OFF=0
		ON=1
	|

SWITCH INCREASE NON RENEWABLE CAPACITY=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'ENERGY', 'SWITCH_INCREASE_NON_RENEWABLE_CAPACITY*'\
		)
	~	Dmnl
	~	OFF=0
		ON=1
		GET DIRECT CONSTANTS ('Policy.xlsx', 'ENERGY', \
		'SWITCH_INCREASE_NON_RENEWABLE_CAPACITY*')
	|

INITIAL YEAR INCREASE IRRIGATED CROP=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Crop system', 'INITIAL_YEAR_INCREASE_IRRIGATED_CROP*'\
		)
	~	Year
	~		|

INCREASE IRRIGATED CROP OBJECTIVE=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Crop system', 'INCREASE_IRRIGATED_CROP_OBJECTIVE*'\
		)
	~	Dmnl
	~	GET DIRECT CONSTANTS ('Policy.xlsx', 'Crop system', \
		'INCREASE_IRRIGATED_CROP_OBJECTIVE*')
	|

FINAL YEAR INCREASE IRRIGATED CROP=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Crop system', 'FINAL_YEAR_INCREASE_IRRIGATED_CROP*'\
		)
	~	Year
	~		|

FINAL YEAR INCREASE NON RENEWABLE CAPACITY=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'ENERGY', 'FINAL_YEAR_INCREASE_NON_RENEWABLE_CAPACITY*'\
		)
	~	Year
	~		|

AGRICULTURE TO WATER=
	IF THEN ELSE (SELECT LOCATION WATER STORAGE=3,WATER AREA,0)
	~	km2
	~		|

FOREST TO WATER=
	IF THEN ELSE (SELECT LOCATION WATER STORAGE=4,WATER AREA,0)
	~	km2
	~		|

WATER TREATMENT=
	IF THEN ELSE (SWITCH WATER TREATMENT INCREASE=0,INITIAL WATER TREATMENT,IF THEN ELSE\
		(SWITCH WATER TREATMENT INCREASE=1:AND:
	Time<=INITIAL YEAR WATER TREATMENT INCREASE,INITIAL WATER TREATMENT,IF THEN ELSE(SWITCH WATER TREATMENT INCREASE\
		=1:AND:
	Time>FINAL YEAR WATER TREATMENT INCREASE,INITIAL WATER TREATMENT+(WATER TREATMENT INCREASE OBJECTIVE\
		),INITIAL WATER TREATMENT
	+(WATER TREATMENT INCREASE OBJECTIVE*((Time-INITIAL YEAR WATER TREATMENT INCREASE)/(\
		FINAL YEAR WATER TREATMENT INCREASE
	-INITIAL YEAR WATER TREATMENT INCREASE))))))
	~	Hm3
	~		|

DESALINATION=
	IF THEN ELSE((SWITCH CS=2),0,IF THEN ELSE(SWITCH DESALINATION INCREASE POLICY=0,INITIAL DESALINATION\
		,IF THEN ELSE(SWITCH DESALINATION INCREASE POLICY
	=1:AND:(Time<INITIAL YEAR DESALINATION INCREASE),INITIAL DESALINATION,IF THEN ELSE(SWITCH DESALINATION INCREASE POLICY
	=1:AND:(Time>FINAL YEAR DESALINATION INCREASE),INITIAL DESALINATION+(DESALINATION OBJECTIVE\
		),INITIAL DESALINATION
	+(DESALINATION OBJECTIVE*((Time-INITIAL YEAR DESALINATION INCREASE)/(FINAL YEAR DESALINATION INCREASE
	-INITIAL YEAR DESALINATION INCREASE)))))))
	~	Hm3
	~		|

ENERGY CONSUMPTION WATER TREATMENT URBAN=
	ENERGY CONSUMPTION WATER TREATMENT*RATIO WATER DEMAND URBAN
	~	MWh
	~		|

ENERGY CONSUMPTION WATER TREATMENT AGRICULTURE=
	ENERGY CONSUMPTION WATER TREATMENT*RATIO WATER DEMAND AGRICULTURE
	~	MWh
	~		|

ENERGY CONSUMPTION DESALINATION=
	DESALINATION*MWH PER HM3 DESALINATED WATER
	~	MWh
	~		|

ENERGY CONSUMPTION DESALINATION URBAN=
	ENERGY CONSUMPTION DESALINATION*RATIO WATER DEMAND URBAN
	~	MWh
	~		|

ENERGY CONSUMPTION WATER TREATMENT INDUSTRY=
	ENERGY CONSUMPTION WATER TREATMENT*RATIO WATER DEMAND INDUSTRY
	~	MWh
	~		|

ENERGY CONSUMPTION DESALINATION INDUSTRY=
	ENERGY CONSUMPTION DESALINATION*RATIO WATER DEMAND INDUSTRY
	~	MWh
	~		|

ENERGY CONSUMPTION DESALINATION AGRICULTURE=
	ENERGY CONSUMPTION DESALINATION*RATIO WATER DEMAND AGRICULTURE
	~	MWh
	~		|

HYDRO PRODUCTION=
	HYDROPOWER CAPACITY*HYDRO PERFORMANCE*HOURS OF HYDRO PRODUCTION PER YEAR
	~	MWh
	~		|

TOTAL FLOW[MONTHS]=
	IF THEN ELSE(SWITCH CS=4,MONTH TO HOURS[MONTHS]*AVAILABLE RUNOFF[MONTHS]+(1e+06)*TRANSBOUNDARY WATER\
		[MONTHS]/(MONTH TO HOURS[MONTHS]*60*60), MONTH TO HOURS[MONTHS]*AVAILABLE RUNOFF[MONTHS\
		])
	~	m3/s
	~	IF THEN ELSE(SWITCH CS=4,MONTH TO HOURS[MONTHS]*RIVER \
		FLOW[MONTHS]+(1e+06)*TRANSBOUNDARY WATER[MONTHS]/(MONTH TO \
		HOURS[MONTHS]*60*60), MONTH TO HOURS[MONTHS]*RIVER FLOW[MONTHS])
	|

MONTH TO HOURS[MONTHS]=
	MONTH DAYS[MONTHS]*24
	~	Hours
	~		|

HOURS OF HYDRO PRODUCTION PER YEAR=
	SUM(HOURS OF PRODUCTION[MONTHS!])
	~	Hours
	~		|

HOURS OF PRODUCTION[MONTHS]=
	IF THEN ELSE(TOTAL FLOW[MONTHS]<2, 0, MONTH TO HOURS[MONTHS])
	~	Hours
	~		|

RATIO WATER DEMAND INDUSTRY=
	WATER DEMAND FROM INDUSTRY/WATER DEMAND
	~	Dmnl
	~		|

RATIO WATER DEMAND URBAN=
	WATER DEMAND FROM URBAN/WATER DEMAND
	~	Dmnl
	~		|

RATIO WATER DEMAND AGRICULTURE=
	WATER DEMAND FROM AGRICULTURE/WATER DEMAND
	~	Dmnl
	~		|

TOTAL SNOW ACCUMULATION=
	SUM(SNOW ACCUMULATION MONTHLY[MONTHS!])
	~	cm
	~		|

FINAL YEAR PROMOTE DOMESTIC TOURISM=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Tourism system', 'FINAL_YEAR_PROMOTE_DOMESTIC_TOURISM*'\
		)
	~	Year
	~		|

ENERGY CONSUMPTION WATER TREATMENT=
	MWH PER HM3 TREATED WATER*WATER TREATMENT
	~	MWh
	~		|

MWH PER HM3 DESALINATED WATER=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Energy', 'MWH_PER_HM3_DESALINATED_WATER*')
	~	MWh/Hm3
	~		|

DAYS INTERNATIONAL VISITORS=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', 'DAYS_INTERNATIONAL_VISITORS*'\
		)
	~	Days
	~		|

ADAPTIVE CAPACITY=
	(INVESTMENT IN TOURISM ADAPTATION AND RESILIENCE+PROMOTE ALL YEAR TOURISM+PROMOTE DOMESTIC TOURISM\
		)/3
	~	Dmnl
	~		|

DAYS NATIONAL VISITORS=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', 'DAYS_NATIONAL_VISITORS*')
	~	Days
	~		|

INITIAL WATER TREATMENT=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', 'INITIAL_WATER_TREATMENT*')
	~	Hm3
	~		|

WATER DEMAND FROM URBAN=
	IF THEN ELSE(SWITCH EFFICIENT WATER DEMAND FROM URBAN=0,WATER DEMAND FROM URBAN PER CAPITA\
		*(CS POPULATION+SUM(NATIONAL VISITORS[SEASONS!])*(DAYS NATIONAL VISITORS/365)+SUM(INTERNATIONAL VISITORS\
		[SEASONS!])*(DAYS INTERNATIONAL VISITORS/365)
	),IF THEN ELSE
	(SWITCH EFFICIENT WATER DEMAND FROM URBAN
	=1:AND:(Time<INITIAL YEAR EFFICIENT WATER DEMAND FROM URBAN),WATER DEMAND FROM URBAN PER CAPITA\
		*(CS POPULATION+SUM(NATIONAL VISITORS[SEASONS!])*(DAYS NATIONAL VISITORS/365)+SUM(INTERNATIONAL VISITORS\
		[SEASONS!])*(DAYS INTERNATIONAL VISITORS/365)
	),IF THEN ELSE
	(SWITCH EFFICIENT WATER DEMAND FROM URBAN
	=1:AND:(Time>FINAL YEAR EFFICIENT WATER DEMAND FROM URBAN),((CS POPULATION+SUM(NATIONAL VISITORS\
		[SEASONS!])*(DAYS NATIONAL VISITORS/365)+SUM(INTERNATIONAL VISITORS[SEASONS!])*(DAYS INTERNATIONAL VISITORS\
		/365)
	)*WATER DEMAND FROM URBAN PER CAPITA)*(1-EFFICIENT WATER DEMAND FROM URBAN OBJECTIVE
	),((CS POPULATION+SUM(NATIONAL VISITORS[SEASONS!])*(DAYS NATIONAL VISITORS/365)+SUM(\
		INTERNATIONAL VISITORS[SEASONS!])*(DAYS INTERNATIONAL VISITORS/365))*WATER DEMAND FROM URBAN PER CAPITA\
		)*(1-(EFFICIENT WATER DEMAND FROM URBAN OBJECTIVE
	*((Time-INITIAL YEAR EFFICIENT WATER DEMAND FROM URBAN
	)/(FINAL YEAR EFFICIENT WATER DEMAND FROM URBAN-INITIAL YEAR EFFICIENT WATER DEMAND FROM URBAN\
		)))))))
	~	Hm3
	~		|

SWITCH PROMOTE DOMESTIC TOURISM=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Tourism system', 'SWITCH_PROMOTE_DOMESTIC_TOURISM*'\
		)
	~	Dmnl
	~	0=OFF
		1=ON
	|

FINAL YEAR WATER TREATMENT INCREASE=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', 'FINAL_YEAR_WATER_TREATMENT_INCREASE*'\
		)
	~	Year
	~		|

INITIAL YEAR WATER TREATMENT INCREASE=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', 'INITIAL_YEAR_WATER_TREATMENT_INCREASE*'\
		)
	~	Year
	~		|

EFFECTIVE PRECIPITATION[MONTHS]=
	IF THEN ELSE( TEMPERATURE[MONTHS]<0 , 0, PRECIPITATION[MONTHS] )+EFFECTIVE SNOWMELT[\
		MONTHS]
	~	mm
	~		|

SWITCH WATER TREATMENT INCREASE=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', 'SWITCH_WATER_TREATMENT_INCREASE*'\
		)
	~	Dmnl
	~		|

WATER TREATMENT INCREASE OBJECTIVE=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', 'WATER_TREATMENT_INCREASE_OBJECTIVE*'\
		)
	~	Hm3
	~		|

INITIAL NATIONAL VISITORS AUTUMN=
	IF THEN ELSE(SWITCH PROMOTE DOMESTIC TOURISM=0,ALFA AUTUMN*MEAN TCI AUTUMN+BETA AUTUMN\
		,IF THEN ELSE(SWITCH PROMOTE DOMESTIC TOURISM=1:AND:Time<INITIAL YEAR PROMOTE DOMESTIC TOURISM\
		,ALFA AUTUMN*MEAN TCI AUTUMN+BETA AUTUMN,IF THEN ELSE(SWITCH PROMOTE DOMESTIC TOURISM\
		=1:AND:Time>FINAL YEAR PROMOTE DOMESTIC TOURISM,(ALFA AUTUMN*MEAN TCI AUTUMN+BETA AUTUMN\
		)*(1+PROMOTE DOMESTIC TOURISM OBJECTIVE[AUTUMN]),(ALFA AUTUMN*MEAN TCI AUTUMN+BETA AUTUMN\
		)*(1+PROMOTE DOMESTIC TOURISM OBJECTIVE[AUTUMN]*((Time-INITIAL YEAR PROMOTE DOMESTIC TOURISM\
		)/(FINAL YEAR PROMOTE DOMESTIC TOURISM-INITIAL YEAR PROMOTE DOMESTIC TOURISM))))))
	~	Tourists
	~		|

INITIAL NATIONAL VISITORS SPRING=
	IF THEN ELSE(SWITCH PROMOTE DOMESTIC TOURISM=0,ALFA SPRING*MEAN TCI SPRING+BETA SPRING\
		,IF THEN ELSE(SWITCH PROMOTE DOMESTIC TOURISM=1:AND:Time<INITIAL YEAR PROMOTE DOMESTIC TOURISM\
		,ALFA SPRING*MEAN TCI SPRING+BETA SPRING,IF THEN ELSE(SWITCH PROMOTE DOMESTIC TOURISM\
		=1:AND:Time>FINAL YEAR PROMOTE DOMESTIC TOURISM,(ALFA SPRING*MEAN TCI SPRING+BETA SPRING\
		)*(1+PROMOTE DOMESTIC TOURISM OBJECTIVE[SPRING]),(ALFA SPRING*MEAN TCI SPRING+BETA SPRING\
		)*(1+PROMOTE DOMESTIC TOURISM OBJECTIVE[SPRING]*((Time-INITIAL YEAR PROMOTE DOMESTIC TOURISM\
		)/(FINAL YEAR PROMOTE DOMESTIC TOURISM-INITIAL YEAR PROMOTE DOMESTIC TOURISM))))))
	~	Tourists
	~		|

INITIAL NATIONAL VISITORS SUMMER=
	IF THEN ELSE(SWITCH PROMOTE DOMESTIC TOURISM=0,ALFA SUMMER*MEAN TCI SUMMER+BETA SUMMER\
		,IF THEN ELSE(SWITCH PROMOTE DOMESTIC TOURISM=1:AND:Time<INITIAL YEAR PROMOTE DOMESTIC TOURISM\
		,ALFA SUMMER*MEAN TCI SUMMER+BETA SUMMER,IF THEN ELSE(SWITCH PROMOTE DOMESTIC TOURISM\
		=1:AND:Time>FINAL YEAR PROMOTE DOMESTIC TOURISM,(ALFA SUMMER*MEAN TCI SUMMER+BETA SUMMER\
		)*(1+PROMOTE DOMESTIC TOURISM OBJECTIVE[SUMMER]),(ALFA SUMMER*MEAN TCI SUMMER+BETA SUMMER\
		)*(1+PROMOTE DOMESTIC TOURISM OBJECTIVE[SUMMER]*((Time-INITIAL YEAR PROMOTE DOMESTIC TOURISM\
		)/(FINAL YEAR PROMOTE DOMESTIC TOURISM-INITIAL YEAR PROMOTE DOMESTIC TOURISM))))))
	~	Tourists
	~		|

REQUEST FROM GROUNDWATER EXTRACTION=
	IF THEN ELSE((WATER DEMAND-STORAGE OUTPUTS-DESALINATION-SUM(TRANSBOUNDARY WATER[MONTHS\
		!])-WATER TREATMENT)<0,0,(WATER DEMAND-STORAGE OUTPUTS-DESALINATION-SUM(TRANSBOUNDARY WATER\
		[MONTHS!])-WATER TREATMENT))
	~	Hm3
	~	WATER DEMAND-STORAGE OUTPUTS-DESALINATION-SUM(TRANSBOUNDARY \
		WATER[MONTHS!])-WATER TREATMENT
	|

MWH PER HM3 TREATED WATER=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Energy', 'MWH_PER_HM3_TREATED_WATER*')
	~	MWh/Hm3
	~		|

INITIAL YEAR PROMOTE DOMESTIC TOURISM=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Tourism system', 'INITIAL_YEAR_PROMOTE_DOMESTIC_TOURISM*'\
		)
	~	Year
	~		|

PROMOTE DOMESTIC TOURISM OBJECTIVE[SEASONS]=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Tourism system', 'PROMOTE_DOMESTIC_TOURISM_OBJECTIVE*'\
		)
	~	Dmnl
	~		|

PROMOTE DOMESTIC TOURISM=
	MIN(1,SUM(NATIONAL VISITORS[SEASONS!])/TOTAL VISITORS)
	~	Dmnl
	~		|

DIRECT RUNOFF[MONTHS]=
	IF THEN ELSE(
	EFFECTIVE PRECIPITATION[MONTHS] > PET[MONTHS] :AND: (PREVIOUS MOISTURE[MONTHS] + EFFECTIVE PRECIPITATION\
		[MONTHS] - PET[MONTHS]) > 150,
	(PREVIOUS MOISTURE[MONTHS] + EFFECTIVE PRECIPITATION[MONTHS] - PET[MONTHS]) - 150,0)
	~	mm
	~	IF THEN ELSE( EFFECTIVE PRECIPITATION[MONTHS]>=PET[MONTHS] , EFFECTIVE \
		PRECIPITATION[MONTHS]-PET[MONTHS]-MOISTURE CHANGE
		[MONTHS] , 0 )
	|

SNOW ACCUMULATION MONTHLY[MONTHS]=
	IF THEN ELSE( TEMPERATURE[MONTHS]<0, PRECIPITATION[MONTHS] , 0 )
	~	cm/Month
	~		|

CUMULATIVE SNOWMELT CAPACITY[MONTHS]=
	IF THEN ELSE( MONTHS = FEBRUARY , SNOWMELT[FEBRUARY] , 
	IF THEN ELSE( MONTHS = MARCH , SNOWMELT[FEBRUARY]+SNOWMELT[MARCH],
	IF THEN ELSE( MONTHS = APRIL , SNOWMELT[FEBRUARY]+SNOWMELT[MARCH]+SNOWMELT[APRIL] ,
	IF THEN ELSE( MONTHS = MAY , SNOWMELT[FEBRUARY]+SNOWMELT[MARCH]+SNOWMELT[APRIL]+SNOWMELT\
		[MAY],
	IF THEN ELSE( MONTHS = JUNE , SNOWMELT[FEBRUARY]+SNOWMELT[MARCH]+SNOWMELT[APRIL]+SNOWMELT\
		[MAY]+SNOWMELT[JUNE] ,
	IF THEN ELSE( MONTHS = JULY , SNOWMELT[FEBRUARY]+SNOWMELT[MARCH]+SNOWMELT[APRIL]+SNOWMELT\
		[MAY]+SNOWMELT[JUNE]+SNOWMELT[JULY]  ,
	IF THEN ELSE( MONTHS = AUGUST , SNOWMELT[FEBRUARY]+SNOWMELT[MARCH]+SNOWMELT[APRIL]+SNOWMELT\
		[MAY]+SNOWMELT[JUNE]+SNOWMELT[JULY]+SNOWMELT[AUGUST] ,
	IF THEN ELSE( MONTHS = SEPTEMBER , SNOWMELT[FEBRUARY]+SNOWMELT[MARCH]+SNOWMELT[APRIL\
		]+SNOWMELT[MAY]+SNOWMELT[JUNE]+SNOWMELT[JULY]+SNOWMELT[AUGUST]+SNOWMELT[SEPTEMBER],
	IF THEN ELSE( MONTHS = OCTOBER , SNOWMELT[FEBRUARY]+SNOWMELT[MARCH]+SNOWMELT[APRIL]+\
		SNOWMELT[MAY]+SNOWMELT[JUNE]+SNOWMELT[JULY]+SNOWMELT[AUGUST]+SNOWMELT[SEPTEMBER]+SNOWMELT\
		[OCTOBER] ,
	IF THEN ELSE( MONTHS = NOVEMBER , SNOWMELT[FEBRUARY]+SNOWMELT[MARCH]+SNOWMELT[APRIL]\
		+SNOWMELT[MAY]+SNOWMELT[JUNE]+SNOWMELT[JULY]+SNOWMELT[AUGUST]+SNOWMELT[SEPTEMBER]+SNOWMELT\
		[OCTOBER]+SNOWMELT[NOVEMBER] ,
	IF THEN ELSE( MONTHS = DECEMBER , SNOWMELT[FEBRUARY]+SNOWMELT[MARCH]+SNOWMELT[APRIL]\
		+SNOWMELT[MAY]+SNOWMELT[JUNE]+SNOWMELT[JULY]+SNOWMELT[AUGUST]+SNOWMELT[SEPTEMBER]+SNOWMELT\
		[OCTOBER]+SNOWMELT[NOVEMBER]+SNOWMELT[DECEMBER] ,
	IF THEN ELSE( MONTHS = JANUARY , SNOWMELT[FEBRUARY]+SNOWMELT[MARCH]+SNOWMELT[APRIL]+\
		SNOWMELT[MAY]+SNOWMELT[JUNE]+SNOWMELT[JULY]+SNOWMELT[AUGUST]+SNOWMELT[SEPTEMBER]+SNOWMELT\
		[OCTOBER]+SNOWMELT[NOVEMBER]+SNOWMELT[DECEMBER]+SNOWMELT[JANUARY],
	0))))))))))))
	~	mm
	~		|

SNOWMELT[MONTHS]=
	IF THEN ELSE( TEMPERATURE[MONTHS]>0, (SNOWMELTING FACTOR*TEMPERATURE[MONTHS]*MONTH DAYS\
		[MONTHS]) , 0 )
	~	mm
	~		|

AET[MONTHS]=
	IF THEN ELSE(EFFECTIVE PRECIPITATION[MONTHS] >= PET[MONTHS],PET[MONTHS],
	EFFECTIVE PRECIPITATION[MONTHS] + MIN(PREVIOUS MOISTURE[MONTHS], PET[MONTHS] - EFFECTIVE PRECIPITATION\
		[MONTHS]))
	~	mm
	~		|

SOIL MOISTURE[MONTHS]=
	INITIAL SOIL MOISTURE[MONTHS]+EFFECTIVE PRECIPITATION[MONTHS]-PET[MONTHS]
	~	mm/Month
	~		|

SOIL MOISTURE REAL[MONTHS]=
	IF THEN ELSE(EFFECTIVE PRECIPITATION[MONTHS] >= PET[MONTHS],
	MIN(PREVIOUS MOISTURE[MONTHS] + EFFECTIVE PRECIPITATION[MONTHS] - PET[MONTHS], SOIL WATER CAPACITY\
		),
	MAX(PREVIOUS MOISTURE[MONTHS] - (PET[MONTHS] - EFFECTIVE PRECIPITATION[MONTHS]), 0))
	~	mm/Month
	~		|

INFILTRATION[MONTHS]=
	(IF THEN ELSE( SOIL MOISTURE REAL[MONTHS]>=SOIL WATER CAPACITY , PERCOLATION COEFFICIENT\
		*(SOIL MOISTURE REAL[MONTHS]) , 0 )*TOTAL CS AREA*MM PER KM2 TO M3)/M3 TO HM3
	~	Hm3
	~		|

SNOW OUTPUT[MONTHS]=
	IF THEN ELSE( MONTHS = JANUARY , SNOW VALIDATION[DECEMBER],
	IF THEN ELSE( MONTHS = FEBRUARY , SNOW VALIDATION[JANUARY],
	IF THEN ELSE( MONTHS = MARCH , SNOW VALIDATION[FEBRUARY],
	IF THEN ELSE( MONTHS = APRIL , SNOW VALIDATION[MARCH],
	IF THEN ELSE( MONTHS = MAY , SNOW VALIDATION[APRIL],
	IF THEN ELSE( MONTHS = JUNE , SNOW VALIDATION[MAY],
	IF THEN ELSE( MONTHS = JULY , SNOW VALIDATION[JUNE],
	IF THEN ELSE( MONTHS = AUGUST , SNOW VALIDATION[JULY],
	IF THEN ELSE( MONTHS = SEPTEMBER , SNOW VALIDATION[AUGUST],
	IF THEN ELSE( MONTHS = OCTOBER , SNOW VALIDATION[SEPTEMBER],
	IF THEN ELSE( MONTHS = NOVEMBER , SNOW VALIDATION[OCTOBER],
	IF THEN ELSE( MONTHS = DECEMBER , SNOW VALIDATION[NOVEMBER],
	0))))))))))))
	~	mm
	~		|

PREVIOUS MOISTURE[MONTHS]=
	IF THEN ELSE( MONTHS = JANUARY , SOIL MOISTURE[DECEMBER],
	IF THEN ELSE( MONTHS = FEBRUARY , SOIL MOISTURE[JANUARY],
	IF THEN ELSE( MONTHS = MARCH , SOIL MOISTURE[FEBRUARY],
	IF THEN ELSE( MONTHS = APRIL , SOIL MOISTURE[MARCH],
	IF THEN ELSE( MONTHS = MAY , SOIL MOISTURE[APRIL],
	IF THEN ELSE( MONTHS = JUNE , SOIL MOISTURE[MAY],
	IF THEN ELSE( MONTHS = JULY , SOIL MOISTURE[JUNE],
	IF THEN ELSE( MONTHS = AUGUST , SOIL MOISTURE[JULY],
	IF THEN ELSE( MONTHS = SEPTEMBER , SOIL MOISTURE[AUGUST],
	IF THEN ELSE( MONTHS = OCTOBER , SOIL MOISTURE[SEPTEMBER],
	IF THEN ELSE( MONTHS = NOVEMBER , SOIL MOISTURE[OCTOBER],
	IF THEN ELSE( MONTHS = DECEMBER , SOIL MOISTURE[NOVEMBER],
	0))))))))))))
	~	mm/Month
	~		|

PERCOLATION RUNOFF[MONTHS]=
	IF THEN ELSE( SOIL MOISTURE REAL[MONTHS]>=SOIL WATER CAPACITY , PERCOLATION COEFFICIENT\
		*(SOIL MOISTURE REAL[MONTHS]) , 0 )*0.1
	~	mm
	~		|

INITIAL SOIL MOISTURE[MONTHS]=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', 'INITIAL_SOIL_MOISTURE*')
	~	mm/Month
	~		|

TOTAL INTERNATIONAL VISITORS=
	SUM(INTERNATIONAL VISITORS[SEASONS!])
	~	Tourists
	~		|

TOTAL NATIONAL VISITORS=
	SUM(NATIONAL VISITORS[SEASONS!])
	~	Tourists
	~		|

DEVIATION TOURISTS[SEASONS]=
	ABS(((INTERNATIONAL VISITORS[SEASONS]+NATIONAL VISITORS[SEASONS])/TOTAL VISITORS)-1/\
		4)
	~	Dmnl
	~		|

TOTAL VISITORS=
	SUM(NATIONAL VISITORS[SEASONS!])+SUM(INTERNATIONAL VISITORS[SEASONS!])
	~	Tourists
	~		|

INTERNATIONAL VISITORS[SEASONS]=
	IF THEN ELSE(SEASONS=SPRING,INTERNATIONAL VISITORS SPRING,IF THEN ELSE(SEASONS=SUMMER\
		,INTERNATIONAL VISITORS SUMMER,IF THEN ELSE(SEASONS=AUTUMN,INTERNATIONAL VISITORS AUTUMN\
		,INTERNATIONAL VISITORS WINTER)))
	~	Tourists
	~		|

NATIONAL VISITORS[SEASONS]=
	IF THEN ELSE(SEASONS=SPRING,NATIONAL VISITORS SPRING,IF THEN ELSE(SEASONS=SUMMER,NATIONAL VISITORS SUMMER\
		,IF THEN ELSE(SEASONS=AUTUMN,NATIONAL VISITORS AUTUMN,NATIONAL VISITORS WINTER)))
	~	Tourists
	~		|

BETA AUTUMN=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Tourism system', 'BETA_AUTUMN*')
	~	Dmnl
	~		|

TOURISM INCOME=
	IF THEN ELSE(RISK INDEX TOURISM> 0.7, 0.02*(TOTAL INTERNATIONAL VISITORS *(INTERNATIONAL EXPENDITURE\
		*(
	1*AVERAGE EXPENDITURE INCREASE)))+(TOTAL NATIONAL VISITORS*(NATIONAL EXPENDITURE*(1+\
		AVERAGE EXPENDITURE INCREASE
	))), 
	IF THEN ELSE(RISK INDEX TOURISM < 0.1, 0.1*(TOTAL INTERNATIONAL VISITORS *(INTERNATIONAL EXPENDITURE
	*(1*AVERAGE EXPENDITURE INCREASE)))+(TOTAL NATIONAL VISITORS*(NATIONAL EXPENDITURE*(\
		1+AVERAGE EXPENDITURE INCREASE
	))), 
	0.05*(TOTAL INTERNATIONAL VISITORS *(INTERNATIONAL EXPENDITURE*(1*AVERAGE EXPENDITURE INCREASE\
		)))+(TOTAL NATIONAL VISITORS
	*(NATIONAL EXPENDITURE*(1+AVERAGE EXPENDITURE INCREASE)))))
	~	Euros
	~		|

SEASONS:
	SPRING, SUMMER, AUTUMN, WINTER
	~	Season
	~		|

ALFA 1 AUTUMN=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Tourism system', 'ALFA_1_AUTUMN*')
	~	Dmnl
	~		|

ALFA 1 SPRING=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Tourism system', 'ALFA_1_SPRING*')
	~	Dmnl
	~		|

NATIONAL VISITORS AUTUMN=
	IF THEN ELSE(SWITCH PROMOTE ALL YEAR TOURISM=0,INITIAL NATIONAL VISITORS[AUTUMN], 
	IF THEN ELSE(SWITCH PROMOTE ALL YEAR TOURISM=1:AND:Time<INITIAL YEAR PROMOTE ALL YEAR TOURISM\
		,INITIAL NATIONAL VISITORS[AUTUMN],
	IF THEN ELSE(SWITCH PROMOTE ALL YEAR TOURISM=1:AND:Time>FINAL YEAR PROMOTE ALL YEAR TOURISM\
		,INITIAL NATIONAL VISITORS[AUTUMN]*(1-PROMOTE ALL YEAR TOURISM OBJECTIVE)+(SUM(INITIAL NATIONAL VISITORS\
		[SEASONS!])/4)*PROMOTE ALL YEAR TOURISM OBJECTIVE,INITIAL NATIONAL VISITORS[AUTUMN]\
		*(1-(PROMOTE ALL YEAR TOURISM OBJECTIVE*((Time-INITIAL YEAR PROMOTE ALL YEAR TOURISM\
		)/(FINAL YEAR PROMOTE ALL YEAR TOURISM-INITIAL YEAR PROMOTE ALL YEAR TOURISM))))+(SUM\
		(INITIAL NATIONAL VISITORS[SEASONS!])/4)*PROMOTE ALL YEAR TOURISM OBJECTIVE*((Time-\
		INITIAL YEAR PROMOTE ALL YEAR TOURISM)/(FINAL YEAR PROMOTE ALL YEAR TOURISM-INITIAL YEAR PROMOTE ALL YEAR TOURISM\
		)))))
	~	Tourists
	~		|

NATIONAL VISITORS SPRING=
	IF THEN ELSE(SWITCH PROMOTE ALL YEAR TOURISM=0,INITIAL NATIONAL VISITORS[SPRING], 
	IF THEN ELSE(SWITCH PROMOTE ALL YEAR TOURISM=1:AND:Time<INITIAL YEAR PROMOTE ALL YEAR TOURISM\
		,INITIAL NATIONAL VISITORS[SPRING],
	IF THEN ELSE(SWITCH PROMOTE ALL YEAR TOURISM=1:AND:Time>FINAL YEAR PROMOTE ALL YEAR TOURISM\
		,INITIAL NATIONAL VISITORS[SPRING]*(1-PROMOTE ALL YEAR TOURISM OBJECTIVE)+(SUM(INITIAL NATIONAL VISITORS\
		[SEASONS!])/4)*PROMOTE ALL YEAR TOURISM OBJECTIVE,INITIAL NATIONAL VISITORS[SPRING]\
		*(1-(PROMOTE ALL YEAR TOURISM OBJECTIVE*((Time-INITIAL YEAR PROMOTE ALL YEAR TOURISM\
		)/(FINAL YEAR PROMOTE ALL YEAR TOURISM-INITIAL YEAR PROMOTE ALL YEAR TOURISM))))+(SUM\
		(INITIAL NATIONAL VISITORS[SEASONS!])/4)*PROMOTE ALL YEAR TOURISM OBJECTIVE*((Time-\
		INITIAL YEAR PROMOTE ALL YEAR TOURISM)/(FINAL YEAR PROMOTE ALL YEAR TOURISM-INITIAL YEAR PROMOTE ALL YEAR TOURISM\
		)))))
	~	Tourists
	~		|

NATIONAL VISITORS SUMMER=
	IF THEN ELSE(SWITCH PROMOTE ALL YEAR TOURISM=0,INITIAL NATIONAL VISITORS[SUMMER], 
	IF THEN ELSE(SWITCH PROMOTE ALL YEAR TOURISM=1:AND:Time<INITIAL YEAR PROMOTE ALL YEAR TOURISM\
		,INITIAL NATIONAL VISITORS[SUMMER],
	IF THEN ELSE(SWITCH PROMOTE ALL YEAR TOURISM=1:AND:Time>FINAL YEAR PROMOTE ALL YEAR TOURISM\
		,INITIAL NATIONAL VISITORS[SUMMER]*(1-PROMOTE ALL YEAR TOURISM OBJECTIVE)+(SUM(INITIAL NATIONAL VISITORS\
		[SEASONS!])/4)*PROMOTE ALL YEAR TOURISM OBJECTIVE,INITIAL NATIONAL VISITORS[SUMMER]\
		*(1-(PROMOTE ALL YEAR TOURISM OBJECTIVE*((Time-INITIAL YEAR PROMOTE ALL YEAR TOURISM\
		)/(FINAL YEAR PROMOTE ALL YEAR TOURISM-INITIAL YEAR PROMOTE ALL YEAR TOURISM))))+(SUM\
		(INITIAL NATIONAL VISITORS[SEASONS!])/4)*PROMOTE ALL YEAR TOURISM OBJECTIVE*((Time-\
		INITIAL YEAR PROMOTE ALL YEAR TOURISM)/(FINAL YEAR PROMOTE ALL YEAR TOURISM-INITIAL YEAR PROMOTE ALL YEAR TOURISM\
		)))))
	~	Tourists
	~		|

FINAL YEAR PROMOTE ALL YEAR TOURISM=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Tourism system', 'FINAL_YEAR_PROMOTE_ALL_YEAR_TOURISM*'\
		)
	~	Year
	~		|

BETA WINTER=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Tourism system', 'BETA_WINTER*')
	~	Dmnl
	~		|

ALFA AUTUMN=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Tourism system', 'ALFA_AUTUMN*')
	~	Dmnl
	~		|

INITIAL INTERNATIONAL VISITORS SPRING=
	ALFA 1 SPRING*MEAN TCI SPRING+BETA 1 SPRING
	~	Tourists
	~		|

INITIAL INTERNATIONAL VISITORS SUMMER=
	ALFA 1 SUMMER*MEAN TCI SUMMER+BETA 1 SUMMER
	~	Tourists
	~		|

INITIAL NATIONAL VISITORS[SEASONS]=
	IF THEN ELSE(SEASONS= SPRING,INITIAL NATIONAL VISITORS SPRING,IF THEN ELSE(SEASONS=SUMMER\
		, INITIAL NATIONAL VISITORS SUMMER,IF THEN ELSE(SEASONS=AUTUMN,INITIAL NATIONAL VISITORS AUTUMN\
		,INITIAL NATIONAL VISITORS WINTER)))
	~	Tourists
	~		|

PROMOTE ALL YEAR TOURISM=
	1-(SUM(DEVIATION TOURISTS[SEASONS!])/(2*(1-(1/4))))
	~	Dmnl
	~	1-((ABS(((INTERNATIONAL VISITORS AUTUMN+NATIONAL VISITORS AUTUMN)/TOTAL \
		VISITORS)-(1/4))+ABS(((INTERNATIONAL VISITORS SPRING
		+NATIONAL VISITORS SPRING
		)/TOTAL VISITORS)-(1/4))+ABS(((INTERNATIONAL VISITORS SUMMER+NATIONAL VISITORS \
		SUMMER)/TOTAL VISITORS)-(1/4))+ABS(((INTERNATIONAL VISITORS WINTER
		+NATIONAL VISITORS WINTER
		)/TOTAL VISITORS)-(1/4)))/(2*(1-(1/4))))
	|

ALFA SPRING=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Tourism system', 'ALFA_SPRING*')
	~	Dmnl
	~		|

ALFA SUMMER=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Tourism system', 'ALFA_SUMMER*')
	~	Dmnl
	~		|

ALFA WINTER=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Tourism system', 'ALFA_WINTER*')
	~	Dmnl
	~		|

INTERNATIONAL VISITORS AUTUMN=
	IF THEN ELSE(SWITCH PROMOTE ALL YEAR TOURISM=0,INITIAL INTERNATIONAL VISITORS[AUTUMN\
		], 
	IF THEN ELSE(SWITCH PROMOTE ALL YEAR TOURISM=1:AND:Time<INITIAL YEAR PROMOTE ALL YEAR TOURISM\
		,INITIAL INTERNATIONAL VISITORS[AUTUMN],
	IF THEN ELSE(SWITCH PROMOTE ALL YEAR TOURISM=1:AND:Time>FINAL YEAR PROMOTE ALL YEAR TOURISM\
		,INITIAL INTERNATIONAL VISITORS[AUTUMN]*(1-PROMOTE ALL YEAR TOURISM OBJECTIVE)+(SUM\
		(INITIAL INTERNATIONAL VISITORS[SEASONS!])/4)*PROMOTE ALL YEAR TOURISM OBJECTIVE,INITIAL INTERNATIONAL VISITORS\
		[AUTUMN]*(1-(PROMOTE ALL YEAR TOURISM OBJECTIVE*((Time-INITIAL YEAR PROMOTE ALL YEAR TOURISM\
		)/(FINAL YEAR PROMOTE ALL YEAR TOURISM-INITIAL YEAR PROMOTE ALL YEAR TOURISM))))+(SUM\
		(INITIAL INTERNATIONAL VISITORS[SEASONS!])/4)*PROMOTE ALL YEAR TOURISM OBJECTIVE*((\
		Time-INITIAL YEAR PROMOTE ALL YEAR TOURISM)/(FINAL YEAR PROMOTE ALL YEAR TOURISM-INITIAL YEAR PROMOTE ALL YEAR TOURISM\
		)))))
	~	Tourists
	~		|

INTERNATIONAL VISITORS SPRING=
	IF THEN ELSE(SWITCH PROMOTE ALL YEAR TOURISM=0,INITIAL INTERNATIONAL VISITORS[SPRING\
		], 
	IF THEN ELSE(SWITCH PROMOTE ALL YEAR TOURISM=1:AND:Time<INITIAL YEAR PROMOTE ALL YEAR TOURISM\
		,INITIAL INTERNATIONAL VISITORS[SPRING],
	IF THEN ELSE(SWITCH PROMOTE ALL YEAR TOURISM=1:AND:Time>FINAL YEAR PROMOTE ALL YEAR TOURISM\
		,INITIAL INTERNATIONAL VISITORS[SPRING]*(1-PROMOTE ALL YEAR TOURISM OBJECTIVE)+(SUM\
		(INITIAL INTERNATIONAL VISITORS[SEASONS!])/4)*PROMOTE ALL YEAR TOURISM OBJECTIVE,INITIAL INTERNATIONAL VISITORS\
		[SPRING]*(1-(PROMOTE ALL YEAR TOURISM OBJECTIVE*((Time-INITIAL YEAR PROMOTE ALL YEAR TOURISM\
		)/(FINAL YEAR PROMOTE ALL YEAR TOURISM-INITIAL YEAR PROMOTE ALL YEAR TOURISM))))+(SUM\
		(INITIAL INTERNATIONAL VISITORS[SEASONS!])/4)*PROMOTE ALL YEAR TOURISM OBJECTIVE*((\
		Time-INITIAL YEAR PROMOTE ALL YEAR TOURISM)/(FINAL YEAR PROMOTE ALL YEAR TOURISM-INITIAL YEAR PROMOTE ALL YEAR TOURISM\
		)))))
	~	Tourists
	~		|

ALFA 1 SUMMER=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Tourism system', 'ALFA_1_SUMMER*')
	~	Dmnl
	~		|

ALFA 1 WINTER=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Tourism system', 'ALFA_1_WINTER*')
	~	Dmnl
	~		|

BETA SPRING=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Tourism system', 'BETA_SPRING*')
	~	Dmnl
	~		|

PROMOTE ALL YEAR TOURISM OBJECTIVE=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Tourism system', 'PROMOTE_ALL_YEAR_TOURISM_OBJECTIVE*'\
		)
	~	Dmnl
	~		|

BETA SUMMER=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Tourism system', 'BETA_SUMMER*')
	~	Dmnl
	~		|

RISK INDEX TOURISM=
	IF THEN ELSE((TOURISM EXPOSURE AND PROBABILITIES*VULNERABILITY)<0,0,IF THEN ELSE((TOURISM EXPOSURE AND PROBABILITIES\
		*VULNERABILITY)>1,1,TOURISM EXPOSURE AND PROBABILITIES*VULNERABILITY))
	~	Dmnl
	~		|

BETA 1 AUTUMN=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Tourism system', 'BETA_1_AUTUMN*')
	~	Dmnl
	~		|

INITIAL YEAR PROMOTE ALL YEAR TOURISM=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Tourism system', 'INITIAL_YEAR_PROMOTE_ALL_YEAR_TOURISM*'\
		)
	~	Year
	~		|

BETA 1 SPRING=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Tourism system', 'BETA_1_SPRING*')
	~	Dmnl
	~		|

INTERNATIONAL VISITORS SUMMER=
	IF THEN ELSE(SWITCH PROMOTE ALL YEAR TOURISM=0,INITIAL INTERNATIONAL VISITORS[SUMMER\
		], 
	IF THEN ELSE(SWITCH PROMOTE ALL YEAR TOURISM=1:AND:Time<INITIAL YEAR PROMOTE ALL YEAR TOURISM\
		,INITIAL INTERNATIONAL VISITORS[SUMMER],
	IF THEN ELSE(SWITCH PROMOTE ALL YEAR TOURISM=1:AND:Time>FINAL YEAR PROMOTE ALL YEAR TOURISM\
		,INITIAL INTERNATIONAL VISITORS[SUMMER]*(1-PROMOTE ALL YEAR TOURISM OBJECTIVE)+(SUM\
		(INITIAL INTERNATIONAL VISITORS[SEASONS!])/4)*PROMOTE ALL YEAR TOURISM OBJECTIVE,INITIAL INTERNATIONAL VISITORS\
		[SUMMER]*(1-(PROMOTE ALL YEAR TOURISM OBJECTIVE*((Time-INITIAL YEAR PROMOTE ALL YEAR TOURISM\
		)/(FINAL YEAR PROMOTE ALL YEAR TOURISM-INITIAL YEAR PROMOTE ALL YEAR TOURISM))))+(SUM\
		(INITIAL INTERNATIONAL VISITORS[SEASONS!])/4)*PROMOTE ALL YEAR TOURISM OBJECTIVE*((\
		Time-INITIAL YEAR PROMOTE ALL YEAR TOURISM)/(FINAL YEAR PROMOTE ALL YEAR TOURISM-INITIAL YEAR PROMOTE ALL YEAR TOURISM\
		)))))
	~	Tourists
	~		|

SWITCH PROMOTE ALL YEAR TOURISM=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Tourism system', 'SWITCH_PROMOTE_ALL_YEAR_TOURISM*'\
		)
	~	Dmnl
	~	0=ON
		1=OFF
	|

INITIAL INTERNATIONAL VISITORS[SEASONS]=
	IF THEN ELSE(SEASONS= SPRING,INITIAL INTERNATIONAL VISITORS SPRING,IF THEN ELSE(SEASONS\
		=SUMMER, INITIAL INTERNATIONAL VISITORS SUMMER,IF THEN ELSE(SEASONS=AUTUMN,INITIAL INTERNATIONAL VISITORS AUTUMN\
		,INITIAL INTERNATIONAL VISITORS WINTER)))
	~	Tourists
	~		|

BETA 1 WINTER=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Tourism system', 'BETA_1_WINTER*')
	~	Dmnl
	~		|

BETA 1 SUMMER=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Tourism system', 'BETA_1_SUMMER*')
	~	Dmnl
	~		|

INITIAL INTERNATIONAL VISITORS AUTUMN=
	ALFA 1 AUTUMN*MEAN TCI AUTUMN+BETA 1 AUTUMN
	~	Tourists
	~		|

TCI WINTER[MONTHS]=
	IF THEN ELSE( (MONTHS = DECEMBER) :OR: (MONTHS = JANUARY) :OR: (MONTHS = FEBRUARY), \
		TCI INDEX SSP585[MONTHS] , 0 )
	~	Dmnl
	~		|

TCI SPRING[MONTHS]=
	IF THEN ELSE( (MONTHS = MARCH) :OR: (MONTHS = APRIL) :OR: (MONTHS = MAY
	), TCI INDEX SSP585[MONTHS] , 0 )
	~	Dmnl
	~		|

MEAN TCI SUMMER=
	SUM(TCI SUMMER[MONTHS!]) / SUM(IF THEN ELSE(TCI SUMMER[MONTHS!] <> 0, 1, 0))
	~	Dmnl
	~		|

MEAN TCI WINTER=
	SUM(TCI WINTER[MONTHS!]) / SUM(IF THEN ELSE(TCI WINTER[MONTHS!] <> 0, 1, 0))
	~	Dmnl
	~		|

MEAN TCI=
	(MEAN TCI AUTUMN+MEAN TCI SPRING+MEAN TCI SUMMER+MEAN TCI WINTER) / 4
	~	Dmnl
	~		|

TCI SUMMER[MONTHS]=
	IF THEN ELSE( (MONTHS = JUNE) :OR: (MONTHS = JULY) :OR: (MONTHS = AUGUST
	):OR: (MONTHS = SEPTEMBER), TCI INDEX SSP585[MONTHS] , 0 )
	~	Dmnl
	~		|

MEAN TCI AUTUMN=
	SUM(TCI AUTUMN[MONTHS!]) / SUM(IF THEN ELSE(TCI AUTUMN[MONTHS!] <> 0, 1, 0))
	~	Dmnl
	~		|

MEAN TCI SPRING=
	SUM(TCI SPRING[MONTHS!]) / SUM(IF THEN ELSE(TCI SPRING[MONTHS!] <> 0, 1, 0))
	~	Dmnl
	~		|

TCI AUTUMN[MONTHS]=
	IF THEN ELSE( (MONTHS = OCTOBER) :OR: (MONTHS = NOVEMBER), TCI INDEX SSP585[MONTHS] \
		, 0 )
	~	Dmnl
	~		|

NEW WIND CAPACITY=
	IF THEN ELSE(SWITCH WIND CAPACITY=0,0,
	IF THEN ELSE(SWITCH WIND CAPACITY=1:AND:(Time<INITIAL YEAR WIND POLICY CAPACITY:OR:Time\
		>FINAL YEAR WIND POLICY CAPACITY
	),0,MIN((WIND CAPACITY OBJECTIVE)/(FINAL YEAR WIND POLICY CAPACITY - INITIAL YEAR WIND POLICY CAPACITY\
		), MAX WIND CAPACITY-WIND CAPACITY)))
	~	MW
	~	IF THEN ELSE(SWITCH WIND CAPACITY=0,MIN(MARKET DRIVEN INVESTMENTS FOR WIND \
		CAPACITY,MAX WIND CAPACITY-WIND CAPACITY),
		IF THEN ELSE(SWITCH WIND CAPACITY=1:AND:(Time<INITIAL YEAR WIND POLICY \
		CAPACITY:OR:Time>FINAL YEAR WIND POLICY CAPACITY
		),MIN(MARKET DRIVEN INVESTMENTS FOR WIND CAPACITY,MAX WIND CAPACITY-WIND CAPACITY),
		IF THEN ELSE( WIND CAPACITY < MAX WIND CAPACITY, IF THEN ELSE(((WIND CAPACITY \
		OBJECTIVE)/(FINAL YEAR WIND POLICY CAPACITY
		 - INITIAL YEAR WIND POLICY CAPACITY))>MARKET DRIVEN INVESTMENTS FOR WIND \
		CAPACITY,MIN((WIND CAPACITY OBJECTIVE)/(FINAL YEAR WIND POLICY CAPACITY
		 - INITIAL YEAR WIND POLICY CAPACITY), MAX WIND CAPACITY-WIND CAPACITY),MIN(MARKET \
		DRIVEN INVESTMENTS FOR WIND CAPACITY,
		MAX WIND CAPACITY-WIND CAPACITY)), 0 ) ) )
	|

NEW ROOFTOP CAPACITY=
	IF THEN ELSE(SWITCH ROOFTOP CAPACITY=0,0,
	IF THEN ELSE(SWITCH ROOFTOP CAPACITY=1:AND:(Time<INITIAL YEAR ROOFTOP POLICY CAPACITY\
		:OR:Time>FINAL YEAR ROOFTOP POLICY CAPACITY
	),0,MIN((ROOFTOP CAPACITY OBJECTIVE)/(FINAL YEAR ROOFTOP POLICY CAPACITY - INITIAL YEAR ROOFTOP POLICY CAPACITY\
		), MAX ROOFTOP CAPACITY-ROOFTOP CAPACITY)))
	~	MW
	~	IF THEN ELSE(SWITCH ROOFTOP CAPACITY=0,MIN(MARKET DRIVEN INVESTMENTS FOR ROOFTOP \
		CAPACITY,MAX ROOFTOP CAPACITY-ROOFTOP CAPACITY
		),
		IF THEN ELSE(SWITCH ROOFTOP CAPACITY=1:AND:(Time<INITIAL YEAR ROOFTOP POLICY \
		CAPACITY:OR:Time>FINAL YEAR ROOFTOP POLICY CAPACITY
		),MIN(MARKET DRIVEN INVESTMENTS FOR ROOFTOP CAPACITY,MAX ROOFTOP CAPACITY-ROOFTOP \
		CAPACITY),
		IF THEN ELSE( ROOFTOP CAPACITY < MAX ROOFTOP CAPACITY, IF THEN ELSE(((ROOFTOP \
		CAPACITY OBJECTIVE)/(FINAL YEAR ROOFTOP POLICY CAPACITY
		 - INITIAL YEAR ROOFTOP POLICY CAPACITY))>MARKET DRIVEN INVESTMENTS FOR ROOFTOP \
		CAPACITY,MIN((ROOFTOP CAPACITY OBJECTIVE
		)/(FINAL YEAR ROOFTOP POLICY CAPACITY - INITIAL YEAR ROOFTOP POLICY CAPACITY), MAX \
		ROOFTOP CAPACITY-ROOFTOP CAPACITY),MIN
		(MARKET DRIVEN INVESTMENTS FOR ROOFTOP CAPACITY,MAX ROOFTOP \
		CAPACITY-ROOFTOP CAPACITY)), 0 ) ) )
	|

NEW HYDRO CAPACITY=
	IF THEN ELSE(SWITCH HYDRO CAPACITY=0,0,
	IF THEN ELSE(SWITCH HYDRO CAPACITY=1:AND:(Time<INITIAL YEAR HYDRO POLICY CAPACITY:OR:\
		Time>FINAL YEAR HYDRO POLICY CAPACITY
	),0,MIN((HYDRO CAPACITY OBJECTIVE)/(FINAL YEAR HYDRO POLICY CAPACITY - INITIAL YEAR HYDRO POLICY CAPACITY\
		), MAX HYDRO CAPACITY-HYDROPOWER CAPACITY)))
	~	MW
	~	IF THEN ELSE(SWITCH HYDRO CAPACITY=0,MIN(MARKET DRIVEN INVESTMENTS FOR HYDRO \
		CAPACITY,MAX HYDRO CAPACITY-HYDROPOWER CAPACITY
		),
		IF THEN ELSE(SWITCH HYDRO CAPACITY=1:AND:(Time<INITIAL YEAR HYDRO POLICY \
		CAPACITY:OR:Time>FINAL YEAR HYDRO POLICY CAPACITY
		),MIN(MARKET DRIVEN INVESTMENTS FOR HYDRO CAPACITY,MAX HYDRO CAPACITY-HYDROPOWER \
		CAPACITY),
		IF THEN ELSE( HYDROPOWER CAPACITY < MAX HYDRO CAPACITY, IF THEN ELSE(((HYDRO \
		CAPACITY OBJECTIVE)/(FINAL YEAR HYDRO POLICY CAPACITY
		 - INITIAL YEAR HYDRO POLICY CAPACITY))>MARKET DRIVEN INVESTMENTS FOR HYDRO \
		CAPACITY,MIN((HYDRO CAPACITY OBJECTIVE)/(FINAL YEAR HYDRO POLICY CAPACITY
		 - INITIAL YEAR HYDRO POLICY CAPACITY), MAX HYDRO CAPACITY-HYDROPOWER \
		CAPACITY),MIN(MARKET DRIVEN INVESTMENTS FOR HYDRO CAPACITY
		,MAX HYDRO CAPACITY-HYDROPOWER CAPACITY)), 0 ) ) )
	|

SWITCH PROTECTED WETLANDS=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Land system', 'SWITCH_WETLANDS_PROTECTED*')
	~	Dmnl
	~	1 = ON
		0 = OFF
		GET DIRECT CONSTANTS ('Policy.xlsx', 'Land system', \
		'SWITCH_WETLANDS_PROTECTED*')
	|

FINAL YEAR FOR PROTECTED WETLANDS=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Land system', 'FINAL_YEAR_FOR_WETLANDS_PROTECTED*'\
		)
	~	Year
	~		|

INITIAL YEAR FOR PROTECTED WETLANDS=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Land system', 'INITIAL_YEAR_FOR_WETLANDS_PROTECTED*'\
		)
	~	Year
	~		|

INITIAL PROTECTED WETLANDS=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Land system', 'INITIAL_PROTECTED_WETLANDS*'\
		)
	~	km2
	~		|

INCREASE OBJECTIVE FOR PROTECTED WETLANDS=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Land system', 'INCREASE_OBJECTIVE_FOR_WETLANDS_PROTECTED*'\
		)
	~	km2
	~		|

"WATER-CROP RATIO"=
	IF THEN ELSE(IRRIGATED CROP AREA=0,1,(STORAGE INPUTS+STORAGE WATER+GROUNDWATER INPUTS\
		)/(IRRIGATED CROP AREA))
	~	Dmnl
	~	Deleted the multiplication factor of 365 applied to IRRIGATED CROP AREA
	|

AVAILABLE RUNOFF[MONTHS]=
	((DIRECT RUNOFF[MONTHS]+PERCOLATION RUNOFF[MONTHS])*TOTAL CS AREA)/MM PER KM2 TO M3
	~	Hm3/Month
	~		|

SWITCH TRANSBOUNDARY POLICY OTHER CS=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', 'SWITCH_TRANSBOUNDARY_POLICY_OTHER_CS*'\
		)
	~	Dmnl
	~	ON = 1
		OFF = 0
	|

TRANSBOUNDARY WATER[MONTHS]=
	IF THEN ELSE((MONTHS = NOVEMBER) :OR: (MONTHS = DECEMBER) :OR: (MONTHS = JANUARY) :OR:\
		 (MONTHS = FEBRUARY),0,IF THEN ELSE
	(SWITCH CS=4,TRANSBOUNDARY OBJECTIVE MURCIA[MONTHS],IF THEN ELSE(SWITCH TRANSBOUNDARY POLICY OTHER CS\
		=0,0,IF THEN ELSE(SWITCH TRANSBOUNDARY POLICY OTHER CS=1:AND:(Time<INITIAL YEAR TRANSBOUNDARY POLICY OTHER CS\
		:OR:Time>=FINAL YEAR TRANSBOUNDARY POLICY OTHER CS),0,(INITIAL TRANSBOUNDARY OBJECTIVE OTHER CS MONTHLY
	[MONTHS]*((Time-INITIAL YEAR TRANSBOUNDARY POLICY OTHER CS)/(FINAL YEAR TRANSBOUNDARY POLICY OTHER CS\
		-INITIAL YEAR TRANSBOUNDARY POLICY OTHER CS
	)))))))
	~	Hm3
	~		|

LIMIT ENERGY CONSUMPTION=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Energy', 'LIMIT_ENERGY_CONSUMPTION*')
	~	Dmnl
	~	GET DIRECT CONSTANTS ('Historical.xlsx', 'Energy', \
		'LIMIT_ENERGY_CONSUMPTION*')
	|

ENERGY CONSUMPTION VARIATION FACTOR=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Energy', 'ENERGY_CONSUMPTION_VARIATION_FACTOR*'\
		)
	~	Hm3 per capita
	~	GET DIRECT CONSTANTS ('Historical.xlsx', 'Energy', \
		'ENERGY_CONSUMPTION_VARIATION_FACTOR*')
	|

ENERGY CONSUMPTION VARIATION=
	IF THEN ELSE(Time<2027,ENERGY CONSUMPTION VARIATION FACTOR,ENERGY CONSUMPTION VARIATION FACTOR\
		*LIMIT ENERGY CONSUMPTION)
	~	Dmnl
	~		|

INITIAL CONSUMPTION PER CAPITA=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Energy', 'INITIAL_CONSUMPTION_PER_CAPITA*'\
		)
	~	MWh per capita
	~	GET DIRECT CONSTANTS ('Historical.xlsx', 'Energy', \
		'INITIAL_CONSUMPTION_PER_CAPITA*')
	|

CONSUMPTION PER CAPITA= INTEG (
	VARIATION CONSUMPTION PER CAPITA,
		INITIAL CONSUMPTION PER CAPITA)
	~	MWh
	~		|

VARIATION CONSUMPTION PER CAPITA=
	SMOOTH(CONSUMPTION PER CAPITA*(ENERGY CONSUMPTION VARIATION),2)
	~	MWh per capita
	~		|

WATER AREA=
	IF THEN ELSE(SWITCH WATER STORAGE INCREASE=0,0,IF THEN ELSE(SWITCH WATER STORAGE INCREASE\
		=1:AND:Time<INITIAL YEAR WATER STORAGE INCREASE,0,IF THEN ELSE(SWITCH WATER STORAGE INCREASE\
		=1:AND:Time>FINAL YEAR WATER STORAGE INCREASE,0,(WATER STORAGE INCREASE AREA OBJECTIVE\
		*((Time-INITIAL YEAR WATER STORAGE INCREASE)/(FINAL YEAR WATER STORAGE INCREASE
	-INITIAL YEAR WATER STORAGE INCREASE))))))
	~	km2
	~	IF THEN ELSE(SWITCH WATER STORAGE INCREASE=0,0,IF THEN ELSE(SWITCH WATER STORAGE \
		INCREASE=1:AND:Time<INITIAL YEAR WATER STORAGE INCREASE,0,IF THEN \
		ELSE(SWITCH WATER STORAGE INCREASE=1:AND:Time>FINAL YEAR WATER STORAGE \
		INCREASE,WATER STORAGE INCREASE AREA OBJECTIVE,(WATER STORAGE INCREASE \
		AREA OBJECTIVE*((Time-INITIAL YEAR WATER STORAGE INCREASE)/(FINAL YEAR \
		WATER STORAGE INCREASE
		-INITIAL YEAR WATER STORAGE INCREASE))))))
	|

SELECT LOCATION WATER STORAGE=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Land system', 'SELECT_LOCATION_WATER_STORAGE*'\
		)
	~	Dmnl
	~	GET DIRECT CONSTANTS ('Policy.xlsx', 'Land system', \
		'SELECT_LOCATION_WATER_STORAGE*')
	|

FINAL FLOW=
	(RUNOFF TO RIVER FLOW*(1-ECOLOGICAL FLOW))-STORAGE INPUTS
	~	Hm3
	~		|

DELAY EDUCATION=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', 'DELAY_EDUCATION*')
	~	Year
	~		|

TEMPERATURE SSP585:INTERPOLATE::=
	SUM(MEAN TEMPERATURE SSP585[MONTHS!])/12
	~	ºc
	~		|

INCREASE IN POPULATION ADAPTATION CAPACITY=
	IF THEN ELSE(SWITCH EDUCATION AND TRAINING INCREASE=0,0,IF THEN ELSE(SWITCH EDUCATION AND TRAINING INCREASE\
		=1:AND:(Time
	<INITIAL YEAR EDUCATION AND TRAINING INCREASE+DELAY EDUCATION),0,EDUCATIONAL LEVEL*EDUCATION AND TRAINING OBJECTIVE\
		))
	~	Dmnl
	~		|

TEMPERATURE SSP245:INTERPOLATE::=
	SUM(MEAN TEMPERATURE SSP245[MONTHS!])/12
	~	ºc
	~		|

FOREST MORTALITY COEFFICIENT=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Carbon stock biomass', 'FOREST_MORTALITY_COEFFICIENT'\
		)
	~	Dmnl
	~		|

FOREST MORTALITY=
	BIOMASS STOCK*FOREST MORTALITY COEFFICIENT
	~	tC
	~		|

WATER STORAGE INCREASE AREA OBJECTIVE=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Land system', 'INITIAL_WATER_STORAGE_INCREASE_AREA_OBJECTIVE*'\
		)
	~	km2
	~	GET DIRECT CONSTANTS ('Policy.xlsx', 'Land system', \
		'INITIAL_WATER_STORAGE_INCREASE_AREA_OBJECTIVE*')
	|

FINAL YEAR WATER STORAGE INCREASE=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', 'FINAL_YEAR_WATER_STORAGE_INCREASE*'\
		)
	~	Year
	~	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', \
		'FINAL_YEAR_WATER_STORAGE_INCREASE*')
	|

UNEMPLOYED=
	IF THEN ELSE(GAMMA UNEMPLOYED=0,(ALFA UNEMPLOYED*GDP PER CAPITA+BETA UNEMPLOYED)*(1-\
		LIMIT UNEMPLOYED*(Time-2018)),IF THEN ELSE(Time<=2030,(ALFA UNEMPLOYED*GDP PER CAPITA\
		^2+BETA UNEMPLOYED*GDP PER CAPITA+GAMMA UNEMPLOYED), (ALFA UNEMPLOYED*GDP PER CAPITA\
		^2+BETA UNEMPLOYED*GDP PER CAPITA+GAMMA UNEMPLOYED)*(1-LIMIT UNEMPLOYED*(Time-2030)\
		)))
	~	Inhabitants
	~	IF THEN ELSE (GAMMA UNEMPLOYED=0,ALFA UNEMPLOYED*GDP PER CAPITA+BETA \
		UNEMPLOYED,IF THEN ELSE(Time<=2030,(ALFA UNEMPLOYED*GDP PER CAPITA^2+BETA \
		UNEMPLOYED*GDP PER CAPITA+GAMMA UNEMPLOYED), (ALFA UNEMPLOYED*GDP PER \
		CAPITA^2+BETA UNEMPLOYED*GDP PER CAPITA+GAMMA UNEMPLOYED)*(1-LIMIT \
		UNEMPLOYED*(Time-2030))))
	|

LIMIT ENERGY POVERTY=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', 'LIMIT_ENERGY_POVERTY*'\
		)
	~	Dmnl
	~	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', \
		'LIMIT_ENERGY_POVERTY*')
	|

WATER STORAGE INCREASE CAPACITY OBJECTIVE=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', 'INITIAL_WATER_STORAGE_INCREASE_CAPACITY_OBJECTIVE*'\
		)
	~	Hm3
	~		|

INITIAL RESERVOIR CAPACITY=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', 'TOTAL_RESERVOIR_CAPACITY*'\
		)
	~	Hm3
	~		|

SWITCH WATER STORAGE INCREASE=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', 'SWITCH_WATER_STORAGE_INCREASE*'\
		)
	~	Dmnl
	~	0 = OFF
		1 = ON
		GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', \
		'SWITCH_WATER_STORAGE_INCREASE*')
	|

TOTAL RESERVOIR CAPACITY=
	IF THEN ELSE(SWITCH WATER STORAGE INCREASE=0,INITIAL RESERVOIR CAPACITY,IF THEN ELSE\
		(SWITCH WATER STORAGE INCREASE=1:AND:Time<INITIAL YEAR WATER STORAGE INCREASE,INITIAL RESERVOIR CAPACITY\
		,IF THEN ELSE(SWITCH WATER STORAGE INCREASE=1:AND:Time>FINAL YEAR WATER STORAGE INCREASE\
		,INITIAL RESERVOIR CAPACITY+WATER STORAGE INCREASE CAPACITY OBJECTIVE,INITIAL RESERVOIR CAPACITY\
		+(WATER STORAGE INCREASE CAPACITY OBJECTIVE*((Time-INITIAL YEAR WATER STORAGE INCREASE\
		+1)/(FINAL YEAR WATER STORAGE INCREASE-INITIAL YEAR WATER STORAGE INCREASE+1))))))
	~	Hm3
	~		|

INITIAL YEAR WATER STORAGE INCREASE=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', 'INITIAL_YEAR_WATER_STORAGE_INCREASE*'\
		)
	~	Year
	~	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', \
		'INITIAL_YEAR_WATER_STORAGE_INCREASE*')
	|

LIMIT UNEMPLOYED=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', 'LIMIT_UNEMPLOYED*')
	~	Dmnl
	~	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', \
		'LIMIT_UNEMPLOYED*')
	|

VARIATION WATER DEMAND FROM INDUSTRY=
	(WATER DEMAND FROM INDUSTRY PER CAPITA * INDUSTRY VARIATION) * (1 - (INDUSTRY VARIATION\
		/ LIMITING FACTOR INDUSTRY))
	~	Hm3/Year
	~		|

VARIATION WATER DEMAND URBAN PER CAPITA=
	(WATER DEMAND FROM URBAN PER CAPITA * URBAN VARIATION) * (1 - (URBAN VARIATION/ LIMITING FACTOR URBAN\
		))
	~	Hm3/Year
	~		|

LIMITING FACTOR INDUSTRY=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', 'LIMITING_FACTOR_INDUSTRY*'\
		)
	~	Hm3
	~	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', \
		'LIMITING_FACTOR_INDUSTRY*')
	|

LIMITING FACTOR URBAN=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', 'LIMITING_FACTOR_URBAN*')
	~	Hm3/Year
	~	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', \
		'LIMITING_FACTOR_URBAN*')
	|

LIMITING FACTOR AGRICULTURE=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', 'LIMITING_FACTOR_AGRICULTURE*'\
		)
	~	Hm3
	~	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', \
		'LIMITING_FACTOR_AGRICULTURE*')
	|

INDUSTRY VARIATION=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', 'INDUSTRY_VARIATION*')
	~	Hm3/Year
	~	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', \
		'INDUSTRY_VARIATION*')
	|

AGRICULTURE VARIATION=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', 'AGRICULTURE_VARIATION*')
	~	Hm3/Year
	~	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', \
		'AGRICULTURE_VARIATION*')
	|

VARIATION WATER DEMAND FROM AGRICULTURE=
	(WATER DEMAND FROM AGRICULTURE PER CAPITA * AGRICULTURE VARIATION) * (1 - (AGRICULTURE VARIATION\
		/ LIMITING FACTOR AGRICULTURE))
	~	Hm3/Year
	~		|

URBAN VARIATION=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', 'URBAN_VARIATION*')
	~	Hm3/Year
	~	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', \
		'URBAN_VARIATION*')
	|

WATER DEMAND FROM AGRICULTURE PER CAPITA= INTEG (
	VARIATION WATER DEMAND FROM AGRICULTURE,
		INITIAL WATER DEMAND FROM AGRICULTURE PER CAPITA)
	~	Hm3/Year
	~		|

WATER DEMAND FROM INDUSTRY PER CAPITA= INTEG (
	VARIATION WATER DEMAND FROM INDUSTRY,
		INITIAL WATER DEMAND FROM INDUSTRY PER CAPITA)
	~	Hm3/Year
	~		|

WATER DEMAND FROM URBAN PER CAPITA= INTEG (
	VARIATION WATER DEMAND URBAN PER CAPITA,
		INITIAL WATER DEMAND FROM URBAN)
	~	Hm3/Year
	~		|

GROUNDWATER MANAGEMENT= WITH LOOKUP (
	GROUNDWATER RESOURCES,
		([(0,0)-(10,10)],(0,0),(50000,1),(100000,1),(200000,1),(500000,1),(750000,1) ))
	~	Dmnl
	~	([(0,0)-(10,10)],(0,0),(5000,1),(10000,1),(20000,1),(50000,1),(75000,1) )
	|

GROUNDWATER CONSUMPTION=
	REQUEST FROM GROUNDWATER EXTRACTION*GROUNDWATER MANAGEMENT
	~	Hm3
	~		|

DECAY GDP PER CAPITA GROWTH RATE=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', 'DECAY_GDP_PER_CAPITA_GROWTH_RATE*'\
		)
	~	Dmnl
	~	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', \
		'DECAY_GDP_PER_CAPITA_GROWTH_RATE*')
	|

INITIAL GDP PER CAPITA=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', 'INITIAL_GDP_PER_CAPITA*'\
		)
	~	Euros per capita
	~	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', \
		'INITIAL_GDP_PER_CAPITA*')
	|

GDP PER CAPITA= INTEG (
	VARIATION GDP PER CAPITA,
		INITIAL GDP PER CAPITA)
	~	Euros per capita
	~		|

POPULATION IN ENERGY POVERTY=
	IF THEN ELSE(Time<=2030,(ALFA ENERGY POVERTY*GDP PER CAPITA)+BETA ENERGY POVERTY, ((\
		ALFA ENERGY POVERTY*GDP PER CAPITA)+BETA ENERGY POVERTY)*(1-(LIMIT ENERGY POVERTY*(\
		Time-2030))))
	~	Inhabitants
	~		|

VARIATION GDP PER CAPITA=
	GDP PER CAPITA*(GDP PER CAPITA GROWTH RATE-DECAY GDP PER CAPITA GROWTH RATE*(Time-INITIAL TIME\
		))
	~	Dmnl
	~		|

GDP PER CAPITA GROWTH RATE=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', 'GDP_PER_CAPITA_GROWTH_RATE*'\
		)
	~	Dmnl
	~	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', \
		'GDP_PER_CAPITA_GROWTH_RATE*')
	|

BETA BIRTHS=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', 'BETA_BIRTHS*')
	~	Dmnl
	~	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', \
		'BETA_BIRTHS*')
	|

BETA DEATHS=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', 'BETA_DEATHS*')
	~	Dmnl
	~	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', \
		'BETA_DEATHS*')
	|

BETA EDUCATION=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', 'BETA_EDUCATION*')
	~	Dmnl
	~	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', \
		'BETA_EDUCATION*')
	|

BETA ENERGY POVERTY=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', 'BETA_ENERGY_POVERTY*'\
		)
	~	Dmnl
	~	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', \
		'BETA_ENERGY_POVERTY*')
	|

ALFA ROOM=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', 'ALFA_ROOMS*')
	~	Dmnl
	~	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', \
		'ALFA_ROOMS*')
	|

ROOMS=
	SMOOTH(IF THEN ELSE ((ALFA ROOM*CS POPULATION+BETA ROOM)<0.0008*CS POPULATION:AND:GAMMA ROOMS\
		=0,0.0008*CS POPULATION,IF THEN ELSE(GAMMA ROOMS=0,ALFA ROOM*CS POPULATION+BETA ROOM\
		,ALFA ROOM*CS POPULATION^2+BETA ROOM*CS POPULATION+GAMMA ROOMS)),2)
	~	Rooms
	~		|

BETA ROOM=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', 'BETA_ROOMS*')
	~	Dmnl
	~	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', \
		'BETA_ROOMS*')
	|

BETA UNEMPLOYED=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', 'BETA_UNEMPLOYED*')
	~	Dmnl
	~	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', \
		'BETA_UNEMPLOYED*')
	|

ALFA BIRTHS=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', 'ALFA_BIRTHS*')
	~	Dmnl
	~	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', \
		'ALFA_BIRTHS*')
	|

ALFA DEATHS=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', 'ALFA_DEATHS*')
	~	Dmnl
	~	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', \
		'ALFA_DEATHS*')
	|

GAMMA ROOMS=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', 'GAMMA_ROOMS*')
	~	Dmnl
	~	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', \
		'GAMMA_ROOMS*')
	|

GAMMA UNEMPLOYED=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', 'GAMMA_UNEMPLOYED*')
	~	Dmnl
	~	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', \
		'GAMMA_UNEMPLOYED*')
	|

INITIAL WATER DEMAND FROM INDUSTRY PER CAPITA=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', 'INITIAL_WATER_DEMAND_FROM_INDUSTRY_PER_CAPITA*'\
		)
	~	Hm3/Year
	~	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', \
		'INITIAL_WATER_DEMAND_FROM_INDUSTRY_PER_CAPITA*')
	|

BIRTHS=
	SMOOTH(IF THEN ELSE((ALFA BIRTHS*CS POPULATION+BETA BIRTHS)<0.001*CS POPULATION,0.001\
		*CS POPULATION,ALFA BIRTHS*CS POPULATION+BETA BIRTHS),2)
	~	Inhabitants
	~		|

INITIAL WATER DEMAND FROM AGRICULTURE PER CAPITA=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', 'INITIAL_WATER_DEMAND_FROM_AGRICULTURE_PER_CAPITA*'\
		)
	~	Hm3/Year
	~	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', \
		'INITIAL_WATER_DEMAND_FROM_AGRICULTURE_PER_CAPITA*')
	|

DEATHS=
	SMOOTH(IF THEN ELSE((ALFA DEATHS*CS POPULATION+BETA DEATHS)<0.002*CS POPULATION,0.002\
		*CS POPULATION,ALFA DEATHS*CS POPULATION+BETA DEATHS), 2 )
	~	Inhabitants
	~		|

ALFA EDUCATION=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', 'ALFA_EDUCATION*')
	~	Dmnl
	~	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', \
		'ALFA_EDUCATION*')
	|

ALFA ENERGY POVERTY=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', 'ALFA_ENERGY_POVERTY*'\
		)
	~	Dmnl
	~	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', \
		'ALFA_ENERGY_POVERTY*')
	|

ALFA UNEMPLOYED=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', 'ALFA_UNEMPLOYED*')
	~	Dmnl
	~	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', \
		'ALFA_UNEMPLOYED*')
	|

EDUCATED POPULATION=
	SMOOTH(IF THEN ELSE((ALFA EDUCATION*CS POPULATION+BETA EDUCATION)<0.05*CS POPULATION\
		,0.05*CS POPULATION,ALFA EDUCATION*CS POPULATION+BETA EDUCATION),2)
	~	Inhabitants
	~		|

ALFA POP LOWER 5=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', 'ALFA_POP_LOWER_5*')
	~	Dmnl
	~	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', \
		'ALFA_POP_LOWER_5*')
	|

POPULATION GROWTH SSP245:=
	GET DIRECT DATA ('Historical.xlsx', 'Energy', 'POPULATION_GROWTH_TIME', 'POPULATION_GROWTH_SSP245'\
		)
	~	Inhabitants
	~		|

POPULATION GROWTH SSP585:=
	GET DIRECT DATA ('Historical.xlsx', 'Energy', 'POPULATION_GROWTH_TIME', 'POPULATION_GROWTH_SSP585'\
		)
	~	Inhabitants
	~		|

POPULATION GROWTH=
	IF THEN ELSE (SELECT POPULATION GROWTH SCENARIO = 0, POPULATION GROWTH SSP245,
	IF THEN ELSE (SELECT POPULATION GROWTH SCENARIO = 1, POPULATION GROWTH SSP585, 1))
	~	
	~		|

POPULATION HIGHER 65=
	SMOOTH( ALFA POP HIGHER 65*CS POPULATION+BETA POP HIGHER 65 , 2 )
	~	Inhabitants
	~		|

ALFA POP HIGHER 65=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', 'ALFA_POP_HIGHER_65*')
	~	Dmnl
	~	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', \
		'ALFA_POP_HIGHER_65*')
	|

SELECT POPULATION GROWTH SCENARIO=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Energy', 'SELECT_POPULATION_GROWTH_SCENARIO*')
	~	Dmnl
	~	0=SSP245
		1=SSP585
	|

POPULATION LOWER 5=
	SMOOTH( (ALFA POP LOWER 5)*CS POPULATION+(BETA POP LOWER 5) , 2 )
	~	Inhabitants
	~		|

BETA POP HIGHER 65=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', 'BETA_POP_HIGHER_65*')
	~	Dmnl
	~	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', \
		'BETA_POP_HIGHER_65*')
	|

BETA POP LOWER 5=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', 'BETA_POP_LOWER_5*')
	~	Dmnl
	~	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', \
		'BETA_POP_LOWER_5*')
	|

STORAGE INPUTS=
	IF THEN ELSE(STORAGE WATER < TOTAL RESERVOIR CAPACITY,
	MIN(RUNOFF TO RIVER FLOW * (1 - ECOLOGICAL FLOW),TOTAL RESERVOIR CAPACITY - STORAGE WATER\
		),0)
	~	Hm3
	~		|

STORAGE OUTPUTS=
	IF THEN ELSE(WATER DEMAND>AVAILABLE WATER, AVAILABLE WATER, WATER DEMAND)
	~	Hm3
	~		|

AVAILABLE WATER=
	IF THEN ELSE(STORAGE WATER<REMAINING STORAGE WATER, 0 , STORAGE WATER-REMAINING STORAGE WATER\
		)
	~	Hm3
	~		|

WATER DEMAND FROM INDUSTRY=
	IF THEN ELSE(SWITCH EFFICIENT WATER DEMAND FROM INDUSTRY=0,WATER DEMAND FROM INDUSTRY PER CAPITA\
		*CS POPULATION,IF THEN ELSE(SWITCH EFFICIENT WATER DEMAND FROM INDUSTRY
	=1:AND:(Time<INITIAL YEAR EFFICIENT WATER DEMAND FROM INDUSTRY),WATER DEMAND FROM INDUSTRY PER CAPITA\
		*CS POPULATION,IF THEN ELSE(SWITCH EFFICIENT WATER DEMAND FROM INDUSTRY
	=1:AND:(Time>FINAL YEAR EFFICIENT WATER DEMAND FROM INDUSTRY),(CS POPULATION*WATER DEMAND FROM INDUSTRY PER CAPITA\
		)*(1-EFFICIENT WATER DEMAND FROM INDUSTRY OBJECTIVE
	),(CS POPULATION*WATER DEMAND FROM INDUSTRY PER CAPITA)*(1-(EFFICIENT WATER DEMAND FROM INDUSTRY OBJECTIVE\
		*((Time-INITIAL YEAR EFFICIENT WATER DEMAND FROM INDUSTRY
	)/(FINAL YEAR EFFICIENT WATER DEMAND FROM INDUSTRY-INITIAL YEAR EFFICIENT WATER DEMAND FROM INDUSTRY\
		)))))))
	~	Hm3
	~		|

GROUNDWATER INPUTS=
	TO AQUIFER YEARLY+INFILTRATION FROM AGRICULTURE
	~	Hm3
	~		|

WATER LOSSES=
	EVAPORATION FROM STORAGE*STORAGE WATER
	~	Hm3
	~		|

STORAGE WATER= INTEG (
	STORAGE INPUTS-STORAGE OUTPUTS-WATER LOSSES,
		INITIAL STORAGE)
	~	Hm3
	~		|

TO AQUIFER YEARLY=
	SUM(TO AQUIFER[MONTHS!])
	~	Hm3
	~		|

INITIAL TRANSBOUNDARY OBJECTIVE OTHER CS MONTHLY[MONTHS]=
	IF THEN ELSE((MONTHS = NOVEMBER) :OR: (MONTHS = DECEMBER) :OR: (MONTHS = JANUARY) :OR:\
		 (MONTHS = FEBRUARY),0,TRANSBOUNDARY OBJECTIVE OTHER CS)
	~	Hm3
	~		|

GROUNDWATER RESOURCES= INTEG (
	GROUNDWATER INPUTS-GROUNDWATER CONSUMPTION,
		INITIAL GROUNDWATER)
	~	Hm3
	~		|

INFILTRATION FROM AGRICULTURE=
	WATER DEMAND FROM AGRICULTURE*INFILTRATION RATE
	~	Hm3
	~		|

WATER SECURITY=
	IF THEN ELSE ((WATER SUPPLY/ WATER DEMAND) >= 1,1,0)
	~	Dmnl
	~		|

HIGH EFFICIENT WATER DEMAND FROM URBAN=
	0.75
	~	Dmnl
	~		|

SELECT INCENTIVES FOR EFFICIENT WATER DEMAND FROM URBAN=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', 'SELECT_INCENTIVES_FOR_EFFICIENT_WATER_DEMAND_FROM_URBAN*'\
		)
	~	Dmnl
	~	0 = Low
		1 = Medium
		2 = High
		3 = Very High
	|

EFFICIENT WATER DEMAND FROM AGRICULTURE OBJECTIVE=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system','INITIAL_EFFICIENT_WATER_DEMAND_FROM_AGRICULTURE_OBJECTIVE*'\
		)
	~	Dmnl
	~	60% decrease of water demand
		GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', \
		'INITIAL_EFFICIENT_WATER_DEMAND_FROM_AGRICULTURE_OBJECTIVE*')
	|

EFFICIENT WATER DEMAND FROM INDUSTRY OBJECTIVE=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', 'INITIAL_EFFICIENT_WATER_DEMAND_FROM_INDUSTRY_OBJECTIVE*'\
		)
	~	Dmnl
	~		|

DESIRED EFFICIENT WATER DEMAND FROM URBAN OBJECTIVE=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', 'INITIAL_EFFICIENT_WATER_DEMAND_FROM_URBAN_OBJECTIVE*'\
		)
	~	Dmnl
	~		|

INITIAL YEAR EFFICIENT WATER DEMAND FROM INDUSTRY=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', 'INITIAL_YEAR_EFFICIENT_WATER_DEMAND_FROM_INDUSTRY*'\
		)
	~	Year
	~		|

INITIAL YEAR EFFICIENT WATER DEMAND FROM URBAN=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', 'INITIAL_YEAR_EFFICIENT_WATER_DEMAND_FROM_URBAN*'\
		)
	~	Year
	~		|

VERY HIGH EFFICIENT WATER DEMAND FROM URBAN=
	1
	~	Dmnl
	~		|

INITIAL WATER DEMAND FROM URBAN=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', 'INITIAL_WATER_DEMAND_FROM_URBAN_PER_CAPITA*'\
		)
	~	Hm3 per capita
	~	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', \
		'INITIAL_WATER_DEMAND_FROM_URBAN_PER_CAPITA*')
	|

MEDIUM EFFICIENT WATER DEMAND FROM URBAN=
	0.5
	~	Dmnl
	~		|

FINAL YEAR EFFICIENT WATER DEMAND FROM URBAN=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', 'FINAL_YEAR_EFFICIENT_WATER_DEMAND_FROM_URBAN*'\
		)
	~	Year
	~		|

LOW EFFICIENT WATER DEMAND FROM URBAN=
	0.25
	~	Dmnl
	~		|

SWITCH EFFICIENT WATER DEMAND FROM AGRICULTURE=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', 'SWITCH_EFFICIENT_WATER_DEMAND_FROM_AGRICULTURE*'\
		)
	~	Dmnl
	~	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', \
		'SWITCH_EFFICIENT_WATER_DEMAND_FROM_AGRICULTURE*')
	|

FINAL YEAR EFFICIENT WATER DEMAND FROM AGRICULTURE=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', 'FINAL_YEAR_EFFICIENT_WATER_DEMAND_FROM_AGRICULTURE*'\
		)
	~	Year
	~	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', \
		'FINAL_YEAR_EFFICIENT_WATER_DEMAND_FROM_AGRICULTURE*')
	|

SWITCH EFFICIENT WATER DEMAND FROM INDUSTRY=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', 'SWITCH_EFFICIENT_WATER_DEMAND_FROM_INDUSTRY*'\
		)
	~	Dmnl
	~		|

FINAL YEAR EFFICIENT WATER DEMAND FROM INDUSTRY=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', 'FINAL_YEAR_EFFICIENT_WATER_DEMAND_FROM_INDUSTRY*'\
		)
	~	Year
	~		|

SWITCH EFFICIENT WATER DEMAND FROM URBAN=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', 'SWITCH_EFFICIENT_WATER_DEMAND_FROM_URBAN*'\
		)
	~	Dmnl
	~		|

INITIAL YEAR EFFICIENT WATER DEMAND FROM AGRICULTURE=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', 'INITIAL_YEAR_EFFICIENT_WATER_DEMAND_FROM_AGRICULTURE*'\
		)
	~	Year
	~	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', \
		'INITIAL_YEAR_EFFICIENT_WATER_DEMAND_FROM_AGRICULTURE*')
	|

EFFICIENT WATER DEMAND FROM URBAN OBJECTIVE=
	IF THEN ELSE (SELECT INCENTIVES FOR EFFICIENT WATER DEMAND FROM URBAN = 0, LOW EFFICIENT WATER DEMAND FROM URBAN\
		*DESIRED EFFICIENT WATER DEMAND FROM URBAN OBJECTIVE,
	IF THEN ELSE (SELECT INCENTIVES FOR EFFICIENT WATER DEMAND FROM URBAN = 1, MEDIUM EFFICIENT WATER DEMAND FROM URBAN\
		*DESIRED EFFICIENT WATER DEMAND FROM URBAN OBJECTIVE,
	IF THEN ELSE (SELECT INCENTIVES FOR EFFICIENT WATER DEMAND FROM URBAN = 2, HIGH EFFICIENT WATER DEMAND FROM URBAN\
		*DESIRED EFFICIENT WATER DEMAND FROM URBAN OBJECTIVE,
	IF THEN ELSE (SELECT INCENTIVES FOR EFFICIENT WATER DEMAND FROM URBAN = 3, VERY HIGH EFFICIENT WATER DEMAND FROM URBAN\
		*DESIRED EFFICIENT WATER DEMAND FROM URBAN OBJECTIVE, LOW EFFICIENT WATER DEMAND FROM URBAN\
		*DESIRED EFFICIENT WATER DEMAND FROM URBAN OBJECTIVE))))
	~	
	~		|

FINAL YEAR DESALINATION INCREASE=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', 'FINAL_YEAR_DESALINATION_INCREASE*'\
		)
	~	Year
	~	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', \
		'FINAL_YEAR_DESALINATION_INCREASE*')
	|

INITIAL YEAR DESALINATION INCREASE=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', 'INITIAL_YEAR_DESALINATION_INCREASE*'\
		)
	~	Year
	~	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', \
		'INITIAL_YEAR_DESALINATION_INCREASE*')
	|

DESALINATION OBJECTIVE=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', 'INITIAL_DESALINATION_OBJECTIVE*'\
		)
	~	Hm3
	~	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', \
		'INITIAL_DESALINATION_OBJECTIVE*')
	|

SWITCH CS=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', 'SWITCH_CS*')
	~	Dmnl
	~	1 = CS1
		2 = CS2
		3 = CS3
		4 = CS4
		5 = CS5
		GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', 'SWITCH_CS*')
	|

SWITCH DESALINATION INCREASE POLICY=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', 'SWITCH_DESALINATION_INCREASE_POLICY*'\
		)
	~	Dmnl
	~	0 = OFF
		1 = ON
		GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', \
		'SWITCH_DESALINATION_INCREASE_POLICY*')
	|

TRANSBOUNDARY OBJECTIVE MURCIA[MONTHS]=
	IF THEN ELSE (SELECT MURCIA CONDITIONS = 3, LEVEL 4 MURCIA,
	IF THEN ELSE (SELECT MURCIA CONDITIONS = 2, LEVEL 3 MURCIA,
	IF THEN ELSE (SELECT MURCIA CONDITIONS = 1, LEVEL 2 MURCIA,
	IF THEN ELSE (SELECT MURCIA CONDITIONS = 0, LEVEL 1 MURCIA, 0))))
	~	Hm3
	~		|

PRECIPITATION[MONTHS]:INTERPOLATE::=
	IF THEN ELSE (SELECT PRECIPITATION SCENARIO = 0, PRECIPITATION SSP245[MONTHS],
	IF THEN ELSE (SELECT PRECIPITATION SCENARIO = 1, PRECIPITATION SSP585[MONTHS], 1))
	~	mm
	~		|

MEAN TEMPERATURE SSP245[MONTHS]:INTERPOLATE::=
	GET DIRECT DATA ('Historical.xlsx', 'Water system', 'MEAN_TEMPERATURE_SSP245_TIME', \
		'MEAN_TEMPERATURE_SSP245')
	~	ºc
	~		|

MEAN TEMPERATURE SSP585[MONTHS]:INTERPOLATE::=
	GET DIRECT DATA ('Historical.xlsx', 'Water system', 'MEAN_TEMPERATURE_SSP585_TIME', \
		'MEAN_TEMPERATURE_SSP585')
	~	ºc
	~		|

PRECIPITATION SSP585[MONTHS]:=
	GET DIRECT DATA ('Historical.xlsx', 'Water system', 'PRECIPITATION_SSP585_TIME', 'PRECIPITATION_SSP585'\
		)
	~	mm
	~		|

LEVEL 1 MURCIA=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', 'LEVEL_1_MURCIA*')
	~	Hm3
	~	Nivel 1. Se dará cuando las existencias conjuntas en Entrepeñas y \
		Buendía sean iguales o mayores que 1300 hm³, o cuando las aportaciones \
		conjuntas entrantes a estos embalses en los últimos doce meses sean \
		iguales o mayores que 1200 hm³. En este caso el órgano competente \
		autorizará un trasvase mensual de 60 hm³, hasta el máximo anual antes \
		referido.
	|

TRANSBOUNDARY OBJECTIVE OTHER CS=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', 'INITIAL_TRANSBOUNDARY_OBJECTIVE_OTHER_CS*'\
		)
	~	Hm3
	~		|

FINAL YEAR TRANSBOUNDARY POLICY OTHER CS=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', 'FINAL_YEAR_TRANSBOUNDARY_POLICY_OTHER_CS*'\
		)
	~	Year
	~		|

INITIAL YEAR TRANSBOUNDARY POLICY OTHER CS=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', 'INITIAL_YEAR_TRANSBOUNDARY_POLICY_OTHER_CS*'\
		)
	~	Year
	~		|

INITIAL DESALINATION=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', 'INITIAL_DESALINATION*')
	~	Hm3
	~	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', \
		'INITIAL_DESALINATION*')
	|

LEVEL 4 MURCIA=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', 'LEVEL_4_MURCIA*')
	~	Hm3
	~	Nivel 4. Se dará esta situación cuando las existencias conjuntas en \
		Entrepeñas y Buendía sean inferiores a 400 hm³, en cuyo caso no cabe \
		aprobar trasvase alguno.
	|

SELECT MURCIA CONDITIONS=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', 'SELECT_MURCIA_CONDITIONS*')
	~	Dmnl
	~	0 = Level 1
		1 = Level 2
		2 = Level 3
		3 = Level 4
		GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', \
		'SELECT_MURCIA_CONDITIONS*')
	|

LEVEL 3 MURCIA=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', 'LEVEL_3_MURCIA*')
	~	Hm3
	~	Nivel 3. Se dará cuando las existencias conjuntas en Entrepeñas y Buendía no \
		superen, a comienzos de cada mes, los valores mostrados en la tabla \
		(valores en hm³):
		
		Oct.	Nov.	Dic.	Ene.	Feb.	Marz.	Abr.	May.	Jun.	Jul.	Ago.	Sep.
		613	609	605	602	597	591	586	645	673	688	661	631
		En este nivel, denominado como de situación hidrológica excepcional, el \
		órgano competente podrá autorizar discrecionalmente y de forma motivada \
		un trasvase de hasta 20 hm³/mes.
	|

PRECIPITATION SSP245[MONTHS]:=
	GET DIRECT DATA ('Historical.xlsx', 'Water system', 'PRECIPITATION_SSP245_TIME', 'PRECIPITATION_SSP245'\
		)
	~	mm
	~		|

SELECT PRECIPITATION SCENARIO=
	1
	~	Dmnl
	~	0 = SSP245
		1 = SSP585
		GET DIRECT CONSTANTS ('Policy.xlsx', 'Water system', \
		'SELECT_PRECIPITATION_SCENARIO*')
	|

LEVEL 2 MURCIA=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', 'LEVEL_2_MURCIA*')
	~	Hm3
	~	Nivel 2. Se dará cuando las existencias conjuntas de Entrepeñas y \
		Buendía sean inferiores a 1300 hm³, sin llegar a los volúmenes \
		previstos en el Nivel 3, y las aportaciones conjuntas registradas en los \
		últimos doce meses sean inferiores a 1200 hm³. En este caso el órgano \
		competente autorizará un trasvase mensual de 27 hm³, hasta el máximo \
		anual antes referido.
	|

DELAY FOREST= DELAY FIXED (
	FOREST, 1 , 0)
	~	km2
	~		|

TBE= INTEG (
	IF THEN ELSE(VARIATION TBE<0,(VARIATION TBE*INITIAL RATIO TBE),VARIATION TBE),
		INITIAL RATIO TBE*INITIAL FOREST AREA)
	~	km2
	~		|

TBS= INTEG (
	IF THEN ELSE(VARIATION TBS<0,(VARIATION TBS*INITIAL RATIO TBS),VARIATION TBS),
		INITIAL RATIO TBS*INITIAL FOREST AREA)
	~	km2
	~		|

RATIO TBE=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Carbon stock biomass', 'RATIO_TBE*')
	~	Dmnl
	~		|

RATIO TBS=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Carbon stock biomass', 'RATIO_TBS*')
	~	Dmnl
	~		|

RATIO TNE=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Carbon stock biomass', 'RATIO_TNE*')
	~	Dmnl
	~		|

VARIATION TNE=
	IF THEN ELSE(Time=INITIAL TIME,0,IF THEN ELSE(FOREST VARIATION<0,FOREST VARIATION,FOREST VARIATION\
		*RATIO TNE))
	~	km2
	~		|

FOREST VARIATION=
	FOREST-DELAY FOREST
	~	km2
	~		|

TNE= INTEG (
	IF THEN ELSE(VARIATION TNE<0,(VARIATION TNE*INITIAL RATIO TNE),VARIATION TNE),
		INITIAL RATIO TNE*INITIAL FOREST AREA)
	~	km2
	~		|

BNE= INTEG (
	IF THEN ELSE(VARIATION BNE<0,(VARIATION BNE*INITIAL RATIO BNE),VARIATION BNE),
		INITIAL RATIO BNE*INITIAL FOREST AREA)
	~	km2
	~		|

BBS= INTEG (
	IF THEN ELSE(VARIATION BBS<0,(VARIATION BBS*INITIAL RATIO BBS),VARIATION BBS),
		INITIAL RATIO BBS*INITIAL FOREST AREA)
	~	km2
	~		|

VARIATION BBS=
	IF THEN ELSE(Time=INITIAL TIME,0,IF THEN ELSE(FOREST VARIATION<0,FOREST VARIATION,FOREST VARIATION\
		*RATIO BBS))
	~	km2
	~		|

VARIATION TBE=
	IF THEN ELSE(Time=INITIAL TIME,0,IF THEN ELSE(FOREST VARIATION<0,FOREST VARIATION,FOREST VARIATION\
		*RATIO TBE))
	~	km2
	~		|

RATIO BBS=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Carbon stock biomass', 'RATIO_BBS*')
	~	Dmnl
	~		|

VARIATION BNE=
	IF THEN ELSE(Time=INITIAL TIME,0,IF THEN ELSE(FOREST VARIATION<0,FOREST VARIATION,FOREST VARIATION\
		*RATIO BNE))
	~	km2
	~		|

VARIATION TBS=
	IF THEN ELSE(Time=INITIAL TIME,0,IF THEN ELSE(FOREST VARIATION<0,FOREST VARIATION,FOREST VARIATION\
		*RATIO TBS))
	~	km2
	~		|

RATIO BNE=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Carbon stock biomass', 'RATIO_BNE*')
	~	Dmnl
	~		|

INITIAL RATIO IRRIGATED CROP AREA=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Crop system', 'RATIO_IRRIGATED_CROP_AREA*'\
		)
	~	Dmnl
	~		|

GROWTH RATE=
	POPULATION GROWTH
	~	Inhabitants
	~		|

BIOMASS STOCK= INTEG (
	((((BOREAL BROADLEAVED SUMMERGREEN*BBS)+(BOREAL NEEDLELEAVED EVERGREEN*BNE)+(TEMPERATE BROADLEAVED EVERGREEN
	*TBE)+(TEMPERATE BROADLEAVED SUMMERGREEN*TBS)
	+(TEMPERATE NEEDLELEAVED EVERGREEN*TNE))*FACTOR HA TO KM2)*KG TO TONNES)-DECAY RATE FOR BIOMASS STOCK INFLUENDED BY FOREST MANAGEMENT\
		-FOREST MORTALITY,
		INITIAL BIOMASS STOCK)
	~	tC
	~	(INITIAL BIOMASS STOCK+(((BOREAL BROADLEAVED SUMMERGREEN*BBS)+(BOREAL NEEDLELEAVED \
		EVERGREEN*BBE)+(TEMPERATE BROADLEAVED EVERGREEN
		*TBE)+(TEMPERATE BROADLEAVED SUMMERGREEN*TBS)
		+(TEMPERATE NEEDLELEAVED EVERGREEN*TNE)-DECAY RATE FOR BIOMASS \
		STOCK)*FACTOR HA TO KM2))*KG TO TONNES
	|

DECAY RATE FOR BIOMASS STOCK INFLUENDED BY FOREST MANAGEMENT=
	IF THEN ELSE (Time = INITIAL TIME, (INITIAL BIOMASS STOCK*DECAY COEFFICIENT FOREST MANAGEMENT\
		),BIOMASS STOCK*(DECAY RATE FOREST MANAGEMENT))
	~	tC
	~	BIOMASS STOCK*DECAY RATE
	|

DECAY RATE FOREST MANAGEMENT=
	IF THEN ELSE(SWITCH FOREST MANAGEMENT=0,DECAY COEFFICIENT FOREST MANAGEMENT,IF THEN ELSE\
		(SWITCH FOREST MANAGEMENT=1
	:AND:(Time<INITIAL YEAR FOREST MANAGEMENT),DECAY COEFFICIENT FOREST MANAGEMENT,IF THEN ELSE\
		(SWITCH FOREST MANAGEMENT=1
	:AND:(Time>FINAL YEAR FOREST MANAGEMENT),DECAY COEFFICIENT FOREST MANAGEMENT*(1-(FOREST MANAGEMENT OBJECTIVE\
		)),
	DECAY COEFFICIENT FOREST MANAGEMENT*(1-(FOREST MANAGEMENT OBJECTIVE)*((Time-INITIAL YEAR FOREST MANAGEMENT
	)/(FINAL YEAR FOREST MANAGEMENT-INITIAL YEAR FOREST MANAGEMENT))))))
	~	Dmnl
	~	0.01
	|

DECAY COEFFICIENT FOREST MANAGEMENT=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Carbon stock biomass', 'DECAY_COEFFICIENT_FOREST_MANAGEMENT'\
		)
	~	Dmnl
	~		|

FINAL YEAR FOREST MANAGEMENT=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Carbon stock biomass', 'FINAL_YEAR_FOREST_MANAGEMENT*'\
		)
	~	Year
	~		|

INITIAL FOREST MANAGEMENT OBJECTIVE=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Carbon stock biomass', 'INITIAL_FOREST_MANAGEMENT_OBJECTIVE*'\
		)
	~	Dmnl
	~	Reduction of 30% of decay
	|

LOW FOREST MANAGEMENT=
	0.25
	~	Dmnl
	~		|

HIGH FOREST MANAGEMENT=
	0.75
	~	Dmnl
	~		|

INITIAL YEAR FOREST MANAGEMENT=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Carbon stock biomass', 'INITIAL_YEAR_FOREST_MANAGEMENT*'\
		)
	~	Year
	~		|

MEDIUM FOREST MANAGEMENT=
	0.5
	~	Dmnl
	~		|

SELECT FOREST MANAGEMENT INCENTIVES=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Carbon stock biomass', 'SELECT_FOREST_MANAGEMENT_INCENTIVES*'\
		)
	~	Dmnl
	~	0 = Low
		1 = Medium
		2 = High
		3 = Very High
	|

VERY HIGH FOREST MANAGEMENT=
	1
	~	Dmnl
	~		|

FOREST MANAGEMENT OBJECTIVE=
	IF THEN ELSE (SELECT FOREST MANAGEMENT INCENTIVES = 0, LOW FOREST MANAGEMENT*INITIAL FOREST MANAGEMENT OBJECTIVE\
		,
	IF THEN ELSE (SELECT FOREST MANAGEMENT INCENTIVES = 1, MEDIUM FOREST MANAGEMENT*INITIAL FOREST MANAGEMENT OBJECTIVE\
		,
	IF THEN ELSE (SELECT FOREST MANAGEMENT INCENTIVES = 2, HIGH FOREST MANAGEMENT*INITIAL FOREST MANAGEMENT OBJECTIVE\
		,
	IF THEN ELSE (SELECT FOREST MANAGEMENT INCENTIVES = 3, VERY HIGH FOREST MANAGEMENT*INITIAL FOREST MANAGEMENT OBJECTIVE\
		, LOW FOREST MANAGEMENT*INITIAL FOREST MANAGEMENT OBJECTIVE))))
	~	Dmnl
	~		|

SWITCH FOREST MANAGEMENT=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Carbon stock biomass', 'SWITCH_FOREST_MANAGEMENT*'\
		)
	~	Dmnl
	~		|

INITIAL RATIO BBS=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Carbon stock biomass', 'INITIAL_RATIO_BBS'\
		)
	~	Dmnl
	~		|

KG TO TONNES=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Carbon stock biomass', 'KG_TO_TONNES')
	~	Dmnl
	~		|

TOTAL CARBON STOCK=
	(BIOMASS STOCK*CARBON TRANSFORMATION CONSTANT*FACTOR HA TO KM2)*KG TO TONNES
	~	tCO2
	~		|

INITIAL RATIO TBE=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Carbon stock biomass', 'INITIAL_RATIO_TBE'\
		)
	~	Dmnl
	~		|

INITIAL RATIO TBS=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Carbon stock biomass', 'INITIAL_RATIO_TBS'\
		)
	~	Dmnl
	~		|

INITIAL RATIO TNE=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Carbon stock biomass', 'INITIAL_RATIO_TNE'\
		)
	~	Dmnl
	~		|

FACTOR HA TO KM2=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Carbon stock biomass', 'FACTOR_HA_TO_KM2')
	~	ha
	~		|

REFERENCE TEMPERATURE 2017=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Carbon stock biomass', 'REFERENCE_TEMPERATURE_2017'\
		)
	~	ºc
	~		|

TEMPERATE BROADLEAVED EVERGREEN=
	(0.28639-(0.03491*TEMPERATURE INCREASE)-(0.0007*POWER(TEMPERATURE INCREASE,2)))+(0.07744\
		*(CO2 CONCENTRATION/(CO2 CONCENTRATION+98.501)))
	~	kgC/ha·year
	~		|

TEMPERATE BROADLEAVED SUMMERGREEN=
	(0.08529+(0.01341*TEMPERATURE INCREASE)-(0.00161*POWER(TEMPERATURE INCREASE,2)))+(0.24635\
		*(CO2 CONCENTRATION/(CO2 CONCENTRATION+768.02)))
	~	kgC/ha·year
	~		|

TEMPERATE NEEDLELEAVED EVERGREEN=
	(0.22092-(0.01822*TEMPERATURE INCREASE)-(0.00094*POWER(TEMPERATURE INCREASE,2)))+(0.35027\
		*(CO2 CONCENTRATION/(CO2 CONCENTRATION+1053.22)))
	~	kgC/ha·year
	~		|

TEMPERATURE INCREASE=
	IF THEN ELSE( Time=2018 , FUTURE TEMPERATURE-REFERENCE TEMPERATURE 2017, FUTURE TEMPERATURE\
		-FUTURE TEMPERATURE DELAY)
	~	ºc
	~		|

CO2 FUTURE DATA:INTERPOLATE::=
	GET DIRECT DATA ('Historical.xlsx', 'Carbon stock biomass', 'CO2_TIME', 'CO2_FUTURE_DATA'\
		)
	~	ppm
	~		|

REFERENCE CO2 2017=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Carbon stock biomass', 'REFERENCE_CO2_2017'\
		)
	~	ppm
	~		|

SELECT TEMPERATURE SCENARIO=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Carbon stock biomass', 'SELECT_TEMPERATURE_SCENARIO*'\
		)
	~	Dmnl
	~	SSP245=0
		SSP585=1
	|

BOREAL BROADLEAVED SUMMERGREEN=
	(0.24572-(0.06422*TEMPERATURE INCREASE)-(0.00477*POWER(TEMPERATURE INCREASE,2)))+(0.0235\
		*(CO2 CONCENTRATION/(CO2 CONCENTRATION+70.6306)))
	~	kgC/ha·year
	~		|

BOREAL NEEDLELEAVED EVERGREEN=
	(0.34654-(0.08512*TEMPERATURE INCREASE)-(0.00558*POWER(TEMPERATURE INCREASE,2)))+(0.02119\
		*(CO2 CONCENTRATION/(CO2 CONCENTRATION+16.6054)))
	~	kgC/ha·year
	~		|

INITIAL RATIO BNE=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Carbon stock biomass', 'INITIAL_RATIO_BNE'\
		)
	~	Dmnl
	~		|

INITIAL BIOMASS STOCK=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Carbon stock biomass', 'INITIAL_BIOMASS_STOCK'\
		)
	~	tC
	~		|

FUTURE TEMPERATURE=
	IF THEN ELSE (SELECT TEMPERATURE SCENARIO = 0, TEMPERATURE SSP245,
	IF THEN ELSE (SELECT TEMPERATURE SCENARIO = 1, TEMPERATURE SSP585, 
	0))
	~	ºc
	~		|

CARBON TRANSFORMATION CONSTANT=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Carbon stock biomass', 'CARBON_TRANSFORMATION_CONSTANT'\
		)
	~	Dmnl
	~		|

FUTURE CO2 DELAY=
	DELAY FIXED(CO2 FUTURE DATA, 1 , 1)
	~	ppm
	~		|

FUTURE TEMPERATURE DELAY=
	DELAY FIXED (FUTURE TEMPERATURE, 1 , 1)
	~	ºc
	~		|

CO2 CONCENTRATION=
	IF THEN ELSE( Time=2018 , CO2 FUTURE DATA-REFERENCE CO2 2017, CO2 FUTURE DATA-FUTURE CO2 DELAY\
		)
	~	ppm
	~		|

SELECT EDUCATION AND TRAINING INCENTIVES=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Population system', 'SELECT_EDUCATION_AND_TRAINING_INCENTIVES*'\
		)
	~	Dmnl
	~	0 = Low
		1 = Medium
		2 = High
		3 = Very High
	|

FINAL YEAR INVESTMENT IN TOURISM ADAPTATION AND RESILIENCE=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Tourism system', 'FINAL_YEAR_INVESTMENT_IN_TOURISM_ADAPTATION_AND_RESILIENCE*'\
		)
	~	Year
	~		|

SELECT INVESTMENT IN TOURISM ADAPTATION AND RESILIENCE=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Tourism system', 'SELECT_INVESTMENT_IN_TOURISM_ADAPTATION_AND_RESILIENCE*'\
		)
	~	Dmnl
	~	0 = Low
		1 = Medium
		2 = High
		3 = Very High
		GET DIRECT CONSTANTS ('Policy.xlsx', 'Tourism system', \
		'SELECT_INVESTMENT_IN_TOURISM_ADAPTATION_AND_RESILIENCE*')
	|

EDUCATION AND TRAINING OBJECTIVE=
	IF THEN ELSE (SELECT EDUCATION AND TRAINING INCENTIVES = 0, LOW EDUCATION AND TRAINING\
		*DESIRED EDUCATION AND TRAINING OBJECTIVE,
	IF THEN ELSE (SELECT EDUCATION AND TRAINING INCENTIVES = 1, MEDIUM EDUCATION AND TRAINING\
		*DESIRED EDUCATION AND TRAINING OBJECTIVE,
	IF THEN ELSE (SELECT EDUCATION AND TRAINING INCENTIVES = 2, HIGH EDUCATION AND TRAINING\
		*DESIRED EDUCATION AND TRAINING OBJECTIVE,
	IF THEN ELSE (SELECT EDUCATION AND TRAINING INCENTIVES = 3, VERY HIGH EDUCATION AND TRAINING\
		*DESIRED EDUCATION AND TRAINING OBJECTIVE, LOW EDUCATION AND TRAINING*DESIRED EDUCATION AND TRAINING OBJECTIVE\
		))))
	~	Dmnl
	~		|

DESIRED EDUCATION AND TRAINING OBJECTIVE=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Population system', 'INITIAL_EDUCATION_AND_TRAINING_OBJECTIVE*'\
		)
	~	Dmnl
	~		|

LOW EDUCATION AND TRAINING=
	0.25
	~	Dmnl
	~		|

INITIAL YEAR INVESTMENT IN TOURISM ADAPTATION AND RESILIENCE=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Tourism system', 'INITIAL_YEAR_INVESTMENT_IN_TOURISM_ADAPTATION_AND_RESILIENCE*'\
		)
	~	Year
	~		|

LOW INVESTMENT IN TOURISM=
	0.25
	~	Dmnl
	~		|

HIGH INVESTMENT IN TOURISM=
	0.75
	~	Dmnl
	~		|

INVESTMENT IN TOURISM ADAPTATION AND RESILIENCE=
	IF THEN ELSE(SWITCH INVESTMENT IN TOURISM ADAPTATION AND RESILIENCE=0,0,IF THEN ELSE\
		(SWITCH INVESTMENT IN TOURISM ADAPTATION AND RESILIENCE=1:AND:(Time<INITIAL YEAR INVESTMENT IN TOURISM ADAPTATION AND RESILIENCE\
		),0,IF THEN ELSE(SWITCH INVESTMENT IN TOURISM ADAPTATION AND RESILIENCE=1:AND:Time>\
		FINAL YEAR INVESTMENT IN TOURISM ADAPTATION AND RESILIENCE,INVESTMENT IN TOURISM ADAPTATION AND RESILIENCE OBJECTIVE\
		,INVESTMENT IN TOURISM ADAPTATION AND RESILIENCE OBJECTIVE*((Time-INITIAL YEAR INVESTMENT IN TOURISM ADAPTATION AND RESILIENCE\
		)/(FINAL YEAR INVESTMENT IN TOURISM ADAPTATION AND RESILIENCE-INITIAL YEAR INVESTMENT IN TOURISM ADAPTATION AND RESILIENCE\
		)))))
	~	Dmnl
	~		|

SWITCH INVESTMENT IN TOURISM ADAPTATION AND RESILIENCE=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Tourism system', 'SWITCH_INVESTMENT_IN_TOURISM_ADAPTATION_AND_RESILIENCE*'\
		)
	~	Dmnl
	~	GET DIRECT CONSTANTS ('Policy.xlsx', 'Tourism system', \
		'SWITCH_INVESTMENT_IN_TOURISM_ADAPTATION_AND_RESILIENCE*')
	|

INITIAL YEAR EDUCATION AND TRAINING INCREASE=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Population system', 'INITIAL_YEAR_EDUCATION_AND_TRAINING_INCREASE*'\
		)
	~	Year
	~		|

MEDIUM EDUCATION AND TRAINING=
	0.5
	~	Dmnl
	~		|

MEDIUM INVESTMENT IN TOURISM=
	0.5
	~	Dmnl
	~		|

HIGH EDUCATION AND TRAINING=
	0.75
	~	Dmnl
	~		|

VERY HIGH INVESTMENT IN TOURISM=
	1
	~	Dmnl
	~		|

VERY HIGH EDUCATION AND TRAINING=
	1
	~	Dmnl
	~		|

SWITCH EDUCATION AND TRAINING INCREASE=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Population system', 'SWITCH_EDUCATION_AND_TRAINING_INCREASE*'\
		)
	~	Dmnl
	~		|

INVESTMENT IN TOURISM ADAPTATION AND RESILIENCE OBJECTIVE=
	IF THEN ELSE (SELECT INVESTMENT IN TOURISM ADAPTATION AND RESILIENCE = 0, LOW INVESTMENT IN TOURISM\
		,
	IF THEN ELSE (SELECT INVESTMENT IN TOURISM ADAPTATION AND RESILIENCE = 1, MEDIUM INVESTMENT IN TOURISM\
		,
	IF THEN ELSE (SELECT INVESTMENT IN TOURISM ADAPTATION AND RESILIENCE = 2, HIGH INVESTMENT IN TOURISM\
		,
	IF THEN ELSE (SELECT INVESTMENT IN TOURISM ADAPTATION AND RESILIENCE = 3, VERY HIGH INVESTMENT IN TOURISM\
		, LOW INVESTMENT IN TOURISM))))
	~	Dmnl
	~		|

VULNERABILITY=
	IF THEN ELSE(TOURISM SENSITIVITY*(1-ADAPTIVE CAPACITY)<0,0,TOURISM SENSITIVITY*(1-ADAPTIVE CAPACITY\
		))
	~	Dmnl
	~		|

VARIABILITY=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Tourism system', 'VARIABILITY*')
	~	Dmnl
	~		|

TOURISM EXPOSURE AND PROBABILITIES=
	(TCI WEIGHT IN EXPOSURE*((100-MEAN TCI)/100))+(WEIGHT OF EXTREME EVENTS IN EXPOSURE*\
		(NUMBER OF EXTREME EVENTS/365))
	~	Dmnl
	~		|

TOURISM SENSITIVITY=
	(CLIMATE DEPENDANCY+IMPACT PERCEPTION+VARIABILITY)/3
	~	Dmnl
	~		|

CLIMATE DEPENDANCY=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Tourism system', 'CLIMATE_DEPENDANCY*')
	~	Dmnl
	~		|

IMPACT PERCEPTION=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Tourism system', 'IMPACT_PERCEPTION*')
	~	Dmnl
	~		|

TOTAL IMPACT=
	TOURISM INCOME-IMPACT SINCE REFERENCE YEAR
	~	Million Euros
	~		|

IMPACT SINCE REFERENCE YEAR=
	DELAY FIXED( TOURISM INCOME, 1 , 1 )
	~	Million Euros
	~		|

NEW ROOMS=
	IF THEN ELSE( TOTAL ROOMS-ROOMS DELAY>0, TOTAL ROOMS-ROOMS DELAY , 0 )
	~	Rooms
	~		|

NUMBER OF ROOMS=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Tourism system', 'NUMBER_OF_ROOMS*')
	~	Rooms
	~		|

TCI INDEX SSP585[MONTHS]:INTERPOLATE::=
	GET DIRECT DATA ('Historical.xlsx', 'Tourism system', 'TCI_INDEX_SSP585_TIME', 'TCI_INDEX_SSP585'\
		)
	~	
	~		|

DISUSE=
	(BUILDING DETERIORATION RATE*INFRASTRUCTURE CAPACITY)+(EFFECTS OF EXTREME EVENTS*NUMBER OF EXTREME EVENTS\
		)
	~	Infrastructure
	~		|

TCI WEIGHT IN EXPOSURE=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Tourism system', 'TCI_WEIGHT_IN_EXPOSURE*'\
		)
	~	Dmnl
	~		|

BUILDING DETERIORATION RATE=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Tourism system', 'BUILDING_DETERIORATION_RATE*'\
		)
	~	Dmnl
	~		|

INFRASTRUCTURE CAPACITY= INTEG (
	NEW INFRASTRUCTURE-DISUSE,
		CAPACITY)
	~	Infrastructure
	~		|

INITIAL ATTRACTIVENESS=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Tourism system', 'TCI_WEIGHT_IN_EXPOSURE*'\
		)
	~	Dmnl
	~		|

NUMBER OF COLD WAVES:=
	GET DIRECT DATA ('Historical.xlsx', 'Tourism system', 'SSP585_HAZARDS_TIME', 'NUMBER_OF_COLD_WAVES'\
		)
	~	Days
	~		|

NUMBER OF DAYS WITH EXTREME PRECIPITATION:=
	GET DIRECT DATA ('Historical.xlsx', 'Tourism system', 'SSP585_HAZARDS_TIME', 'NUMBER_OF_DAYS_WITH_EXTREME_PRECIPITATION'\
		)
	~	Days
	~		|

EFFECTS OF EXTREME EVENTS=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Tourism system', 'EFFECTS_OF_EXTREME_EVENTS*'\
		)
	~	Dmnl
	~		|

NUMBER OF EXTREME EVENTS=
	NUMBER OF COLD WAVES+NUMBER OF DAYS WITH EXTREME PRECIPITATION+NUMBER OF DAYS WITH HIGH WINDS\
		+NUMBER OF HEATWAVES+NUMBER OF VERY HOT DAYS
	~	
	~		|

NUMBER OF HEATWAVES:=
	GET DIRECT DATA ('Historical.xlsx', 'Tourism system', 'SSP585_HAZARDS_TIME', 'NUMBER_OF_HEATWAVES'\
		)
	~	Number
	~		|

NUMBER OF DAYS WITH HIGH WINDS:=
	GET DIRECT DATA ('Historical.xlsx', 'Tourism system', 'SSP585_HAZARDS_TIME', 'NUMBER_OF_DAYS_WITH_HIGH_WINDS'\
		)
	~	Days
	~		|

HISTORICAL EXPENDITURE FOR INTERNATIONAL VISITORS=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Tourism system', 'HISTORICAL_EXPENDITURE_FOR_INTERNATIONAL_VISITORS*'\
		)
	~	Euros
	~		|

ATTRACTIVENESS FOR TOURISM= INTEG (
	ATTRACTIVENESS FOR TOURISM*CHANGE IN TOURISM ATTRACTION,
		INITIAL ATTRACTIVENESS)
	~	Dmnl
	~		|

NATIONAL EXPENDITURE= INTEG (
	NATIONAL EXPENDITURE INCREASE,
		HISTORICAL EXPENDITURE FOR NATIONAL VISITORS)
	~	Euros
	~		|

AVERAGE EXPENDITURE INCREASE=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Tourism system', 'AVERAGE_EXPENDITURE_INCREASE*'\
		)
	~	Dmnl
	~		|

TOURISM FACTOR=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Tourism system', 'TOURISM_FACTOR*')
	~	Tourist per room and day
	~		|

WEIGHT OF EXTREME EVENTS IN EXPOSURE=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Tourism system', 'WEIGHT_OF_EXTREME_EVENTS_IN_EXPOSURE*'\
		)
	~	Dmnl
	~		|

ROOMS DELAY= DELAY FIXED (
	TOTAL ROOMS, 1 , TOTAL ROOMS)
	~	Rooms
	~		|

CAPACITY=
	((NUMBER OF ROOMS*TOURISM FACTOR)/MEAN FACTOR OF USE)*365
	~	Tourists
	~		|

NATIONAL EXPENDITURE INCREASE=
	(NATIONAL EXPENDITURE * AVERAGE EXPENDITURE INCREASE) * (1 - (NATIONAL EXPENDITURE /\
		 900))
	~	Euros
	~	(NATIONAL EXPENDITURE * AVERAGE EXPENDITURE INCREASE) * (1 - (NATIONAL EXPENDITURE / \
		330))
		(NATIONAL EXPENDITURE * AVERAGE EXPENDITURE INCREASE) * (1 - (NATIONAL \
		EXPENDITURE / 680))
	|

CHANGE IN TOURISM ATTRACTION=
	1-(MEAN TCI/MEAN HISTORICAL TCI)
	~	Dmnl
	~		|

HISTORICAL EXPENDITURE FOR NATIONAL VISITORS=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Tourism system', 'HISTORICAL_EXPENDITURE_FOR_NATIONAL_VISITORS*'\
		)
	~	Euros
	~		|

NUMBER OF VERY HOT DAYS:=
	GET DIRECT DATA ('Historical.xlsx', 'Tourism system', 'SSP585_HAZARDS_TIME', 'NUMBER_OF_VERY_HOT_DAYS'\
		)
	~	Days
	~		|

MEAN FACTOR OF USE=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Tourism system', 'MEAN_FACTOR_OF_USE*')
	~	Dmnl
	~		|

INVESTMENT IN TOURISTIC INFRASTRUCTURE OBJECTIVES=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Tourism system', 'INVESTMENT_IN_INFRASTRUCTURE_OBJECTIVE*'\
		)
	~	Dmnl
	~		|

INTERNATIONAL EXPENDITURE= INTEG (
	INTERNATIONAL EXPENDITURE INCREASE,
		HISTORICAL EXPENDITURE FOR INTERNATIONAL VISITORS)
	~	Euros
	~		|

TOTAL ROOMS=
	INTEGER((INFRASTRUCTURE CAPACITY*MEAN FACTOR OF USE)/(TOURISM FACTOR*365)-NUMBER OF ROOMS\
		)
	~	Rooms
	~		|

INTERNATIONAL EXPENDITURE INCREASE=
	(INTERNATIONAL EXPENDITURE * AVERAGE EXPENDITURE INCREASE) * (1 - (INTERNATIONAL EXPENDITURE\
		 / 1600))
	~	Dmnl
	~		|

POPULATION DENSITY=
	CS POPULATION/TOTAL CS AREA
	~	Dmnl
	~		|

BIRTH RATE=
	BIRTHS/CS POPULATION
	~	Dmnl
	~		|

MONTHS:
	OCTOBER, NOVEMBER, DECEMBER, JANUARY, FEBRUARY, MARCH, APRIL, MAY, JUNE, JULY, AUGUST\
		, SEPTEMBER
	~	Month
	~		|

RATIO ENERGY POVERTY=
	POPULATION IN ENERGY POVERTY/CS POPULATION
	~	Dmnl
	~		|

"RATIO OF POPULATION <5"=
	POPULATION LOWER 5/CS POPULATION
	~	Dmnl
	~		|

"RATIO OF POPULATION >65"=
	POPULATION HIGHER 65/CS POPULATION
	~	Dmnl
	~		|

SENSITIVITY FROM DENSITY=
	IF THEN ELSE( POPULATION DENSITY>1000, 1 , IF THEN ELSE( 500<POPULATION DENSITY , 0.25\
		 , 0.5 ) )
	~	Dmnl
	~		|

MORTALITY RATE=
	DEATHS/CS POPULATION
	~	Dmnl
	~		|

EDUCATIONAL LEVEL=
	EDUCATED POPULATION/CS POPULATION
	~	Dmnl
	~		|

HEALTH SERVICES=
	ROOMS/CS POPULATION
	~	Dmnl
	~		|

DECREASE POPULATION SENSITIVITY=
	POPULATION ADAPTATION EFFICIENCY*(ADAPTATION FOR POPULATION)
	~	Dmnl
	~		|

SENSITIVITY FOR POPULATION=
	IF THEN ELSE(POPULATION BASELINE SENSITIVITY-DECREASE POPULATION SENSITIVITY > 1, 1,\
		 IF THEN ELSE(POPULATION BASELINE SENSITIVITY-DECREASE POPULATION SENSITIVITY < 0, \
		0, POPULATION BASELINE SENSITIVITY-DECREASE POPULATION SENSITIVITY))
	~	Dmnl
	~		|

MEDIUM BIOMASS=
	0.5
	~	Dmnl
	~		|

BIOMASS PERFORMANCE=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Energy', 'BIOMASS_PERFORMANCE*')
	~	Dmnl
	~		|

LIFETIME BIOMASS=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'ENERGY', 'LIFETIME_BIOMASS*')
	~	Year
	~		|

SWITCH BIOMASS CAPACITY=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'ENERGY', 'SWITCH_BIOMASS_CAPACITY*')
	~	Dmnl
	~		|

VERY HIGH BIOMASS=
	1
	~	Dmnl
	~		|

LOW BIOMASS=
	0.25
	~	Dmnl
	~		|

MINIMUM DECOMMISSIONING BIOMASS=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'ENERGY', 'MINIMUM_DECOMMISSIONING_BIOMASS*'\
		)
	~	Dmnl
	~		|

DELAY BIOMASS=
	DELAY FIXED(NEW BIOMASS CAPACITY*MINIMUM DECOMMISSIONING FOR NEW BIOMASS CAPACITY, LIFETIME BIOMASS\
		 , 0)
	~	MW
	~		|

DELAY BIOMASS INITIAL=
	DELAY FIXED(MINIMUM DECOMMISSIONING BIOMASS*BIOMASS CAPACITY, 5 ,0 )
	~	MW
	~		|

INITIAL BIOMASS CAPACITY=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'ENERGY', 'INITIAL_BIOMASS_CAPACITY*')
	~	MW
	~		|

BIOMASS ENERGY CONTENT=
	5
	~	MWh/ton
	~	GET DIRECT CONSTANTS ('Historical.xlsx', 'ENERGY', \
		'BIOMASS_ENERGY_CONTENT*')
	|

FINAL YEAR BIOMASS POLICY CAPACITY=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'ENERGY', 'FINAL_YEAR_BIOMASS_POLICY_CAPACITY*'\
		)
	~	Year
	~		|

BIOMASS CAPACITY= INTEG (
	NEW BIOMASS CAPACITY-DECOMMINSSIONING BIOMASS,
		INITIAL BIOMASS CAPACITY)
	~	MW
	~		|

INITIAL YEAR HYDRO POLICY CAPACITY=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'ENERGY', 'INITIAL_YEAR_HYDRO_POLICY_CAPACITY*'\
		)
	~	Year
	~		|

SWITCH HYDRO CAPACITY=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'ENERGY', 'SWITCH_HYDRO_CAPACITY*')
	~	Dmnl
	~		|

FINAL YEAR HYDRO POLICY CAPACITY=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'ENERGY', 'FINAL_YEAR_HYDRO_POLICY_CAPACITY*')
	~	Year
	~		|

ENERGY SHARE OBJECTIVES[TYPE OF ENERGY]=
	IF THEN ELSE(SELECT ENERGY SHARE=2,(BEST PROGRESS SCENARIO[TYPE OF ENERGY]),
	IF THEN ELSE(SELECT ENERGY SHARE=1,(GOOD PROGRESS SCENARIO[TYPE OF ENERGY]),
	IF THEN ELSE(SELECT ENERGY SHARE=0,(GRADUAL PROGRESS SCENARIO[TYPE OF ENERGY]),(GRADUAL PROGRESS SCENARIO\
		[TYPE OF ENERGY]))))
	~	Dmnl
	~		|

BIOMASS CAPACITY OBJECTIVE=
	IF THEN ELSE (SELECT BIOMASS INCENTIVES = 0, LOW BIOMASS*DESIRED OBJECTIVE FOR BIOMASS\
		,
	IF THEN ELSE (SELECT BIOMASS INCENTIVES = 1, MEDIUM BIOMASS*DESIRED OBJECTIVE FOR BIOMASS\
		,
	IF THEN ELSE (SELECT BIOMASS INCENTIVES = 2, HIGH BIOMASS*DESIRED OBJECTIVE FOR BIOMASS\
		,
	IF THEN ELSE (SELECT BIOMASS INCENTIVES = 3, VERY HIGH BIOMASS*DESIRED OBJECTIVE FOR BIOMASS\
		, LOW BIOMASS*DESIRED OBJECTIVE FOR BIOMASS))))
	~	MW
	~		|

SELECT BIOMASS INCENTIVES=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'ENERGY', 'SELECT_BIOMASS_INCENTIVES*')
	~	Dmnl
	~	0 = Low
		1 = Medium
		2 = High
		3 = Very High
	|

INITIAL YEAR BIOMASS POLICY CAPACITY=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'ENERGY', 'INITIAL_YEAR_BIOMASS_POLICY_CAPACITY*'\
		)
	~	Year
	~		|

HIGH BIOMASS=
	0.75
	~	Dmnl
	~		|

DECOMMINSSIONING BIOMASS=
	IF THEN ELSE(Time<(INITIAL TIME+LIFETIME BIOMASS), DELAY BIOMASS INITIAL, DELAY BIOMASS\
		)
	~	MW
	~		|

DESIRED OBJECTIVE FOR BIOMASS=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'ENERGY', 'INITIAL_OBJECTIVE_FOR_BIOMASS*')
	~	MW
	~		|

MINIMUM DECOMMISSIONING FOR NEW BIOMASS CAPACITY=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'ENERGY', 'MINIMUM_DECOMMISSIONING_FOR_NEW_BIOMASS_CAPACITY*'\
		)
	~	Dmnl
	~		|

ENERGY SUPPLY=
	PRODUCTION-LOSSES
	~	MWh
	~		|

LIFETIME HYDRO=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'ENERGY', 'LIFETIME_HYDRO*')
	~	Year
	~		|

LIFETIME NON RENEWABLE=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'ENERGY', 'LIFETIME_NON_RENEWABLE*')
	~	Year
	~		|

LIFETIME ROOFTOP=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'ENERGY', 'LIFETIME_ROOFTOP*')
	~	Year
	~		|

LIFETIME SOLAR=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'ENERGY', 'LIFETIME_SOLAR*')
	~	Year
	~		|

LIFETIME WIND=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'ENERGY', 'LIFETIME_WIND*')
	~	Year
	~		|

LOSSES=
	PRODUCTION*LOSSES FACTOR
	~	MWh
	~		|

LOSSES FACTOR=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Energy', 'LOSSES_FACTOR*')
	~	Dmnl
	~		|

DELAY HYDRO= DELAY FIXED (
	NEW HYDRO CAPACITY*MINIMUM DECOMMISSIONING FOR NEW HYDRO CAPACITY, LIFETIME HYDRO, 0\
		)
	~	MW
	~		|

LOW ENERGY EFFICIENCY=
	0.25
	~	Dmnl
	~		|

LOW ENERGY EMISSIONS DECREASE=
	0.2
	~	Dmnl
	~		|

LOW HYDRO=
	0.25
	~	Dmnl
	~		|

LOW ROOFTOP=
	0.25
	~	Dmnl
	~		|

BALANCE=
	ENERGY CONSUMPTION-ENERGY SUPPLY
	~	MWh
	~		|

LOW TAX=
	0.25
	~	Dmnl
	~		|

LOW WIND=
	0.25
	~	Dmnl
	~		|

BEST PROGRESS SCENARIO[TYPE OF ENERGY]=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Energy', 'BEST_PROGRESS_SCENARIO*')
	~	Dmnl
	~		|

NON RENEWABLE CAPACITY= INTEG (
	NEW NON RENEWABLE CAPACITY-DECOMMISSIONNING NON RENEWABLE,
		INITIAL NON RENEWABLE CAPACITY)
	~	MW
	~		|

CARBON EMISSIONS[TYPE OF ENERGY]=
	ENERGY EMISSION FACTORS[TYPE OF ENERGY]*ENERGY CONSUMPTION SHARE[TYPE OF ENERGY]
	~	tCO2
	~		|

SELECT HYDRO INCENTIVES=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'ENERGY', 'SELECT_HYDRO_INCENTIVES*')
	~	Dmnl
	~	 = Low
		1 = Medium
		2 = High
		3 = Very High
	|

MAX AREA ROOFTOP=
	10
	~	km2
	~		|

HIGH HYDRO=
	0.75
	~	Dmnl
	~		|

CS POPULATION= INTEG (
	 SMOOTH( GROWTH RATE , 2 ),
		INITIAL POPULATION)
	~	Inhabitants
	~		|

MAX POTENTIAL HYDRO=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'ENERGY', 'MAX_POTENTIAL_HYDRO*')
	~	MWh
	~		|

MAX POTENTIAL SOLAR=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'ENERGY', 'MAX_POTENTIAL_SOLAR*')
	~	MW/km2
	~		|

MAX POTENTIAL WIND=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'ENERGY', 'MAX_POTENTIAL_WIND*')
	~	MW
	~		|

DECOMMISSIONING HYDRO=
	IF THEN ELSE(Time<(INITIAL TIME+LIFETIME HYDRO), DELAY HYDRO INITIAL, DELAY HYDRO)
	~	MW
	~		|

DECOMMISSIONING ROOFTOP=
	IF THEN ELSE(Time<(INITIAL TIME+LIFETIME ROOFTOP), DELAY ROOFTOP INITIAL, DELAY ROOFTOP\
		)
	~	MW
	~		|

DECOMMISSIONING WIND=
	IF THEN ELSE(Time<(INITIAL TIME+LIFETIME WIND), DELAY WIND INITIAL, DELAY WIND)
	~	MW
	~		|

DECOMMISSIONNING NON RENEWABLE=
	IF THEN ELSE((NON RENEWABLE CAPACITY-NON RENEWABLE CAPACITY*0.2)<=0,0,IF THEN ELSE(SWITCH DECREASE NON RENEWABLE CAPACITY\
		=0,IF THEN ELSE(Time<(INITIAL TIME+LIFETIME NON RENEWABLE), DELAY NON RENEWABLE INITIAL\
		, DELAY NON RENEWABLE), IF THEN ELSE(SWITCH DECREASE NON RENEWABLE CAPACITY=1:AND:(\
		Time<INITIAL YEAR DECREASE NON RENEWABLE POLICY CAPACITY:OR:Time>FINAL YEAR DECREASE NON RENEWABLE POLICY CAPACITY\
		),IF THEN ELSE(Time<(INITIAL TIME+LIFETIME NON RENEWABLE),DELAY NON RENEWABLE INITIAL\
		, DELAY NON RENEWABLE),IF THEN ELSE(Time<(INITIAL TIME+LIFETIME NON RENEWABLE),IF THEN ELSE\
		(DELAY NON RENEWABLE INITIAL>(NON RENEWABLE CAPACITY OBJECTIVE/(FINAL YEAR DECREASE NON RENEWABLE POLICY CAPACITY\
		-INITIAL YEAR DECREASE NON RENEWABLE POLICY CAPACITY)),DELAY NON RENEWABLE INITIAL,\
		(NON RENEWABLE CAPACITY OBJECTIVE/(FINAL YEAR DECREASE NON RENEWABLE POLICY CAPACITY\
		-INITIAL YEAR DECREASE NON RENEWABLE POLICY CAPACITY))),IF THEN ELSE(DELAY NON RENEWABLE\
		>(NON RENEWABLE CAPACITY OBJECTIVE/(FINAL YEAR DECREASE NON RENEWABLE POLICY CAPACITY\
		-INITIAL YEAR DECREASE NON RENEWABLE POLICY CAPACITY)),DELAY NON RENEWABLE,(NON RENEWABLE CAPACITY OBJECTIVE\
		/(FINAL YEAR DECREASE NON RENEWABLE POLICY CAPACITY-INITIAL YEAR DECREASE NON RENEWABLE POLICY CAPACITY\
		)))))))
	~	MW
	~		|

DELAY WIND=
	DELAY FIXED(NEW WIND CAPACITY*MINIMUM DECOMMISSIONING FOR NEW WIND CAPACITY, LIFETIME WIND\
		 , 0)
	~	MW
	~		|

MEDIUM ENERGY EFFICIENCY=
	0.5
	~	Dmnl
	~		|

MEDIUM ENERGY EMISSIONS DECREASE=
	0.4
	~	Dmnl
	~		|

MEDIUM HYDRO=
	0.5
	~	Dmnl
	~		|

MEDIUM ROOFTOP=
	0.5
	~	Dmnl
	~		|

MEDIUM SOLAR=
	0.5
	~	Dmnl
	~		|

MEDIUM TAX=
	0.5
	~	Dmnl
	~		|

DEFICIT TO IMPORT=
	IF THEN ELSE(BALANCE>0,BALANCE,0)
	~	Million Euros
	~		|

VERY HIGH ENERGY EMISSIONS DECREASE=
	0.8
	~	Dmnl
	~		|

EXPORT=
	EXCEEDANCE TO EXPORT
	~	MWh
	~		|

MINIMUM DECOMMISSIONING FOR NEW HYDRO CAPACITY=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'ENERGY', 'MINIMUM_DECOMMISSIONING_FOR_NEW_HYDRO_CAPACITY*'\
		)
	~	Dmnl
	~		|

MINIMUM DECOMMISSIONING FOR NEW NON RENEWABLE CAPACITY=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'ENERGY', 'MINIMUM_DECOMMISSIONING_FOR_NEW_NON_RENEWABLE_CAPACITY*'\
		)
	~	Dmnl
	~		|

SWITCH ROOFTOP CAPACITY=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'ENERGY', 'SWITCH_ROOFTOP_CAPACITY*')
	~	Dmnl
	~		|

DESIRED ENERGY EFFICIENCY OBJECTIVE=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'ENERGY', 'INITIAL_EFFICIENCY_OBJECTIVE*')
	~	Dmnl
	~	GET DIRECT CONSTANTS ('Policy.xlsx', 'ENERGY', \
		'INITIAL_EFFICIENCY_OBJECTIVE*')
	|

DELAY HYDRO INITIAL=
	DELAY FIXED(HYDROPOWER CAPACITY*MINIMUM DECOMMISSIONING HYDRO, 5 , 0)
	~	MW
	~		|

DELAY NON RENEWABLE= DELAY FIXED (
	NEW NON RENEWABLE CAPACITY*MINIMUM DECOMMISSIONING FOR NEW NON RENEWABLE CAPACITY, LIFETIME NON RENEWABLE\
		, 0)
	~	MW
	~		|

DELAY NON RENEWABLE INITIAL=
	DELAY FIXED(NON RENEWABLE CAPACITY*MINIMUM DECOMMISSIONING NON RENEWABLE, 5 , 0)
	~	MW
	~		|

DELAY ROOFTOP=
	DELAY FIXED(NEW ROOFTOP CAPACITY*MINIMUM DECOMMISSIONING FOR NEW ROOFTOP CAPACITY, LIFETIME ROOFTOP\
		 , 0)
	~	MW
	~		|

DELAY ROOFTOP INITIAL=
	DELAY FIXED(MINIMUM DECOMMISSIONING ROOFTOP*ROOFTOP CAPACITY, 5 , 0)
	~	MW
	~		|

DELAY SOLAR=
	DELAY FIXED(NEW SOLAR CAPACITY*MINIMUM DECOMMISSIONING FOR NEW SOLAR CAPACITY , LIFETIME SOLAR\
		 , 0)
	~	MW
	~		|

DELAY SOLAR INITIAL=
	DELAY FIXED(SOLAR CAPACITY*MINIMUM DECOMMISSIONING SOLAR, 5, 0)
	~	MW
	~		|

DELAY WIND INITIAL=
	DELAY FIXED(WIND CAPACITY*MINIMUM DECOMMISSIONING WIND, 5 , 0)
	~	MW
	~		|

SELECT CARBON TAX=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'ENERGY', 'SELECT_CARBON_TAX*')
	~	Dmnl
	~	0 = Low
		1 = Medium
		2 = High
		3 = Very High
	|

NON RENEWABLE CAPACITY OBJECTIVE=
	IF THEN ELSE (SELECT CARBON TAX = 0, LOW TAX*DESIRED OBJECTIVE FOR DECREASE NON RENEWABLE CAPACITY\
		,
	IF THEN ELSE (SELECT CARBON TAX = 1, MEDIUM TAX*DESIRED OBJECTIVE FOR DECREASE NON RENEWABLE CAPACITY\
		,
	IF THEN ELSE (SELECT CARBON TAX = 2, HIGH TAX*DESIRED OBJECTIVE FOR DECREASE NON RENEWABLE CAPACITY\
		,
	IF THEN ELSE (SELECT CARBON TAX = 3, VERY HIGH TAX*DESIRED OBJECTIVE FOR DECREASE NON RENEWABLE CAPACITY\
		, LOW TAX*DESIRED OBJECTIVE FOR DECREASE NON RENEWABLE CAPACITY))))
	~	MW
	~		|

NON RENEWABLE PERFORMANCE=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'ENERGY', 'NON_RENEWABLE_PERFORMANCE*')
