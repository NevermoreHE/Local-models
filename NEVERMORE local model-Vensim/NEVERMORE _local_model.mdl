	IF THEN ELSE(SWITCH SOLAR CAPACITY=1:AND:(Time<INITIAL YEAR SOLAR POLICY CAPACITY:OR:\
		Time>FINAL YEAR SOLAR POLICY CAPACITY
	),0,MIN((SOLAR CAPACITY OBJECTIVE)/(FINAL YEAR SOLAR POLICY CAPACITY - INITIAL YEAR SOLAR POLICY CAPACITY\
		), MAX SOLAR CAPACITY-SOLAR CAPACITY)))
