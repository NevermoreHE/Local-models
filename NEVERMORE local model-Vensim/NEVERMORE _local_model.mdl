		)
	~	MW
	~	GET DIRECT CONSTANTS ('Historical.xlsx', 'ENERGY', \
		'INCREASE_NON_RENEWABLE_CAPACITY*')
	|

VERY HIGH HYDRO=
	1
	~	Dmnl
	~		|

INITIAL WIND CAPACITY=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'ENERGY', 'INITIAL_WIND_CAPACITY*')
	~	MW
	~		|

ENERGY EFFICIENCY OBJECTIVE=
	IF THEN ELSE (SELECT ENERGY EFFICIENCY INCENTIVES = 0, LOW ENERGY EFFICIENCY*DESIRED ENERGY EFFICIENCY OBJECTIVE\
		,
	IF THEN ELSE (SELECT ENERGY EFFICIENCY INCENTIVES = 1, MEDIUM ENERGY EFFICIENCY*DESIRED ENERGY EFFICIENCY OBJECTIVE\
		,
	IF THEN ELSE (SELECT ENERGY EFFICIENCY INCENTIVES = 2, HIGH ENERGY EFFICIENCY*DESIRED ENERGY EFFICIENCY OBJECTIVE\
		,
	IF THEN ELSE (SELECT ENERGY EFFICIENCY INCENTIVES = 3, VERY HIGH ENERGY EFFICIENCY*DESIRED ENERGY EFFICIENCY OBJECTIVE\
		, LOW ENERGY EFFICIENCY*DESIRED ENERGY EFFICIENCY OBJECTIVE))))
	~	Dmnl
	~		|

ENERGY EMISSION FACTORS[TYPE OF ENERGY]=
	IF THEN ELSE( SWITCH INCENTIVE FOR ENERGY EMISSIONS DECREASE=0,INITIAL ENERGY EMISSION FACTORS\
		[TYPE OF ENERGY],
	IF THEN ELSE(SWITCH INCENTIVE FOR ENERGY EMISSIONS DECREASE=1:AND:(Time<INITIAL YEAR INCENTIVE FOR ENERGY EMISSIONS DECREASE\
		),INITIAL ENERGY EMISSION FACTORS[TYPE OF ENERGY],IF THEN ELSE(SWITCH INCENTIVE FOR ENERGY EMISSIONS DECREASE\
		=1:AND:(Time>FINAL YEAR INCENTIVE FOR ENERGY EMISSIONS DECREASE),INITIAL ENERGY EMISSION FACTORS\
		[TYPE OF ENERGY]-(ENERGY EMISSIONS DECREASE INCENTIVES[TYPE OF ENERGY]),(INITIAL ENERGY EMISSION FACTORS\
		[TYPE OF ENERGY]-((ENERGY EMISSIONS DECREASE INCENTIVES[TYPE OF ENERGY])*(Time-INITIAL YEAR INCENTIVE FOR ENERGY EMISSIONS DECREASE\
		))/(FINAL YEAR INCENTIVE FOR ENERGY EMISSIONS DECREASE-INITIAL YEAR INCENTIVE FOR ENERGY EMISSIONS DECREASE\
		)))))
	~	tCO2/MWh
	~		|

ENERGY EMISSIONS DECREASE INCENTIVES[TYPE OF ENERGY]=
	IF THEN ELSE (SELECT INCENTIVE FOR ENERGY EMISSIONS DECREASE = 3, VERY HIGH ENERGY EMISSIONS DECREASE\
		*INITIAL ENERGY EMISSION FACTORS[TYPE OF ENERGY],
	IF THEN ELSE (SELECT INCENTIVE FOR ENERGY EMISSIONS DECREASE = 2, HIGH ENERGY EMISSIONS DECREASE\
		*INITIAL ENERGY EMISSION FACTORS[TYPE OF ENERGY],
	IF THEN ELSE (SELECT INCENTIVE FOR ENERGY EMISSIONS DECREASE = 1, MEDIUM ENERGY EMISSIONS DECREASE\
		*INITIAL ENERGY EMISSION FACTORS[TYPE OF ENERGY],
	IF THEN ELSE (SELECT INCENTIVE FOR ENERGY EMISSIONS DECREASE = 0, LOW ENERGY EMISSIONS DECREASE\
		*INITIAL ENERGY EMISSION FACTORS[TYPE OF ENERGY], LOW ENERGY EMISSIONS DECREASE*INITIAL ENERGY EMISSION FACTORS\
		[TYPE OF ENERGY]))))
	~	Dmnl
	~		|

ENERGY CONSUMPTION SHARE[TYPE OF ENERGY]=
	IF THEN ELSE( SWITCH ENERGY SHARE POLICY=0,INITIAL ENERGY SHARE[TYPE OF ENERGY]*ENERGY CONSUMPTION\
		,
	IF THEN ELSE(SWITCH ENERGY SHARE POLICY=1:AND:(Time<INITIAL YEAR ENERGY SHARE POLICY\
		),INITIAL ENERGY SHARE[TYPE OF ENERGY
	]*ENERGY CONSUMPTION,ENERGY SHARE OBJECTIVES[TYPE OF ENERGY]*ENERGY CONSUMPTION))
	~	Dmnl
	~		|

HIGH TAX=
	0.75
	~	Dmnl
	~		|

