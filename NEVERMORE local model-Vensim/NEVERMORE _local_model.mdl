	~	Dmnl
	~		|

INITIAL ENERGY SHARE[TYPE OF ENERGY]=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'ENERGY', 'INITIAL_ENERGY_SHARE*')
	~	Dmnl
	~		|

INITIAL ROOFTOP CAPACITY=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'ENERGY', 'INITIAL_ROOFTOP_CAPACITY*')
	~	MW
	~		|

INITIAL SOLAR CAPACITY=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'ENERGY', 'INITIAL_SOLAR_CAPACITY*')
	~	MW
	~		|

PRODUCTION=
	TOTAL PRODUCTION
	~	MWh
	~		|

INITIAL NON RENEWABLE CAPACITY=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'ENERGY', 'INITIAL_NON_RENEWABLE_CAPACITY*'\
		)
	~	MW
	~		|

ROOFTOP PERFORMANCE=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'ENERGY', 'ROOFTOP_PERFORMANCE*')
	~	Dmnl
	~		|

VERY HIGH ROOFTOP=
	1
	~	Dmnl
	~		|

SWITCH DECREASE NON RENEWABLE CAPACITY=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'ENERGY', 'SWITCH_NON_RENEWABLE_CAPACITY*')
	~	Dmnl
	~	GET DIRECT CONSTANTS ('Policy.xlsx', 'ENERGY', \
		'SWITCH_NON_RENEWABLE_CAPACITY*')
	|

INITIAL YEAR ENERGY EFFICIENCY INCREASE=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'ENERGY', 'INITIAL_YEAR_EFFICIENCY_INCREASE*')
	~	Year
	~	GET DIRECT CONSTANTS ('Policy.xlsx', 'ENERGY', \
		'INITIAL_YEAR_EFFICIENCY_INCREASE*')
	|

INITIAL YEAR ENERGY SHARE POLICY=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'ENERGY', 'INITIAL_YEAR_ENERGY_SHARE_POLICY*')
	~	Year
	~	GET DIRECT CONSTANTS ('Policy.xlsx', 'ENERGY', \
		'INITIAL_YEAR_ENERGY_SHARE_POLICY*')
	|

VERY HIGH WIND=
	1
	~	Dmnl
	~		|

SWITCH WIND CAPACITY=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'ENERGY', 'SWITCH_WIND_CAPACITY*')
	~	Dmnl
	~		|

SOLAR CAPACITY= INTEG (
	NEW SOLAR CAPACITY-SOLAR DECOMMISSIONING,
		INITIAL SOLAR CAPACITY)
	~	MW
	~		|

MINIMUM DECOMMISSIONING NON RENEWABLE=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'ENERGY', 'MINIMUM_DECOMMISSIONING_NON_RENEWABLE*'\
		)
	~	Dmnl
	~		|

INITIAL HYDRO CAPACITY=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'ENERGY', 'INITIAL_HYDRO_CAPACITY*')
	~	MW
	~		|

INITIAL YEAR ROOFTOP POLICY CAPACITY=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'ENERGY', 'INITIAL_YEAR_ROOFTOP_POLICY_CAPACITY*'\
		)
	~	Year
	~		|

INITIAL YEAR SOLAR POLICY CAPACITY=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'ENERGY', 'INITIAL_YEAR_SOLAR_POLICY_CAPACITY*'\
		)
	~	Year
	~	GET DIRECT CONSTANTS ('Policy.xlsx', 'ENERGY', \
		'INITIAL_YEAR_SOLAR_POLICY_CAPACITY*')
	|

INITIAL YEAR WIND POLICY CAPACITY=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'ENERGY', 'INITIAL_YEAR_WIND_POLICY_CAPACITY*')
	~	Year
	~		|

WIND PERFORMANCE=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'ENERGY', 'WIND_PERFORMANCE*')
	~	Dmnl
	~		|

SELECT WIND INCENTIVES=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'ENERGY', 'SELECT_WIND_INCENTIVES*')
	~	Dmnl
	~	0 = Low
		1 = Medium
		2 = High
		3 = Very High
	|

VERY HIGH TAX=
	1
	~	Dmnl
	~		|

SOLAR PRODUCTION=
	SOLAR CAPACITY*SOLAR PERFORMANCE*HOURS IN A YEAR
	~	MWh
	~		|

MINIMUM DECOMMISSIONING HYDRO=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'ENERGY', 'MINIMUM_DECOMMISSIONING_HYDRO*')
	~	Dmnl
	~		|

TOTAL CARBON EMISSIONS FROM ENERGY=
	SUM(CARBON EMISSIONS[TYPE OF ENERGY!])
	~	tCO2
	~		|

MINIMUM DECOMMISSIONING WIND=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'ENERGY', 'MINIMUM_DECOMMISSIONING_WIND*')
	~	Dmnl
	~		|

VERY HIGH SOLAR=
	1
	~	Dmnl
	~		|

INITIAL YEAR INCENTIVE FOR ENERGY EMISSIONS DECREASE=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'ENERGY', 'INITIAL_YEAR_INCENTIVE_EMISSIONS*')
	~	Year
	~		|

INITIAL YEAR DECREASE NON RENEWABLE POLICY CAPACITY=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'ENERGY', 'INITIAL_YEAR_NON_RENEWABLE_POLICY_CAPACITY*'\
		)
	~	Year
	~		|

SOLAR PERFORMANCE=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'ENERGY', 'SOLAR_PERFORMANCE*')
	~	Dmnl
	~		|

WIND CAPACITY= INTEG (
	NEW WIND CAPACITY-DECOMMISSIONING WIND,
		INITIAL WIND CAPACITY)
	~	MW
	~		|

SELECT INCENTIVE FOR ENERGY EMISSIONS DECREASE=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'ENERGY', 'SELECT_EMISSIONS_DECREASE*')
	~	Dmnl
	~	0 = Low
		1 = Medium
		2 = High
		3 = Very High
		GET DIRECT CONSTANTS ('Policy.xlsx', 'ENERGY', \
		'SELECT_EMISSIONS_DECREASE*')
	|

WIND CAPACITY OBJECTIVE=
	IF THEN ELSE (SELECT WIND INCENTIVES = 0, LOW WIND*DESIRED OBJECTIVE FOR WIND,
	IF THEN ELSE (SELECT WIND INCENTIVES = 1, MEDIUM WIND*DESIRED OBJECTIVE FOR WIND,
	IF THEN ELSE (SELECT WIND INCENTIVES = 2, HIGH WIND*DESIRED OBJECTIVE FOR WIND,
	IF THEN ELSE (SELECT WIND INCENTIVES = 3, VERY HIGH WIND*DESIRED OBJECTIVE FOR WIND,\
		 LOW WIND*DESIRED OBJECTIVE FOR WIND))))
	~	MW
	~		|

MINIMUM DECOMMISSIONING SOLAR=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'ENERGY', 'MINIMUM_DECOMMISSIONING_SOLAR*')
	~	Dmnl
	~		|

POPULATION AT RISK=
	(EXPOSED POPULATION/CS POPULATION)*HEATWAVES PROBABILITY
	~	Dmnl
	~		|

SOLAR DECOMMISSIONING=
	IF THEN ELSE(Time<(INITIAL TIME+LIFETIME SOLAR), DELAY SOLAR INITIAL, DELAY SOLAR)
	~	MW
	~		|

TYPE OF ENERGY:
	COAL, GAS, OIL, RENEWABLES
	~	Type of energy
	~		|

TYPE OF RENEWABLES:
	SOLAR, WIND, ROOFTOP, BIOMASS, HYDRO
	~	Type of renewable
	~		|

RAINFED RATIO=
	RAINFED CROP AREA/AGRICULTURE
	~	Dmnl
	~		|

TOTAL CS AREA=
	AGRICULTURE+FOREST+OTHER+URBAN+WATER+WETLANDS
	~	km2
	~		|

DECREASE IN CROP SENSITIVTY=
	(1-ADAPTATION EFFICIENCY)*CROPS ADAPTATION
	~	Dmnl
	~		|

INCREASE EXPOSED CROPS=
	EXPOSED CROP RATE
	~	km2
	~	IF THEN ELSE(EXPOSED CROPS<AGRICULTURE*0.995, MIN(CROP RATE*EXPOSED CROPS, \
		AGRICULTURE*CROP RATE),0)
	|

IRRIGATED RATIO=
	IRRIGATED CROP AREA/AGRICULTURE
	~	Dmnl
	~		|

CROPS SENSITIVITY=
	IF THEN ELSE(SENSITIVITY-DECREASE IN CROP SENSITIVTY > 1, 1, IF THEN ELSE(SENSITIVITY\
		-DECREASE IN CROP SENSITIVTY < 0, 0, SENSITIVITY-DECREASE IN CROP SENSITIVTY))
	~	Dmnl
	~	IF THEN ELSE(SENSITIVITY-DECREASE IN CROP SENSITIVTY > 1, 1, IF THEN \
		ELSE(SENSITIVITY-DECREASE IN CROP SENSITIVTY < 0, 0, SENSITIVITY-DECREASE \
		IN CROP SENSITIVTY))
	|

NORMALIZED PERCENTAGE[CROPS I]=
	CROP DISTRIBUTION[CROPS I]/SUM(CROP DISTRIBUTION[CROPS I!])
	~	Dmnl
	~		|

INITIAL DIVERSIFICATION=
	1-(SUM(NORMALIZED PERCENTAGE[CROPS I!]^2))
	~	Dmnl
	~		|

CROPS IN RISK=
	(EXPOSED CROPS/AGRICULTURE)*DROUGHT PROBABILITY
	~	Dmnl
	~		|

CROP DISTRIBUTION[CROPS I]=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Crop system', 'CROP_DISTRIBUTION*')
	~	Dmnl
	~		|

HIGH AFFORESTATION POLICY=
	0.75
	~	Dmnl
	~		|

AFFORESTATION=
	AGRICULTURE*AFFORESTATION RATIO*SUBSIDES FOR AFFORESTATION
	~	km2
	~		|

AFFORESTATION RATIO=
	IF THEN ELSE(SWITCH AFFORESTATION POLICY=0,0.0001,IF THEN ELSE(SWITCH AFFORESTATION POLICY\
		=1:AND:(Time<INITIAL YEAR FOR AFFORESTATION POLICY:OR:Time>FINAL YEAR FOR AFFORESTATION POLICY\
		),0.0001,0.001))
	~	Dmnl
	~		|

AFFORESTATION SUBSIDES=
	IF THEN ELSE (SELECT AFFORESTATION POLICY = 0, LOW AFFORESTATION POLICY,
	IF THEN ELSE (SELECT AFFORESTATION POLICY = 1, MEDIUM AFFORESTATION POLICY,
	IF THEN ELSE (SELECT AFFORESTATION POLICY = 2, HIGH AFFORESTATION POLICY,
	IF THEN ELSE (SELECT AFFORESTATION POLICY = 3, VERY HIGH AFFORESTATION POLICY, LOW AFFORESTATION POLICY\
		))))
	~	Dmnl
	~	Valor entre 0 y 1
	|

AGRICULTURAL DEMAND RATIO=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Land system', 'AGRICULTURAL_DEMAND_RATIO*'\
		)
	~	Dmnl
	~		|

MEDIUM AFFORESTATION POLICY=
	0.5
	~	Dmnl
	~		|

VERY HIGH AFFORESTATION POLICY=
	1
	~	Dmnl
	~		|

INCREASE OBJECTIVE FOR PROTECTED FOREST LAND=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Land system', 'INCREASE_OBJECTIVE_FOR_FOREST_PROTECTED_LAND*'\
		)
	~	km2
	~		|

INITIAL FOREST PROTECTED LAND=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Land system', 'INITIAL_PROTECTED_FOREST_AREA*'\
		)
	~	km2
	~		|

SUBSIDES FOR AFFORESTATION=
	IF THEN ELSE( SWITCH AFFORESTATION POLICY=0,0.0001,IF THEN ELSE(SWITCH AFFORESTATION POLICY\
		=1:AND:(Time<INITIAL YEAR FOR AFFORESTATION POLICY:OR:Time>FINAL YEAR FOR AFFORESTATION POLICY\
		),0.0001,AFFORESTATION SUBSIDES))
	~	Dmnl
	~		|

FINAL YEAR FOR AFFORESTATION POLICY=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Land system', 'FINAL_YEAR_FOR_AFFORESTATION_POLICY*'\
		)
	~	Year
	~		|

SELECT AFFORESTATION POLICY=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Land system', 'SELECT_AFFORESTATION_POLICY*')
	~	Dmnl
	~		|

LOW AFFORESTATION POLICY=
	0.25
	~	Dmnl
	~		|

INITIAL YEAR FOR AFFORESTATION POLICY=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Land system', 'INITIAL_YEAR_FOR_AFFORESTATION_POLICY*'\
		)
	~	Year
	~		|

FINAL YEAR FOR PROTECTED FOREST LAND=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Land system', 'FINAL_YEAR_FOR_FOREST_PROTECTED_LAND*'\
		)
	~	Year
	~		|

SWITCH AFFORESTATION POLICY=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Land system', 'SWITCH_AFFORESTATION_POLICY*')
	~	Dmnl
	~		|

SWITCH PROTECTED FOREST LAND=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Land system', 'SWITCH_FOREST_PROTECTED_LAND*')
	~	Dmnl
	~		|

INITIAL YEAR FOR PROTECTED FOREST LAND=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Land system', 'INITIAL_YEAR_FOR_FOREST_PROTECTED_LAND*'\
		)
	~	Year
	~		|

ACCESIBILITY RESTRICTION=
	EXP(-0.5*DISTANCE)
	~	Dmnl
	~	\!km\!dmnl
	|

CONVERSION SPEED WETLANDS TO URBAN=
	IF THEN ELSE( (WETLANDS-PROTECTED WETLANDS NOT CORRECTED)/((WETLANDS-PROTECTED WETLANDS NOT CORRECTED\
		)+URBAN)>0 , (WETLANDS-PROTECTED WETLANDS NOT CORRECTED)/((WETLANDS-PROTECTED WETLANDS NOT CORRECTED\
		)+URBAN), 0 )
	~	Dmnl
	~		|

DISTANCE=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Land system', 'DISTANCE*')
	~	km
	~		|

PERCENTAGE OF PROTECTED LAND=
	PROTECTED FOREST LAND NOT CORRECTED/FOREST
	~	Dmnl
	~		|

ENVIRONMENTAL RESTRICTION=
	EXP(-0.8*PERCENTAGE OF PROTECTED LAND)
	~	Dmnl
	~		|

AGRICULTURAL EXPANSION=
	AGRICULTURAL DEMAND RATIO*ENVIRONMENTAL RESTRICTION*AVAILABLE FOREST LAND
	~	km2
	~		|

AGRICULTURAL PRESSURE=
	IF THEN ELSE( AVAILABLE LAND>0 , (AGRICULTURAL DEMAND RATIO/AVAILABLE LAND), 0 )
	~	Dmnl
	~		|

CONVERSION SPEED=
	IF THEN ELSE( (OTHER/(OTHER+URBAN))>0 , OTHER/(OTHER+URBAN) , 0 )
	~	Dmnl
	~		|

EXPANSION RATIO=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Land system', 'EXPANSION_RATIO*')
	~	Dmnl
	~		|

FOREST= INTEG (
	AFFORESTATION-AGRICULTURAL EXPANSION-FOREST TO WATER,
		INITIAL FOREST AREA)
	~	km2
	~		|

INITIAL AGRICULTURAL AREA=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Land system', 'INITIAL_AGRICULTURAL_AREA*'\
		)
	~	km2
	~		|

INITIAL FOREST AREA=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Land system', 'INITIAL_FOREST_AREA*')
	~	km2
	~		|

INITIAL OTHER AREA=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Land system', 'INITIAL_OTHER_AREA*')
	~	km2
	~		|

INITIAL URBAN AREA=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Land system', 'INITIAL_URBAN_AREA*')
	~	km2
	~		|

INITIAL WATER AREA=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Land system', 'INITIAL_WATER_AREA*')
	~	km2
	~		|

INITIAL WETLANDS AREA=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Land system', 'INITIAL_WETLANDS_AREA*')
	~	km2
	~		|

POPULATION ADAPTATION BASELINE=
	IF THEN ELSE( GDP PER CAPITA>1, (1+EDUCATIONAL LEVEL)/2 , (EDUCATIONAL LEVEL+GDP PER CAPITA\
		)/2 )
	~	Dmnl
	~	(EDUCATIONAL LEVEL+PIB PER CAPITA)/2
	|

POPULATION ADAPTATION CAPACITY= INTEG (
	INCREASE IN POPULATION ADAPTATION CAPACITY-DECREASE IN POPULATION ADAPTATION CAPACITY\
		,
		POPULATION ADAPTATION BASELINE)
	~	Dmnl
	~		|

ADAPTATION DECAY RATE 1=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', 'ADAPTATION_DECAY_RATE_1*'\
		)
	~	Dmnl
	~		|

ADAPTATION FOR POPULATION=
	POPULATION ADAPTATION CAPACITY*POP ADJUSTED RATIO
	~	Dmnl
	~		|

DELADAPTATION INVESTMENT RATE=
	0.01
	~	Dmnl
	~		|

RISK INDEX POPULATION=
	SMOOTH(IF THEN ELSE((SENSITIVITY FOR POPULATION-ADAPTATION FOR POPULATION)<0,0,IF THEN ELSE\
		((POPULATION AT RISK*(SENSITIVITY FOR POPULATION-ADAPTATION FOR POPULATION))>1,1,POPULATION AT RISK\
		*(SENSITIVITY FOR POPULATION-ADAPTATION FOR POPULATION))), 2)
	~	Dmnl
	~		|

POPULATION EXPOSED GROWTH:INTERPOLATE::=
	GET DIRECT DATA ('Historical.xlsx', 'Population system', 'POPULATION_EXPOSED_GROWTH_TIME'\
		, 'POPULATION_EXPOSED_GROWTH')
	~	Dmnl
	~		|

POP ADJUSTED RATIO=
	IF THEN ELSE( POP RATIO>1, 1 , POP RATIO )
	~	Dmnl
	~		|

POPULATION ADAPTATION EFFICIENCY=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', 'POPULATION_ADAPTATION_EFFICIENCY*'\
		)
	~	Dmnl
	~		|

DECREASE IN POPULATION ADAPTATION CAPACITY=
	POPULATION ADAPTATION CAPACITY*ADAPTATION DECAY RATE 1
	~	Dmnl
	~		|

HEATWAVES PROBABILITY=
	IF THEN ELSE (SELECT HEATWAVES PROBABILITIES = 0, SSP245 HEATWAVES,
	IF THEN ELSE (SELECT HEATWAVES PROBABILITIES = 1, SSP585 HEATWAVES, 1))
	~	Dmnl
	~		|

IMPACT IN POPULATION=
	IF THEN ELSE(RISK INDEX POPULATION > 0.7, 0.1*VULNERABLE POPULATION, 
	IF THEN ELSE(RISK INDEX POPULATION < 0.1, 0.02*VULNERABLE POPULATION, 
	0.05*VULNERABLE POPULATION))
	~	Deaths
	~		|

SELECT HEATWAVES PROBABILITIES=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Population system', 'SELECT_HEAT_WAVES_PROBABILITIES*'\
		)
	~	Dmnl
	~	0 = SSP245
		1 = SSP585
	|

POP RATIO=
	1/POPULATION ADAPTATION CAPACITY
	~	Dmnl
	~		|

SSP245 HEATWAVES=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', 'SSP245_HEATWAVES*')
	~	Dmnl
	~		|

SSP585 HEATWAVES=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Population system', 'SSP585_HEATWAVES*')
	~	Dmnl
	~		|

INCREASE EXPOSED POPULATION=
	POPULATION EXPOSED GROWTH
	~	Inhabitants
	~		|

VULNERABLE POPULATION=
	POPULATION LOWER 5+POPULATION HIGHER 65
	~	Inhabitants
	~		|

SSP585 DROUGHTS=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Crop system','SSP585_DROUGHTS*')
	~	Dmnl
	~		|

DROUGHT PROBABILITY=
	IF THEN ELSE (SELECT DROUGHTS PROBABILITIES = 0, SSP245 DROUGHTS,
	IF THEN ELSE (SELECT DROUGHTS PROBABILITIES = 1, SSP585 DROUGHTS, 1))
	~	Dmnl
	~		|

FINAL PRODUCTION[CROPS I]=
	BASELINE PRODUCTION[CROPS I]-IMPACT IN PRODUCTION[CROPS I]
	~	kg/ha·year
	~		|

SSP245 DROUGHTS=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Crop system', 'SSP245_DROUGHTS*')
	~	Dmnl
	~		|

SELECT DROUGHTS PROBABILITIES=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Crop system', 'SELECT_DROUGHTS_PROBABILITIES*'\
		)
	~	Dmnl
	~	0 = SSP245
		1 = SSP585
	|

INCREASE IN DIVERSIFICATION LEVEL=
	IF THEN ELSE(SWITCH CROP DIVERSIFICATION=0,0,IF THEN ELSE(SWITCH CROP DIVERSIFICATION\
		=1:AND:(Time<INITIAL YEAR FOR CROP DIVERSIFICATION:OR:Time>FINAL YEAR FOR CROP DIVERSIFICATION\
		),0,(DIVERSIFICATION OBJECTIVE)/(FINAL YEAR FOR CROP DIVERSIFICATION-INITIAL YEAR FOR CROP DIVERSIFICATION\
		)))
	~	Dmnl
	~		|

FINAL YEAR FOR CROP ADAPTATION BUDGET=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Crop system', 'FINAL_YEAR_FOR_CROP_ADAPTATION_BUDGET*'\
		)
	~	Year
	~		|

FINAL YEAR FOR CROP DIVERSIFICATION=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Crop system', 'FINAL_YEAR_FOR_CROP_DIVERSIFICATION*'\
		)
	~	Dmnl
	~		|

INITIAL YEAR FOR CROP ADAPTATION BUDGET=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Crop system', 'INITIAL_YEAR_FOR_CROP_ADAPTATION_BUDGET*'\
		)
	~	Year
	~		|

SWITCH CROP DIVERSIFICATION=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Crop system', 'SWITCH_CROP_DIVERSIFICATION*')
	~	Dmnl
	~	1 = ACTIVO
		0 = DESACTIVO
	|

ASIGNED BUDGET=
	IF THEN ELSE( SWITCH ADAPTATION BUDGET=0,0,IF THEN ELSE(SWITCH ADAPTATION BUDGET=1:AND:\
		(Time<INITIAL YEAR FOR CROP ADAPTATION BUDGET:OR:Time>FINAL YEAR FOR CROP ADAPTATION BUDGET
	),0,(INVESTMENT OBJECTIVE IN CROP ADAPTATION
	)/(FINAL YEAR FOR CROP ADAPTATION BUDGET-INITIAL YEAR FOR CROP ADAPTATION BUDGET)))
	~	Million Euros
	~		|

DIVERSIFICATION OBJECTIVE=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Crop system', 'DIVERSIFICATION_OBJECTIVE*')
	~	Dmnl
	~	Valor entre 0 y 1. Mejor cuanto más cerca de 1
	|

SWITCH ADAPTATION BUDGET=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Crop system', 'SWITCH_ADAPTATION_BUDGET*')
	~	Dmnl
	~	1 = ACTIVO
		0 = DESACTIVO
		GET DIRECT CONSTANTS ('Policy.xlsx', 'Crop system', \
		'SWITCH_ADAPTATION_BUDGET*')
	|

INITIAL YEAR FOR CROP DIVERSIFICATION=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Crop system', 'INITIAL_YEAR_FOR_CROP_DIVERSIFICATION*'\
		)
	~	Year
	~		|

INVESTMENT OBJECTIVE IN CROP ADAPTATION=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Crop system', 'INVESTMENT_OBJECTIVE_IN_CROP_ADAPTATION*'\
		)
	~	Million Euros
	~	GET DIRECT CONSTANTS ('Policy.xlsx', 'Crop system', \
		'INVESTMENT_OBJECTIVE_IN_CROP_ADAPTATION*')
	|

FINAL DIVERSIFICATION=
	IF THEN ELSE(DIVERSIFICATION LEVEL > 1, 1, IF THEN ELSE(DIVERSIFICATION LEVEL < 0, 0\
		, DIVERSIFICATION LEVEL))
	~	Dmnl
	~		|

SENSITIVITY=
	BASELINE SENSITIVITY*(1-(DIVERSIFICATION EFFICIENCY*FINAL DIVERSIFICATION))+BASELINE SENSITIVITY
	~	Dmnl
	~		|

RISK INDEX CROPS=
	SMOOTH(IF THEN ELSE(((CROPS IN RISK+(-1*CROPS ADAPTATION)+CROPS SENSITIVITY)/3)>1,1,\
		IF THEN ELSE(((CROPS IN RISK+(-1*CROPS ADAPTATION)+CROPS SENSITIVITY)/3)<0,0,(CROPS IN RISK\
		+(-1*CROPS ADAPTATION)+CROPS SENSITIVITY)/3)), 2)
	~	Dmnl
	~		|

CROP ADAPTATION CAPACITY= INTEG (
	INCREASE IN ADAPTATION CAPACITY-DECREASE IN ADAPTATION CAPACITY,
		0.5)
	~	Dmnl
	~		|

IMPACT IN PRODUCTION[CROPS I]=
	IF THEN ELSE(RISK INDEX CROPS > 0.7, 0.25*BASELINE PRODUCTION[CROPS I], 
	IF THEN ELSE(RISK INDEX CROPS < 0.1, 0.05*BASELINE PRODUCTION[CROPS I],
	0.15*BASELINE PRODUCTION[CROPS I]))
	~	kg/ha·year
	~		|

CROPS ADAPTATION=
	CROP ADAPTATION CAPACITY*ADJUSTED RATIO
	~	Dmnl
	~		|

ADJUSTED RATIO=
	IF THEN ELSE( RATIO>1, 1 , RATIO )
	~	Dmnl
	~		|

DECREASE IN ADAPTATION CAPACITY=
	CROP ADAPTATION CAPACITY*DECAY RATE 1
	~	Dmnl
	~		|

RATIO=
	1/CROP ADAPTATION CAPACITY
	~	Dmnl
	~		|

DIVERSIFICATION LEVEL= INTEG (
	INCREASE IN DIVERSIFICATION LEVEL-DECREASE IN DIVERSIFICATION LEVEL,
		INITIAL DIVERSIFICATION)
	~	Dmnl
	~		|

CROPS I:
	CEREALS, VEGETABLES, FRUITS AND NUTS, OILSEED CROPS, ROOTS AND TUBERS, BEVERAGE AND SPICE CROPS\
		, LEGUMINOUS CROPS, SUGAR CROPS, OTHER CROPS
	~	Crops
	~		|

BASELINE SENSITIVITY=
	(IRRIGATED RATIO+IRRIGATED VS RAINFED+RAINFED RATIO+"WATER-CROP RATIO")/4
	~	Dmnl
	~		|

IRRIGATED VS RAINFED=
	IF THEN ELSE(RAINFED CROP AREA=0,1,IF THEN ELSE(IRRIGATED CROP AREA/RAINFED CROP AREA\
		>1,1,IRRIGATED CROP AREA/RAINFED CROP AREA))
	~	Dmnl
	~		|

ADAPTATION EFFICIENCY=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Crop system', 'ADAPTATION_EFFICIENCY*')
	~	Dmnl
	~		|

ADAPTATION INVESTMENT RATE=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Crop system', 'ADAPTATION_INVESTMENT_RATE*'\
		)
	~	Dmnl
	~		|

BASELINE PRODUCTION[CROPS I]=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Crop system', 'BASELINE_PRODUCTION*')
	~	kg/ha·year
	~		|

EXPOSED CROP RATE:=
	GET DIRECT DATA ('Historical.xlsx', 'Crop system', 'EXPOSED_CROP_RATE_TIME', 'EXPOSED_CROP_RATE'\
		)
	~	Dmnl
	~		|

DECAY RATE 1=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Crop system', 'DECAY_RATE_1*')
	~	Dmnl
	~		|

DECAY RATE 2=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Crop system', 'DECAY_RATE_2*')
	~	Dmnl
	~		|

DECREASE IN DIVERSIFICATION LEVEL=
	DECAY RATE 2*DIVERSIFICATION LEVEL
	~	Dmnl
	~		|

DIVERSIFICATION EFFICIENCY=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Crop system', 'DIVERSIFICATION_EFFICIENCY*'\
		)
	~	Dmnl
	~		|

INVESTMENT EXECUTION RATE FOR CROPLAND ADAPTATION=
	GET DIRECT CONSTANTS ('Policy.xlsx', 'Crop system', 'EXECUTION_RATE*')
	~	Dmnl
	~	GET DIRECT CONSTANTS ('Policy.xlsx', 'Crop system', 'EXECUTION_RATE*')
	|

INCREASE IN ADAPTATION CAPACITY=
	IF THEN ELSE(INVESTMENT FUNDS IN ADAPTATION=0, 0 , IF THEN ELSE(INVESTMENT FUNDS IN ADAPTATION\
		>0:AND:INVESTMENT FUNDS IN ADAPTATION<=20,0.25*ADAPTATION INVESTMENT RATE,IF THEN ELSE\
		(INVESTMENT FUNDS IN ADAPTATION>20:AND:INVESTMENT FUNDS IN ADAPTATION<=75,0.5*ADAPTATION INVESTMENT RATE\
		,IF THEN ELSE(INVESTMENT FUNDS IN ADAPTATION>75:AND:INVESTMENT FUNDS IN ADAPTATION<=\
		200,0.75*ADAPTATION INVESTMENT RATE,ADAPTATION INVESTMENT RATE))))
	~	Million Euros
	~	IF THEN ELSE(INVESTMENT FUNDS IN ADAPTATION=0, 0 , ((ADAPTATION INVESTMENT \
		RATE*INVESTMENT FUNDS IN ADAPTATION)/INVESTMENT FUNDS IN ADAPTATION))
	|

INVESTMENT FUNDS IN ADAPTATION= INTEG (
	ASIGNED BUDGET-USED BUDGET,
		0)
	~	Million Euros
	~		|

USED BUDGET=
	INVESTMENT EXECUTION RATE FOR CROPLAND ADAPTATION*INVESTMENT FUNDS IN ADAPTATION
	~	Million Euros
	~		|

INFILTRATION RATE=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', 'INFILTRATION_RATE*')
	~	Dmnl
	~		|

SECURITY COEFFICIENT=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', 'SECURITY_COEFFICIENT*')
	~	Dmnl
	~		|

EVAPORATION FROM STORAGE=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', 'EVAPORATION_FROM_STORAGE*'\
		)
	~	Dmnl
	~		|

REMAINING STORAGE WATER=
	TOTAL RESERVOIR CAPACITY*SECURITY COEFFICIENT
	~	Hm3
	~		|

INITIAL STORAGE=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', 'INITIAL_STORAGE*')
	~	Hm3
	~		|

ECOLOGICAL FLOW=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', 'ECOLOGICAL_FLOW*')
	~	Dmnl
	~	2592000 segundo s en un mes y 1hm3 se corresponde con 1000000m3
	|

INITIAL GROUNDWATER=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', 'INITIAL_GROUNDWATER*')
	~	Hm3
	~		|

M3 TO HM3=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', 'M3_TO_HM3*')
	~	Dmnl
	~		|

MM PER KM2 TO M3=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', 'MM_PER_KM2_TO_M3*')
	~	Dmnl
	~		|

PERCOLATION COEFFICIENT=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', 'PERCOLATION_COEFFICIENT*')
	~	Dmnl
	~		|

TO AQUIFER[MONTHS]=
	0.9*INFILTRATION[MONTHS]
	~	Hm3
	~		|

ANNUAL HOT INDEX=
	SUM(MONTHLY HOT INDEX[MONTHS!])
	~	
	~		|

COEFICIENT A=
	6.75e-07*(ANNUAL HOT INDEX)^3 - 7.71e-05*(ANNUAL HOT INDEX)^2 + 0.0179*ANNUAL HOT INDEX\
		 + 0.49239
	~	
	~		|

DEFICIT[MONTHS]=
	PET[MONTHS]-AET[MONTHS]
	~	mm
	~		|

MONTH DAYS[MONTHS]=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', 'MONTH_DAYS*')
	~	Days
	~		|

MONTHLY HOT INDEX[MONTHS]=
	IF THEN ELSE(TEMPERATURE[MONTHS] > 0, (TEMPERATURE[MONTHS]/5)^1.514, 0)
	~	Dmnl
	~		|

PET[MONTHS]=
	IF THEN ELSE(TEMPERATURE[MONTHS] > 0 :AND: ANNUAL HOT INDEX > 0, 16*POWER(((10*TEMPERATURE\
		[MONTHS]) / ANNUAL HOT INDEX), COEFICIENT A), 0)
	~	mm
	~		|

SNOWMELTING FACTOR=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', 'SNOWMELTING_FACTOR*')
	~	mm/ºc/dia
	~		|

SOIL WATER CAPACITY=
	GET DIRECT CONSTANTS ('Historical.xlsx', 'Water system', 'SOIL_WATER_CAPACITY*')
	~	mm
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 2060
	~	Year
	~	The final time for the simulation.
	|

INITIAL TIME  = 2018
	~	Year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Year [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Year [0,?]
	~	The time step for the simulation.
	|

